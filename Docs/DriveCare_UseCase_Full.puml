@startuml DriveCare_UseCase_Full
' Полная диаграмма вариантов использования DriveCare
' Открыть: https://www.plantuml.com/plantuml/uml/  или плагин PlantUML в VS Code

skinparam shadowing false
skinparam packageStyle rectangle
skinparam usecase {
  BackgroundColor #F5F8FF
  BorderColor #2563EB
  FontSize 11
}
skinparam actor {
  BackgroundColor #FFFFFF
  BorderColor #333333
}

top to bottom direction

actor "Клиент" as Client
actor "Сотрудник\nмастерской" as Worker
actor "Руководитель\nмастерской" as Owner
actor "Администратор\nплатформы" as Admin

rectangle "Информационная система DriveCare" as SYS {

  package "Общие" {
    usecase "UC-01\nРегистрация" as UC01
    usecase "UC-02\nАвторизация" as UC02
  }

  package "DriveCare — клиент (UC-10 … UC-23)" {
    usecase "UC-10\nУправление гаражом" as UC10
    usecase "UC-11\nУчёт обслуживания" as UC11
    usecase "UC-12\nПоиск мастерских" as UC12
    usecase "UC-13\nОнлайн-запись" as UC13
    usecase "UC-14\nЧат с сервисом" as UC14
    usecase "UC-15\nМагазин" as UC15
    usecase "UC-16\nОплата заказа" as UC16
    usecase "UC-17\nЗаявка на покраску" as UC17
    usecase "UC-18\nКаталог объявлений" as UC18
    usecase "UC-19\nПросмотр объявления" as UC19
    usecase "UC-20\nПубликация объявления" as UC20
    usecase "UC-21\nМои заказы" as UC21
    usecase "UC-22\nУведомления" as UC22
    usecase "UC-23\nПрофиль" as UC23
  }

  package "DriveCare Pro — сотрудник (UC-30 … UC-41)" {
    usecase "UC-30\nСписок заданий" as UC30
    usecase "UC-31\nВыполнение задания" as UC31
    usecase "UC-32\nЗавершение задания" as UC32
    usecase "UC-33\nДелегирование" as UC33
    usecase "UC-34\nЗакупка деталей" as UC34
    usecase "UC-35\nАвто в ремонте" as UC35
    usecase "UC-36\nЧат с клиентом" as UC36
    usecase "UC-37\nОнлайн-записи" as UC37
    usecase "UC-38\nПодтверждение записи" as UC38
    usecase "UC-39\nЗаказ-наряд" as UC39
    usecase "UC-40\nУведомления Pro" as UC40
    usecase "UC-41\nАрхив заданий" as UC41
  }

  package "DriveCare Pro — руководитель (UC-50 … UC-57)" {
    usecase "UC-50\nЗапись клиента" as UC50
    usecase "UC-51\nПерсонал" as UC51
    usecase "UC-52\nКонструктор ролей" as UC52
    usecase "UC-53\nКаталог услуг" as UC53
    usecase "UC-54\nПокраска и типы" as UC54
    usecase "UC-55\nСклад" as UC55
    usecase "UC-56\nРасписание" as UC56
    usecase "UC-57\nСтатистика орг." as UC57
  }

  package "Администратор платформы (UC-60 … UC-68)" {
    usecase "UC-60\nМодерация объявлений" as UC60
    usecase "UC-61\nМодерация типов" as UC61
    usecase "UC-62\nОрганизации" as UC62
    usecase "UC-63\nСоздание компании" as UC63
    usecase "UC-64\nСправочники" as UC64
    usecase "UC-65\nСистемные роли" as UC65
    usecase "UC-66\nРассылка" as UC66
    usecase "UC-67\nСтатистика платф." as UC67
    usecase "UC-68\nСводка БД" as UC68
  }
}

' ===== Клиент =====
Client --> UC01
Client --> UC02
Client --> UC10
Client --> UC11
Client --> UC12
Client --> UC13
Client --> UC14
Client --> UC15
Client --> UC16
Client --> UC17
Client --> UC18
Client --> UC19
Client --> UC20
Client --> UC21
Client --> UC22
Client --> UC23

' ===== Сотрудник =====
Worker --> UC02
Worker --> UC30
Worker --> UC31
Worker --> UC32
Worker --> UC33
Worker --> UC34
Worker --> UC35
Worker --> UC36
Worker --> UC37
Worker --> UC38
Worker --> UC39
Worker --> UC40
Worker --> UC41

' ===== Руководитель =====
Owner --> UC02
Owner --> UC30
Owner --> UC31
Owner --> UC32
Owner --> UC33
Owner --> UC36
Owner --> UC37
Owner --> UC38
Owner --> UC39
Owner --> UC40
Owner --> UC41
Owner --> UC50
Owner --> UC51
Owner --> UC52
Owner --> UC53
Owner --> UC54
Owner --> UC55
Owner --> UC56
Owner --> UC57

' ===== Администратор =====
Admin --> UC02
Admin --> UC60
Admin --> UC61
Admin --> UC62
Admin --> UC63
Admin --> UC64
Admin --> UC65
Admin --> UC66
Admin --> UC67
Admin --> UC68

' ===== Include =====
UC10 ..> UC02 : <<include>>
UC11 ..> UC02 : <<include>>
UC13 ..> UC02 : <<include>>
UC15 ..> UC02 : <<include>>
UC31 ..> UC02 : <<include>>
UC50 ..> UC02 : <<include>>
UC60 ..> UC02 : <<include>>

' ===== Extend =====
UC20 ..> UC60 : <<extend>>
