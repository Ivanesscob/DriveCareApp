<mah:MetroWindow x:Class="DriveCarePro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Icon="/DriveCareCore;component/Data/Pics/AppIcon.ico"
        Title="DriveCare Pro"
        Height="600"
        Width="900"
        WindowState="Maximized"
        GlowBrush="{DynamicResource MahApps.Metro.Brushes.Accent}"
        BorderThickness="0"
        Background="{DynamicResource App.Brush.Background}">
    <Grid>
        <Frame NavigationUIVisibility="Hidden" Content="{Binding MainFrame}" />
    </Grid>
</mah:MetroWindow>
