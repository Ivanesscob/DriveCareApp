<Page x:Class="DriveCarePro.Pages.WorkshopClientLookupPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Клиент">

    <Grid Background="{DynamicResource App.Brush.Panel}" Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button Content="← На главную" Style="{StaticResource App.Button.Outline}"
                HorizontalAlignment="Left" Height="40" MinWidth="130" Margin="0,0,0,16"
                Click="Back_Click"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel HorizontalAlignment="Center" MaxWidth="560" MinWidth="320">
                <Border CornerRadius="12" Padding="24,20"
                        Background="{DynamicResource App.Brush.SurfaceCard}"
                        BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock x:Name="TitleText" FontSize="18" FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource App.Brush.Foreground}"/>
                        <TextBlock Text="Укажите email или телефон клиента для поиска в системе."
                                   FontSize="13" TextWrapping="Wrap" TextAlignment="Center"
                                   Margin="0,8,0,16"
                                   Foreground="{DynamicResource App.Brush.Muted}"/>

                        <TextBlock Text="Email" FontSize="12" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,0,0,4"/>
                        <TextBox x:Name="EmailBox" MinHeight="36" Margin="0,0,0,12"/>

                        <TextBlock Text="Телефон" FontSize="12" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,0,0,4"/>
                        <TextBox x:Name="PhoneBox" MinHeight="36" Margin="0,0,0,16"/>

                        <WrapPanel HorizontalAlignment="Center">
                            <Button x:Name="BtnSearch" Content="Найти клиента" Style="{StaticResource App.Button.Primary}"
                                    Height="42" MinWidth="160" Margin="0,0,10,10" Click="Search_Click"/>
                            <Button Content="Зарегистрировать клиента" Style="{StaticResource App.Button.Outline}"
                                    Height="42" MinWidth="200" Margin="0,0,10,10" Click="Register_Click"/>
                            <Button Content="Продолжить без регистрации" Style="{StaticResource App.Button.Outline}"
                                    Height="42" MinWidth="220" Margin="0,0,0,10" Click="ContinueWithoutRegistration_Click"/>
                        </WrapPanel>
                        <TextBlock x:Name="NotFoundHintText" Visibility="Collapsed" Text="Клиент не найден. Зарегистрируйте или продолжите без регистрации."
                                   FontSize="12" TextWrapping="Wrap" TextAlignment="Center" Margin="0,4,0,0"
                                   Foreground="{DynamicResource App.Brush.Muted}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
