<Page x:Class="DriveCarePro.Pages.CompletedTasksPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Завершённые задания">

    <Grid Background="{DynamicResource App.Brush.Panel}" Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,16" LastChildFill="False">
            <Button DockPanel.Dock="Left" Content="← На главную" Style="{StaticResource App.Button.Outline}"
                    Height="40" MinWidth="130" Click="Back_Click"/>
            <Button DockPanel.Dock="Right" Content="Обновить" Style="{StaticResource App.Button.Outline}"
                    Height="40" MinWidth="110" Click="Refresh_Click"/>
        </DockPanel>

        <Border Grid.Row="1" Margin="0,0,0,12" CornerRadius="12" Padding="14,12"
                Background="{DynamicResource App.Brush.SurfaceCard}"
                BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Завершённые задания" FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource App.Brush.Foreground}"/>
                <TextBlock Text="Только просмотр. Двойной щелчок — открыть карточку и скачать заказ-наряд."
                           FontSize="12" Foreground="{DynamicResource App.Brush.Muted}" TextWrapping="Wrap" Margin="0,4,0,10"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="SearchBox" Grid.Column="0" Style="{StaticResource App.FieldTextBox}"
                             MinHeight="38" Margin="0,0,10,0"
                             ToolTip="VIN, госномер, клиент, автомобиль, исполнитель"/>
                    <Button Grid.Column="1" Content="Найти" Style="{StaticResource App.Button.Primary}"
                            Height="38" MinWidth="100" Click="Search_Click"/>
                </Grid>
                <TextBlock Text="Подсказка: введите VIN или часть номера — например WVWZZZ3CZWE123456"
                           FontSize="11" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,6,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" CornerRadius="12" Padding="16,14"
                Background="{DynamicResource App.Brush.SurfaceCard}"
                BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">
            <DataGrid x:Name="Grid" AutoGenerateColumns="False" IsReadOnly="True"
                      SelectionMode="Single" HeadersVisibility="Column" MinHeight="320"
                      MouseDoubleClick="Grid_MouseDoubleClick"
                      AlternatingRowBackground="{DynamicResource App.Brush.Surface2}"
                      Foreground="{DynamicResource App.Brush.Foreground}" RowHeight="36"
                      Background="Transparent" BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Задание" Binding="{Binding Title}" Width="*" MinWidth="140"/>
                    <DataGridTextColumn Header="VIN" Binding="{Binding Vin}" Width="150"/>
                    <DataGridTextColumn Header="Госномер" Binding="{Binding PlateNumber}" Width="100"/>
                    <DataGridTextColumn Header="Автомобиль" Binding="{Binding CarDisplay}" Width="1.5*" MinWidth="120"/>
                    <DataGridTextColumn Header="Клиент" Binding="{Binding ClientDisplay}" Width="*" MinWidth="100"/>
                    <DataGridTextColumn Header="Исполнитель" Binding="{Binding EmployeeName}" Width="*" MinWidth="110"/>
                    <DataGridTextColumn Header="Завершено" Binding="{Binding CompletedDisplay}" Width="130"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>
