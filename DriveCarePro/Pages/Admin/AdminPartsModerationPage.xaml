<Page x:Class="DriveCarePro.Pages.Admin.AdminPartsModerationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Модерация запчастей">

    <Grid Background="{DynamicResource App.Brush.Panel}" Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <Button Content="← На главную" Style="{StaticResource App.Button.Outline}"
                    Height="36" MinWidth="140" HorizontalAlignment="Left" Margin="0,0,0,12"
                    Click="BackHome_Click"/>
            <TextBlock Text="Запчасти" FontSize="20" FontWeight="SemiBold"
                       Foreground="{DynamicResource App.Brush.Foreground}"/>
            <TextBlock Text="Список последних позиций для контроля. Отдельные статусы модерации для запчастей можно подключить позже."
                       FontSize="13" Margin="0,6,0,0" Foreground="{DynamicResource App.Brush.Muted}" TextWrapping="Wrap"/>
            <Button Content="Обновить" Style="{StaticResource App.Button.Outline}" Height="36" MinWidth="120"
                    HorizontalAlignment="Left" Margin="0,12,0,0" Click="Refresh_Click"/>
        </StackPanel>

        <Border Grid.Row="1" CornerRadius="12" Padding="12" Background="{DynamicResource App.Brush.SurfaceCard}"
                BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">
            <DataGrid x:Name="PartsGrid" AutoGenerateColumns="True" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                      AlternatingRowBackground="{DynamicResource App.Brush.Surface2}"
                      Foreground="{DynamicResource App.Brush.Foreground}"
                      Background="Transparent" BorderThickness="0"/>
        </Border>
    </Grid>
</Page>
