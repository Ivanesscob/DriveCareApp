<Page x:Class="DriveCarePro.Pages.Admin.AdminTableBrowserPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Таблицы БД">

    <DockPanel Margin="28,24" LastChildFill="True">
        <Button DockPanel.Dock="Top" Content="← На главную" Style="{StaticResource App.Button.Outline}"
                Height="36" MinWidth="140" HorizontalAlignment="Left" Margin="0,0,0,14"
                Click="BackHome_Click"/>
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
            <TextBlock Text="Просмотр таблиц" FontSize="22" FontWeight="SemiBold"
                       Foreground="{DynamicResource App.Brush.Foreground}"/>
            <TextBlock Text="Выберите таблицу из белого списка и нажмите «Загрузить». До 300 строк, только чтение. Для правок используйте SSMS или отдельные формы."
                       FontSize="13" Margin="0,6,0,0" Foreground="{DynamicResource App.Brush.Muted}" TextWrapping="Wrap"/>
            <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                <ComboBox x:Name="TablePicker" Width="280" MinHeight="40" VerticalAlignment="Center"/>
                <Button Content="Загрузить" Style="{StaticResource App.Button.Primary}" Margin="12,0,0,0"
                        Height="40" MinWidth="120" Click="Load_Click"/>
            </StackPanel>
            <TextBlock x:Name="StatusText" Margin="0,10,0,0" FontSize="12"
                       Foreground="{DynamicResource App.Brush.SecondaryText}" TextWrapping="Wrap"/>
        </StackPanel>

        <DataGrid x:Name="Grid" AutoGenerateColumns="True"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="{DynamicResource App.Brush.Surface2}"
                  Background="{DynamicResource App.Brush.SurfaceCard}"
                  BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1"
                  Foreground="{DynamicResource App.Brush.Foreground}"
                  RowBackground="{DynamicResource App.Brush.SurfaceCard}"
                  HorizontalGridLinesBrush="{DynamicResource App.Brush.Border}"
                  VerticalGridLinesBrush="{DynamicResource App.Brush.Border}"/>
    </DockPanel>
</Page>
