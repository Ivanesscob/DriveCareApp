<Page x:Class="DriveCarePro.Pages.Admin.AdminOrganizationsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Организации">

    <DockPanel Margin="28,24" LastChildFill="True">
        <Button DockPanel.Dock="Top" Content="← На главную" Style="{StaticResource App.Button.Outline}"
                Height="36" MinWidth="140" HorizontalAlignment="Left" Margin="0,0,0,14"
                Click="BackHome_Click"/>
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
            <TextBlock Text="Организации и точки" FontSize="22" FontWeight="SemiBold"
                       Foreground="{DynamicResource App.Brush.Foreground}"/>
            <TextBlock Text="Компании, цеха и сотрудники. Заявки на вступление пока без отдельной таблицы — после добавления в БД появится список и кнопки одобрения."
                       FontSize="13" Margin="0,6,0,0" Foreground="{DynamicResource App.Brush.Muted}" TextWrapping="Wrap"/>
            <Border Margin="0,14,0,0" Padding="14,12" CornerRadius="12"
                    Background="{DynamicResource App.Brush.SurfaceCard}"
                    BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Заявки на вступление" FontWeight="SemiBold"
                               Foreground="{DynamicResource App.Brush.Foreground}"/>
                    <TextBlock Text="Нет записей в очереди (таблица заявок не подключена к модели)."
                               FontSize="13" Margin="0,6,0,0" Foreground="{DynamicResource App.Brush.SecondaryText}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Content="Создать компанию" Style="{StaticResource App.Button.Primary}"
                                Height="36" MinWidth="170" Margin="0,0,10,0" Click="CreateCompany_Click"/>
                        <Button Content="Обновить списки" Style="{StaticResource App.Button.Outline}"
                                Height="36" MinWidth="160" Click="Refresh_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <DockPanel Grid.Row="0">
                <TextBlock DockPanel.Dock="Top" Text="Компании" FontWeight="SemiBold" Margin="0,0,0,8"
                           Foreground="{DynamicResource App.Brush.Foreground}"/>
                <DataGrid x:Name="CompaniesGrid" AutoGenerateColumns="True" IsReadOnly="True"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                          AlternatingRowBackground="{DynamicResource App.Brush.Surface2}"
                          Background="{DynamicResource App.Brush.SurfaceCard}"
                          BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1"/>
            </DockPanel>
            <DockPanel Grid.Row="2">
                <TextBlock DockPanel.Dock="Top" Text="Цеха / мастерские" FontWeight="SemiBold" Margin="0,0,0,8"
                           Foreground="{DynamicResource App.Brush.Foreground}"/>
                <DataGrid x:Name="WorkshopsGrid" AutoGenerateColumns="True" IsReadOnly="True"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                          AlternatingRowBackground="{DynamicResource App.Brush.Surface2}"
                          Background="{DynamicResource App.Brush.SurfaceCard}"
                          BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1"/>
            </DockPanel>
        </Grid>
    </DockPanel>
</Page>
