<Page x:Class="DriveCarePro.Pages.Admin.AdminWorkshopTypesModerationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Модерация типов мастерских">

    <Grid Background="{DynamicResource App.Brush.Panel}" Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,16" LastChildFill="True">
            <Button DockPanel.Dock="Left" Content="← На главную" Style="{StaticResource App.Button.Outline}"
                    Height="40" MinWidth="140" Margin="0,0,12,0" Click="BackHome_Click"/>
            <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                <TextBlock Text="Типы мастерских" FontSize="20" FontWeight="SemiBold"
                           Foreground="{DynamicResource App.Brush.Foreground}"/>
                <TextBlock Text="Заявки владельцев на добавление покраски, шиномонтажа и др."
                           FontSize="12" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,4,0,0"/>
            </StackPanel>
            <Button DockPanel.Dock="Right" Content="Обновить" Style="{StaticResource App.Button.Outline}"
                    Height="40" MinWidth="120" Click="Refresh_Click"/>
        </DockPanel>

        <Border Grid.Row="1" CornerRadius="12" Padding="16,14"
                Background="{DynamicResource App.Brush.SurfaceCard}"
                BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock x:Name="HintText" Grid.Row="0" FontSize="13" Margin="0,0,0,12" TextWrapping="Wrap"
                           Foreground="{DynamicResource App.Brush.Muted}"/>
                <DataGrid x:Name="QueueGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                          SelectionMode="Single" HeadersVisibility="Column" MinHeight="220"
                          CanUserAddRows="False" CanUserDeleteRows="False"
                          AlternatingRowBackground="{DynamicResource App.Brush.Surface2}"
                          Foreground="{DynamicResource App.Brush.Foreground}" RowHeight="40"
                          Background="Transparent" BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Мастерская" Binding="{Binding WorkshopName}" Width="*" MinWidth="120"/>
                        <DataGridTextColumn Header="Компания" Binding="{Binding CompanyName}" Width="120"/>
                        <DataGridTextColumn Header="Сейчас" Binding="{Binding CurrentTypesLabel}" Width="130"/>
                        <DataGridTextColumn Header="Запрос" Binding="{Binding RequestedTypesLabel}" Width="130"/>
                        <DataGridTextColumn Header="Заявитель" Binding="{Binding RequesterName}" Width="120"/>
                        <DataGridTextColumn Header="Дата" Binding="{Binding CreatedAtDisplay}" Width="110"/>
                        <DataGridTemplateColumn Header="Действия" Width="200">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Одобрить" Tag="{Binding RequestId}"
                                                Style="{StaticResource App.Button.Primary}" Height="30" MinWidth="88"
                                                Margin="0,0,6,0" Click="Approve_Click"/>
                                        <Button Content="Отклонить" Tag="{Binding RequestId}"
                                                Style="{StaticResource App.Button.Outline}" Height="30" MinWidth="88"
                                                Click="Reject_Click"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Page>
