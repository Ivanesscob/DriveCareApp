<Page x:Class="DriveCarePro.Pages.Admin.AdminCarSaleReviewPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Проверка объявления">

    <Grid Background="{DynamicResource App.Brush.Panel}" Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="{Binding TitleText}" FontSize="22" FontWeight="SemiBold"
                       Foreground="{DynamicResource App.Brush.Foreground}" TextWrapping="Wrap"/>
            <TextBlock Text="{Binding CarText}" FontSize="14" Margin="0,6,0,0"
                       Foreground="{DynamicResource App.Brush.Muted}"/>
            <TextBlock Text="{Binding StatusText}" FontSize="13" Margin="0,8,0,0"
                       Foreground="{DynamicResource App.Brush.Accent}" FontWeight="SemiBold"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="12" Background="{DynamicResource App.Brush.Surface2}"
                    BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1" Padding="12" Margin="0,0,14,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" CornerRadius="10" Background="{DynamicResource App.Brush.PhotoMat}" ClipToBounds="True" MinHeight="220">
                        <Image Source="{Binding CurrentPhoto}" Stretch="Uniform"/>
                    </Border>
                    <Grid Grid.Row="1" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="◀" Width="42" Height="32" Margin="0,0,8,0"
                                Style="{StaticResource App.Button.Outline}" Click="PrevPhoto_Click"/>
                        <TextBlock Grid.Column="1" Text="{Binding PhotoPositionText}"
                                   Foreground="{DynamicResource App.Brush.Muted}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Button Grid.Column="2" Content="▶" Width="42" Height="32" Margin="8,0,0,0"
                                Style="{StaticResource App.Button.Outline}" Click="NextPhoto_Click"/>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="1" CornerRadius="12" Background="{DynamicResource App.Brush.Surface2}"
                    BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1" Padding="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="{Binding PriceText}" FontSize="26" FontWeight="SemiBold"
                                   Foreground="{DynamicResource App.Brush.Foreground}"/>
                        <TextBlock Text="{Binding SellerText}" FontSize="13" Margin="0,8,0,0"
                                   Foreground="{DynamicResource App.Brush.Muted}"/>
                        <TextBlock Text="Описание" FontSize="15" FontWeight="SemiBold" Margin="0,16,0,6"
                                   Foreground="{DynamicResource App.Brush.Foreground}"/>
                        <TextBlock Text="{Binding DescriptionText}" TextWrapping="Wrap"
                                   Foreground="{DynamicResource App.Brush.SecondaryText}"/>
                        <TextBlock Text="Модель" FontSize="15" FontWeight="SemiBold" Margin="0,14,0,6"
                                   Foreground="{DynamicResource App.Brush.Foreground}"/>
                        <TextBlock Text="{Binding ModelInfoText}" TextWrapping="Wrap"
                                   Foreground="{DynamicResource App.Brush.SecondaryText}"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,18,0,0">
            <Button Content="Назад" Style="{StaticResource App.Button.Outline}" Height="42" MinWidth="120" Click="Back_Click"/>
            <Button Content="Вернуть на корректировку" Style="{StaticResource App.Button.Outline}" Height="42" MinWidth="220"
                    Margin="12,0,0,0" Click="Reject_Click"/>
            <Button Content="Одобрить" Style="{StaticResource App.Button.Primary}" Height="42" MinWidth="140"
                    Margin="12,0,0,0" Click="Approve_Click"/>
        </StackPanel>
    </Grid>
</Page>
