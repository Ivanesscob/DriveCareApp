<Page x:Class="DriveCarePro.Pages.WorkshopPaintShopSettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Покраска и типы мастерской"
      Background="{DynamicResource App.Brush.Panel}">
    <Grid Margin="24,18,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,14" LastChildFill="False">
            <Button DockPanel.Dock="Left" Content="← Назад" Style="{StaticResource App.Button.Outline}"
                    Height="40" MinWidth="110" Click="Back_Click"/>
            <StackPanel DockPanel.Dock="Left" Margin="16,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="Покраска и типы мастерской" FontSize="22" FontWeight="SemiBold"
                           Foreground="{DynamicResource App.Brush.Foreground}"/>
                <TextBlock x:Name="HintText" FontSize="13" Foreground="{DynamicResource App.Brush.Muted}"
                           Margin="0,4,0,0" TextWrapping="Wrap"/>
            </StackPanel>
            <Button x:Name="BtnSaveTypes" DockPanel.Dock="Right" Content="Отправить на согласование"
                    Style="{StaticResource App.Button.Primary}"
                    Height="40" MinWidth="190" Click="SaveTypes_Click"/>
        </DockPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="900">

                <Border CornerRadius="12" Padding="16" Margin="0,0,0,16"
                        Background="{DynamicResource App.Brush.SurfaceCard}"
                        BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Типы мастерской на карте" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource App.Brush.Foreground}"/>
                        <TextBlock Text="Можно выбрать несколько: автосервис, покраска и шиномонтаж в одной точке."
                                   FontSize="12" Foreground="{DynamicResource App.Brush.Muted}"
                                   TextWrapping="Wrap" Margin="0,6,0,8"/>
                        <TextBlock x:Name="TypesStatusText" FontSize="12"
                                   Foreground="{DynamicResource App.Brush.Accent}"
                                   TextWrapping="Wrap" Margin="0,0,0,12" Visibility="Collapsed"/>
                        <CheckBox x:Name="ChkAutoService" Content="Автосервис" Margin="0,0,0,8"/>
                        <CheckBox x:Name="ChkPainting" Content="Покраска" Margin="0,0,0,8"/>
                        <CheckBox x:Name="ChkTireService" Content="Шиномонтаж"/>
                    </StackPanel>
                </Border>

                <Border CornerRadius="12" Padding="16" Margin="0,0,0,16"
                        Background="{DynamicResource App.Brush.SurfaceCard}"
                        BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Цвета покраски" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource App.Brush.Foreground}" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="+ Добавить цвет"
                                    Style="{StaticResource App.Button.Outline}" Height="36"
                                    Click="AddColor_Click"/>
                        </Grid>
                        <TextBlock Text="Клиенты увидят эти цвета при выборе молярки на карте."
                                   FontSize="12" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,0,0,8"/>
                        <DataGrid x:Name="ColorsGrid" AutoGenerateColumns="False" IsReadOnly="True"
                                  HeadersVisibility="Column" CanUserAddRows="False" MinHeight="80" MaxHeight="200">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Цвет" Binding="{Binding ColorName}" Width="*"/>
                                <DataGridTemplateColumn Header="" Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Удалить" Tag="{Binding RowId}"
                                                    Style="{StaticResource App.Button.Outline}" Height="28"
                                                    Click="DeleteColor_Click"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <Border CornerRadius="12" Padding="16"
                        Background="{DynamicResource App.Brush.SurfaceCard}"
                        BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Что красят (услуги)" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource App.Brush.Foreground}" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="+ Добавить услугу"
                                    Style="{StaticResource App.Button.Outline}" Height="36"
                                    Click="AddService_Click"/>
                        </Grid>
                        <DataGrid x:Name="ServicesGrid" AutoGenerateColumns="False" IsReadOnly="True"
                                  HeadersVisibility="Column" CanUserAddRows="False" MinHeight="100">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Услуга" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="Тип" Binding="{Binding KindTitle}" Width="140"/>
                                <DataGridTextColumn Header="Цена" Binding="{Binding PriceDisplay}" Width="100"/>
                                <DataGridTemplateColumn Header="" Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Удалить" Tag="{Binding RowId}"
                                                    Style="{StaticResource App.Button.Outline}" Height="28"
                                                    Click="DeleteService_Click"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
