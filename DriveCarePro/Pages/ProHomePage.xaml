<Page x:Class="DriveCarePro.Pages.ProHomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="DriveCare Pro">

    <Grid Background="{DynamicResource App.Brush.Panel}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="24,18,24,12" LastChildFill="False">
            <TextBlock DockPanel.Dock="Left" Text="DriveCare Pro" FontSize="22" FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource App.Brush.Foreground}"/>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="BtnEmployeeNotifications" Style="{StaticResource App.Button.Outline}"
                        Height="40" Width="40" Margin="0,0,10,0" Padding="0"
                        Click="EmployeeNotificationsButton_Click"
                        ToolTip="Уведомления по заданиям">
                    <Grid>
                        <Image Width="20" Height="20"
                               Source="pack://application:,,,/DriveCareCore;component/Data/Pics/Notification.png"/>
                        <Border x:Name="NotificationsBadge" Background="#E53935" CornerRadius="7"
                                Width="14" Height="14" HorizontalAlignment="Right" VerticalAlignment="Top"
                                Margin="0,-4,-4,0" Visibility="Collapsed">
                            <TextBlock x:Name="NotificationsBadgeText" Text="!" FontSize="9" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Button>
                <Button Content="Профиль" Style="{StaticResource App.Button.Outline}"
                        Height="40" MinWidth="120"
                        Click="Profile_Click"/>
            </StackPanel>

            <Popup x:Name="EmployeeNotificationsPopup"
                   PlacementTarget="{Binding ElementName=BtnEmployeeNotifications}"
                   Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                <Border Background="{DynamicResource App.Brush.PopupSurface}"
                        BorderBrush="{DynamicResource App.Brush.PopupBorder}"
                        BorderThickness="1" CornerRadius="12"
                        MinWidth="340" MaxWidth="380" Padding="10" Margin="0,8,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Уведомления"
                                   Foreground="{DynamicResource App.Brush.Foreground}"
                                   FontSize="15" FontWeight="SemiBold" Margin="4,2,0,8"/>
                        <Grid Grid.Row="1">
                            <TextBlock Text="Нет уведомлений"
                                       Foreground="{DynamicResource App.Brush.Muted}"
                                       FontSize="13" TextAlignment="Center" VerticalAlignment="Center"
                                       Visibility="{Binding NoNotificationsVisibility}"/>
                            <ListBox x:Name="EmployeeNotificationsList"
                                     ItemsSource="{Binding EmployeeNotificationItems}"
                                     Visibility="{Binding NotificationsListVisibility}"
                                     Background="Transparent" BorderThickness="0"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto" MaxHeight="300"
                                     MouseLeftButtonUp="EmployeeNotificationsList_Click">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Margin" Value="0,0,0,8"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource App.Brush.NotificationCardBg}"
                                                BorderBrush="{DynamicResource App.Brush.Border}"
                                                BorderThickness="1" CornerRadius="8" Padding="10">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="13"
                                                           Foreground="{DynamicResource App.Brush.Foreground}"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Text}" FontSize="12" Margin="0,4,0,0"
                                                           Foreground="{DynamicResource App.Brush.Muted}"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Text="Открыть задание →" FontSize="11" Margin="0,6,0,0"
                                                           Foreground="{DynamicResource App.Brush.Accent}"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Grid>
                </Border>
            </Popup>
        </DockPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled" Padding="0,0,0,24">
            <StackPanel MaxWidth="960" Margin="24,0,24,0" HorizontalAlignment="Center">

                <!-- Платформенный администратор -->
                <Border x:Name="AdminPanelCard" CornerRadius="16" Padding="24,20"
                        Background="{DynamicResource App.Brush.SurfaceCard}"
                        BorderBrush="{DynamicResource App.Brush.Accent}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Панель администратора" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource App.Brush.Accent}"/>
                        <TextBlock Text="Модерация, организации, справочники и настройки платформы."
                                   FontSize="12" Foreground="{DynamicResource App.Brush.Muted}"
                                   TextWrapping="Wrap" Margin="0,4,0,16"/>

                        <Border x:Name="AdminStatsSection" Margin="0,0,0,14" Padding="14,12" CornerRadius="12"
                                Background="{DynamicResource App.Brush.Surface2}"
                                BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">
                            <UniformGrid Columns="3" Rows="2">
                                <StackPanel Margin="0,0,8,10">
                                    <TextBlock Text="Пользователи" FontSize="11" Foreground="{DynamicResource App.Brush.Muted}"/>
                                    <TextBlock x:Name="CntUsers" FontSize="22" FontWeight="SemiBold"
                                               Foreground="{DynamicResource App.Brush.Foreground}" Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,8,10">
                                    <TextBlock Text="Сотрудники" FontSize="11" Foreground="{DynamicResource App.Brush.Muted}"/>
                                    <TextBlock x:Name="CntEmployees" FontSize="22" FontWeight="SemiBold"
                                               Foreground="{DynamicResource App.Brush.Foreground}" Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="Объявления" FontSize="11" Foreground="{DynamicResource App.Brush.Muted}"/>
                                    <TextBlock x:Name="CntCarSales" FontSize="22" FontWeight="SemiBold"
                                               Foreground="{DynamicResource App.Brush.Foreground}" Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="Запчасти" FontSize="11" Foreground="{DynamicResource App.Brush.Muted}"/>
                                    <TextBlock x:Name="CntParts" FontSize="22" FontWeight="SemiBold"
                                               Foreground="{DynamicResource App.Brush.Foreground}" Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="Компании" FontSize="11" Foreground="{DynamicResource App.Brush.Muted}"/>
                                    <TextBlock x:Name="CntCompanies" FontSize="22" FontWeight="SemiBold"
                                               Foreground="{DynamicResource App.Brush.Foreground}" Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Автомобили" FontSize="11" Foreground="{DynamicResource App.Brush.Muted}"/>
                                    <TextBlock x:Name="CntCars" FontSize="22" FontWeight="SemiBold"
                                               Foreground="{DynamicResource App.Brush.Foreground}" Margin="0,4,0,0"/>
                                </StackPanel>
                            </UniformGrid>
                        </Border>

                        <Border x:Name="QuickActionsSection" Margin="0,0,0,14" Padding="14,12" CornerRadius="12"
                                Background="{DynamicResource App.Brush.Surface2}"
                                BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Быстрые действия" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource App.Brush.Foreground}" Margin="0,0,0,10"/>
                                <WrapPanel Orientation="Horizontal">
                                    <Button x:Name="BtnQuickAddCompany" Content="Добавить компанию"
                                            Style="{StaticResource App.Button.Primary}"
                                            Height="40" MinWidth="170" Margin="0,0,10,8"
                                            Click="QuickAddCompany_Click"/>
                                    <Button x:Name="BtnQuickAddPermissions" Content="Добавить разрешения"
                                            Style="{StaticResource App.Button.Outline}"
                                            Height="40" MinWidth="180" Margin="0,0,10,8"
                                            Click="QuickAddPermissions_Click"/>
                                    <Button x:Name="BtnQuickAddRoles" Content="Добавить роли"
                                            Style="{StaticResource App.Button.Outline}"
                                            Height="40" MinWidth="150" Margin="0,0,10,8"
                                            Click="QuickAddRoles_Click"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <WrapPanel x:Name="AdminActionsPanel">
                            <Button x:Name="BtnModerationCars"
                                    Style="{StaticResource App.Button.Primary}"
                                    Height="42" MinWidth="190" Margin="0,0,10,10"
                                    Click="ModerationCars_Click">
                                <Grid>
                                    <TextBlock Text="Модерация объявлений" VerticalAlignment="Center" HorizontalAlignment="Center"
                                               Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"/>
                                    <Border x:Name="ModerationCarsBadge" Background="#E53935" CornerRadius="9"
                                            MinWidth="18" Height="18" Padding="4,0"
                                            HorizontalAlignment="Right" VerticalAlignment="Top"
                                            Margin="0,-6,-6,0" Visibility="Collapsed">
                                        <TextBlock x:Name="ModerationCarsBadgeText" FontSize="10" FontWeight="Bold"
                                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Button>
                            <Button x:Name="BtnModerationParts"
                                    Style="{StaticResource App.Button.Outline}"
                                    Height="42" MinWidth="190" Margin="0,0,10,10"
                                    Click="ModerationParts_Click">
                                <Grid>
                                    <TextBlock Text="Модерация запчастей" VerticalAlignment="Center" HorizontalAlignment="Center"
                                               Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"/>
                                    <Border x:Name="ModerationPartsBadge" Background="#E53935" CornerRadius="9"
                                            MinWidth="18" Height="18" Padding="4,0"
                                            HorizontalAlignment="Right" VerticalAlignment="Top"
                                            Margin="0,-6,-6,0" Visibility="Collapsed">
                                        <TextBlock x:Name="ModerationPartsBadgeText" FontSize="10" FontWeight="Bold"
                                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Button>
                            <Button x:Name="BtnModerationWorkshopTypes"
                                    Style="{StaticResource App.Button.Outline}"
                                    Height="42" MinWidth="190" Margin="0,0,10,10"
                                    Click="ModerationWorkshopTypes_Click">
                                <Grid>
                                    <TextBlock Text="Типы мастерских" VerticalAlignment="Center" HorizontalAlignment="Center"
                                               Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"/>
                                    <Border x:Name="ModerationWorkshopTypesBadge" Background="#E53935" CornerRadius="9"
                                            MinWidth="18" Height="18" Padding="4,0"
                                            HorizontalAlignment="Right" VerticalAlignment="Top"
                                            Margin="0,-6,-6,0" Visibility="Collapsed">
                                        <TextBlock x:Name="ModerationWorkshopTypesBadgeText" FontSize="10" FontWeight="Bold"
                                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Button>
                            <Button x:Name="BtnOrganizations" Content="Организации"
                                    Style="{StaticResource App.Button.Outline}"
                                    Height="42" MinWidth="150" Margin="0,0,10,10"
                                    Click="AdminOrganizations_Click"/>
                            <Button x:Name="BtnSystemRoles" Content="Системные роли"
                                    Style="{StaticResource App.Button.Outline}"
                                    Height="42" MinWidth="160" Margin="0,0,10,10"
                                    Click="AdminSystemRoles_Click"/>
                            <Button x:Name="BtnDirectories" Content="Справочники"
                                    Style="{StaticResource App.Button.Outline}"
                                    Height="42" MinWidth="150" Margin="0,0,10,10"
                                    Click="AdminDirectories_Click"/>
                            <Button x:Name="BtnNotifications" Content="Уведомления"
                                    Style="{StaticResource App.Button.Outline}"
                                    Height="42" MinWidth="150" Margin="0,0,10,10"
                                    Click="AdminBroadcast_Click"/>
                            <Button x:Name="BtnStatisticsAdmin" Content="Статистика"
                                    Style="{StaticResource App.Button.Outline}"
                                    Height="42" MinWidth="150" Margin="0,0,10,10"
                                    Click="Statistics_Click"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- Сотрудник организации -->
                <Border x:Name="EmployeePanelCard" Margin="0,16,0,0" CornerRadius="16" Padding="24,20"
                        Background="{DynamicResource App.Brush.SurfaceCard}"
                        BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Рабочая панель" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource App.Brush.Foreground}"/>
                        <TextBlock Text="Сотрудники, роли организации, сервис и задания вашей компании."
                                   FontSize="12" Foreground="{DynamicResource App.Brush.Muted}"
                                   TextWrapping="Wrap" Margin="0,4,0,16"/>

                        <TextBlock x:Name="SectionOrgLabel" Text="Организация" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource App.Brush.Accent}" Margin="0,0,0,8"/>
                        <WrapPanel x:Name="OrgActionsPanel" Margin="0,0,0,14">
                            <Button x:Name="BtnManageEmployees" Content="Управление сотрудниками"
                                    Style="{StaticResource App.Button.Primary}"
                                    Height="42" MinWidth="220" Margin="0,0,10,10"
                                    Click="ManageEmployees_Click"/>
                            <Button x:Name="BtnRolesConstructor" Content="Конструктор ролей"
                                    Style="{StaticResource App.Button.Outline}"
                                    Height="42" MinWidth="180" Margin="0,0,10,10"
                                    Click="RolesConstructor_Click"/>
                            <Button x:Name="BtnStatisticsOrg" Content="Статистика"
                                    Style="{StaticResource App.Button.Outline}"
                                    Height="42" MinWidth="150" Margin="0,0,10,10"
                                    Click="Statistics_Click"/>
                        </WrapPanel>

                        <TextBlock x:Name="SectionWorkLabel" Text="Сервис" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource App.Brush.Accent}" Margin="0,0,0,8"/>
                        <WrapPanel x:Name="WorkActionsPanel" Margin="0,0,0,14">
                            <Button x:Name="BtnBookRepair" Content="Записать машину на ремонт"
                                    Style="{StaticResource App.Button.Primary}"
                                    Height="42" MinWidth="220" Margin="0,0,10,10"
                                    Click="BookRepair_Click"/>
                            <Button x:Name="BtnBookPainting" Content="Записать машину на покраску"
                                    Style="{StaticResource App.Button.Outline}"
                                    Height="42" MinWidth="240" Margin="0,0,10,10"
                                    Click="BookPainting_Click"/>
                            <Button x:Name="BtnRepairCars" Content="Автомобили в ремонте"
                                    Style="{StaticResource App.Button.Outline}"
                                    Height="42" MinWidth="190" Margin="0,0,10,10"
                                    Click="RepairCars_Click"/>
                            <Button x:Name="BtnWorkshopServices" Content="Услуги мастерской"
                                    Style="{StaticResource App.Button.Outline}"
                                    Height="42" MinWidth="190" Margin="0,0,10,10"
                                    Click="WorkshopServices_Click"/>
                            <Button x:Name="BtnPaintShopSettings" Content="Покраска и типы"
                                    Style="{StaticResource App.Button.Outline}"
                                    Height="42" MinWidth="190" Margin="0,0,10,10"
                                    Click="PaintShopSettings_Click"/>
                            <Button x:Name="BtnShop" Content="Магазин"
                                    Style="{StaticResource App.Button.Outline}"
                                    Height="42" MinWidth="140" Margin="0,0,10,10"
                                    Click="Shop_Click"/>
                            <Button x:Name="BtnOnlineBookings" Content="Онлайн-записи"
                                    Style="{StaticResource App.Button.Outline}"
                                    Height="42" MinWidth="170" Margin="0,0,10,10"
                                    Click="OnlineBookings_Click"/>
                            <Button x:Name="BtnWorkSchedule" Content="Расписание работы"
                                    Style="{StaticResource App.Button.Outline}"
                                    Height="42" MinWidth="180" Margin="0,0,10,10"
                                    Click="WorkSchedule_Click"/>
                            <Button x:Name="BtnClientMessages"
                                    Style="{StaticResource App.Button.Outline}"
                                    Height="42" MinWidth="200" Margin="0,0,10,10"
                                    Click="ClientMessages_Click"
                                    ToolTip="Сообщения клиентам">
                                <Grid>
                                    <TextBlock Text="Сообщения клиентам" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <Border x:Name="ClientMessagesBadge" Background="#E53935" CornerRadius="8"
                                            MinWidth="18" Height="18" Padding="4,0"
                                            HorizontalAlignment="Right" VerticalAlignment="Top"
                                            Margin="0,-6,-6,0" Visibility="Collapsed">
                                        <TextBlock x:Name="ClientMessagesBadgeText" Text="1" FontSize="10" FontWeight="Bold"
                                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Button>
                        </WrapPanel>

                        <Border x:Name="EmployeeTasksSection" Padding="14,12" CornerRadius="12"
                                Background="{DynamicResource App.Brush.Surface2}"
                                BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock x:Name="TasksSectionTitle" Text="Мои задания" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource App.Brush.Foreground}"/>
                                <TextBlock Text="Дерево заданий по документам. Двойной щелчок — открыть. Завершённые — в архиве."
                                           FontSize="12" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,4,0,10"/>
                                <Button x:Name="BtnCompletedTasks" Content="Завершённые задания"
                                        Style="{StaticResource App.Button.Outline}" Height="36" MinWidth="200"
                                        HorizontalAlignment="Left" Margin="0,0,0,10"
                                        Click="CompletedTasks_Click"/>
                                <TreeView x:Name="TasksTree" MinHeight="180" MaxHeight="400"
                                          Background="Transparent" BorderThickness="0"
                                          MouseDoubleClick="TasksTree_MouseDoubleClick">
                                    <TreeView.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Открыть задание" Click="OpenTaskFromTreeMenu_Click"/>
                                            <Separator/>
                                            <MenuItem Header="Обновить список" Click="RefreshTasks_Click"/>
                                        </ContextMenu>
                                    </TreeView.ContextMenu>
                                    <TreeView.ItemTemplate>
                                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                            <Border Padding="6,4" CornerRadius="6" Margin="0,2">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                                        <Setter Property="BorderThickness" Value="1"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsReadyToComplete}" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource App.ComboItemSelected}"/>
                                                                <Setter Property="BorderBrush" Value="{DynamicResource App.Brush.Accent}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding LevelNumber}" FontSize="13" FontWeight="SemiBold"
                                                               MinWidth="44" Foreground="{DynamicResource App.Brush.Accent}"/>
                                                    <TextBlock Text="{Binding Title}" FontSize="13" MaxWidth="300" TextTrimming="CharacterEllipsis"
                                                               Foreground="{DynamicResource App.Brush.Foreground}" ToolTip="{Binding Title}"/>
                                                    <TextBlock Text="{Binding EmployeeName}" FontSize="12" Margin="12,0,0,0"
                                                               Foreground="{DynamicResource App.Brush.Muted}"/>
                                                    <TextBlock Text="{Binding StatusDisplay}" FontSize="12" Margin="8,0,0,0"
                                                               Foreground="{DynamicResource App.Brush.SecondaryText}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground"
                                                                        Value="{DynamicResource App.Brush.SecondaryText}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsReadyToComplete}" Value="True">
                                                                        <Setter Property="Foreground"
                                                                                Value="{DynamicResource App.Brush.Accent}"/>
                                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                        </HierarchicalDataTemplate>
                                    </TreeView.ItemTemplate>
                                </TreeView>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="NoAccessHint" Margin="0,20,0,0" FontSize="13" TextWrapping="Wrap"
                           Foreground="{DynamicResource App.Brush.Muted}" TextAlignment="Center"
                           Text="Нет доступных разделов. Обратитесь к администратору платформы."
                           Visibility="Collapsed"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
