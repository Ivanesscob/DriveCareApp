<Page x:Class="DriveCarePro.Pages.StatisticsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Статистика"
      Background="{DynamicResource App.Brush.Panel}">
    <Grid Margin="24,18,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,12" LastChildFill="False">
            <Button DockPanel.Dock="Left" Content="← На главную" Style="{StaticResource App.Button.Outline}"
                    Height="40" MinWidth="130" Click="Back_Click"/>
            <TextBlock DockPanel.Dock="Left" Text="Статистика" FontSize="22" FontWeight="SemiBold"
                       Margin="16,0,0,0" VerticalAlignment="Center"
                       Foreground="{DynamicResource App.Brush.Foreground}"/>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <ComboBox x:Name="PeriodCombo" Width="150" Height="36" Margin="0,0,8,0"
                          SelectionChanged="PeriodCombo_SelectionChanged"/>
                <Button Content="Обновить" Style="{StaticResource App.Button.Outline}"
                        Height="36" MinWidth="100" Click="Refresh_Click"/>
            </StackPanel>
        </DockPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock x:Name="ScopeHintText" FontSize="12" Foreground="{DynamicResource App.Brush.Muted}" TextWrapping="Wrap"/>
            <TextBlock x:Name="TotalHintText" FontSize="13" FontWeight="SemiBold" Margin="0,6,0,0"
                       Foreground="{DynamicResource App.Brush.Foreground}"/>
            <TextBlock x:Name="MissingTableText" FontSize="12" Foreground="#C62828" TextWrapping="Wrap"
                       Margin="0,8,0,0" Visibility="Collapsed"/>
        </StackPanel>

        <TabControl Grid.Row="2" Background="Transparent" BorderThickness="0">
            <TabItem Header="Сводка">
                <Border CornerRadius="12" Padding="4" Margin="0,8,0,0"
                        Background="{DynamicResource App.Brush.SurfaceCard}"
                        BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">
                    <DataGrid x:Name="SummaryGrid" AutoGenerateColumns="False" IsReadOnly="True"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              Background="Transparent" BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Действие" Binding="{Binding Title}" Width="*"/>
                            <DataGridTextColumn Header="Код" Binding="{Binding EventCode}" Width="200"/>
                            <DataGridTextColumn Header="Количество" Binding="{Binding Count}" Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>
            <TabItem Header="Объявления (просмотры)">
                <Border CornerRadius="12" Padding="4" Margin="0,8,0,0"
                        Background="{DynamicResource App.Brush.SurfaceCard}"
                        BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">
                    <DataGrid x:Name="CarViewsGrid" AutoGenerateColumns="False" IsReadOnly="True"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              Background="Transparent" BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Объявление" Binding="{Binding Label}" Width="*"/>
                            <DataGridTextColumn Header="Просмотров" Binding="{Binding ViewCount}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>
            <TabItem Header="Журнал событий">
                <Border CornerRadius="12" Padding="4" Margin="0,8,0,0"
                        Background="{DynamicResource App.Brush.SurfaceCard}"
                        BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">
                    <DataGrid x:Name="EventsGrid" AutoGenerateColumns="False" IsReadOnly="True"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              Background="Transparent" BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Время" Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy HH:mm}" Width="130"/>
                            <DataGridTextColumn Header="Событие" Binding="{Binding Title}" Width="220"/>
                            <DataGridTextColumn Header="Кто" Binding="{Binding ActorLabel}" Width="150"/>
                            <DataGridTextColumn Header="Объект" Binding="{Binding EntityLabel}" Width="160"/>
                            <DataGridTextColumn Header="Детали" Binding="{Binding PayloadJson}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</Page>
