<Page x:Class="DriveCarePro.Pages.LoginPages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Вход"
      Background="Transparent"
      PreviewKeyDown="Page_PreviewKeyDown">

    <Page.Resources>
        <Style x:Key="LoginFieldBorder" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderBrush" Value="{DynamicResource App.Brush.LoginBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource App.Brush.LoginFieldBg}"/>
            <Setter Property="Padding" Value="2"/>
        </Style>
        <Style x:Key="LoginInnerTextBox" TargetType="TextBox" BasedOn="{StaticResource App.FieldTextBox}">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="15"/>
        </Style>
        <Style x:Key="LoginInnerPasswordBox" TargetType="PasswordBox" BasedOn="{StaticResource App.FieldPasswordBox}">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="15"/>
        </Style>
    </Page.Resources>

    <Grid Background="{DynamicResource App.Brush.LoginShellBackground}">
        <Ellipse Width="420" Height="420" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-120,-120,0"
                 IsHitTestVisible="False" Opacity="0.22" Fill="{DynamicResource App.Brush.Accent}"/>
        <Ellipse Width="320" Height="320" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-80,0,0,-80"
                 IsHitTestVisible="False" Opacity="0.12" Fill="{DynamicResource App.Brush.AccentDim}"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="24" VerticalAlignment="Center">
                <Border MaxWidth="440" HorizontalAlignment="Center" Padding="40,36" CornerRadius="20"
                        Background="{DynamicResource App.Brush.LoginSurface}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="36" ShadowDepth="0" Opacity="0.5" Color="#000000"/>
                    </Border.Effect>

                    <StackPanel>
                        <StackPanel HorizontalAlignment="Center" Margin="0,0,0,8">
                            <Border Width="56" Height="56" CornerRadius="16"
                                    Background="{DynamicResource App.Brush.SurfaceElevated}"
                                    BorderBrush="{DynamicResource App.Brush.BorderStrong}" BorderThickness="1"
                                    HorizontalAlignment="Center" Margin="0,0,0,16"
                                    ClipToBounds="True" Padding="6">
                                <Image Source="/DriveCareCore;component/Data/Pics/AppIcon.ico"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Добро пожаловать" FontSize="26" FontWeight="SemiBold"
                                       Foreground="{DynamicResource App.Brush.Foreground}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Войдите в DriveCare Pro" FontSize="15"
                                       Foreground="{DynamicResource App.Brush.Muted}"
                                       HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>

                        <TextBlock Text="Логин" Foreground="{DynamicResource App.Brush.Muted}" FontSize="12" Margin="0,28,0,6"/>
                        <Border Style="{StaticResource LoginFieldBorder}" Margin="0,0,0,16">
                            <TextBox x:Name="UsernameInput" Style="{StaticResource LoginInnerTextBox}"
                                     Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>
                        </Border>

                        <TextBlock Text="Пароль" Foreground="{DynamicResource App.Brush.Muted}" FontSize="12" Margin="0,0,0,6"/>
                        <Border Style="{StaticResource LoginFieldBorder}" Margin="0,0,0,8">
                            <PasswordBox x:Name="PasswordInput"
                                         Style="{StaticResource LoginInnerPasswordBox}"/>
                        </Border>

                        <TextBlock Text="Забыли пароль? Свяжитесь с администратором."
                                   Foreground="{DynamicResource App.Brush.Muted}" FontSize="12"
                                   Margin="0,0,0,12" TextWrapping="Wrap" HorizontalAlignment="Right"/>

                        <Border x:Name="ConnectionErrorBanner" Margin="0,0,0,12" Padding="12,10"
                                CornerRadius="10" Background="#33E57373"
                                BorderBrush="#E57373" BorderThickness="1" Visibility="Collapsed">
                            <TextBlock x:Name="ConnectionErrorText" FontSize="12" TextWrapping="Wrap"
                                       Foreground="#FFCDD2"/>
                        </Border>

                        <Button Content="Войти"
                                Command="{Binding LoginCommand}"
                                IsDefault="True"
                                Style="{StaticResource App.Button.Primary}"
                                Height="50" FontSize="16" FontWeight="SemiBold"
                                Margin="0,0,0,12"/>

                        <Button Content="Регистрация"
                                Command="{Binding RegisterCommand}"
                                Style="{StaticResource App.Button.Outline}"
                                Height="48" FontSize="15" FontWeight="SemiBold"
                                Margin="0,0,0,0"/>

                        <TextBlock Text="Нажимая «Войти», вы соглашаетесь с правилами использования приложения."
                                   Foreground="{DynamicResource App.Brush.FooterMuted}" FontSize="11" Margin="0,20,0,0"
                                   TextWrapping="Wrap" TextAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
