<Page x:Class="DriveCarePro.Pages.LoginPages.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Регистрация"
      Background="Transparent">

    <Page.Resources>
        <Style x:Key="LoginFieldBorder" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderBrush" Value="{DynamicResource App.Brush.LoginBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource App.Brush.LoginFieldBg}"/>
            <Setter Property="Padding" Value="2"/>
        </Style>
        <Style x:Key="LoginInnerTextBox" TargetType="TextBox" BasedOn="{StaticResource App.FieldTextBox}">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="15"/>
        </Style>
        <Style x:Key="LoginInnerPasswordBox" TargetType="PasswordBox" BasedOn="{StaticResource App.FieldPasswordBox}">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="15"/>
        </Style>
    </Page.Resources>

    <Grid Background="{DynamicResource App.Brush.LoginShellBackground}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="24" VerticalAlignment="Center">
                <Border MaxWidth="460" HorizontalAlignment="Center" Padding="36,32" CornerRadius="20"
                        Background="{DynamicResource App.Brush.LoginSurface}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="32" ShadowDepth="0" Opacity="0.45" Color="#000000"/>
                    </Border.Effect>

                    <StackPanel>
                        <Button Content="←  Назад к входу"
                                Command="{Binding BackCommand}"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,20"
                                Padding="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="{DynamicResource App.Brush.Accent}"
                                FontSize="14"
                                Cursor="Hand"
                                Focusable="False"/>

                        <TextBlock Text="Создать аккаунт" FontSize="26" FontWeight="SemiBold"
                                   Foreground="{DynamicResource App.Brush.Foreground}"/>
                        <TextBlock Text="Заполните поля для регистрации в DriveCare Pro"
                                   FontSize="14" Foreground="{DynamicResource App.Brush.Muted}"
                                   Margin="0,6,0,28" TextWrapping="Wrap"/>

                        <TextBlock Text="Email" Foreground="{DynamicResource App.Brush.Muted}" FontSize="12" Margin="0,0,0,6"/>
                        <Border Style="{StaticResource LoginFieldBorder}" Margin="0,0,0,16">
                            <TextBox Style="{StaticResource LoginInnerTextBox}"
                                     Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
                        </Border>

                        <TextBlock Text="Логин" Foreground="{DynamicResource App.Brush.Muted}" FontSize="12" Margin="0,0,0,6"/>
                        <Border Style="{StaticResource LoginFieldBorder}" Margin="0,0,0,16">
                            <TextBox Style="{StaticResource LoginInnerTextBox}"
                                     Text="{Binding UserLogin, UpdateSourceTrigger=PropertyChanged}"/>
                        </Border>

                        <TextBlock Text="Пароль" Foreground="{DynamicResource App.Brush.Muted}" FontSize="12" Margin="0,0,0,6"/>
                        <Border Style="{StaticResource LoginFieldBorder}" Margin="0,0,0,24">
                            <PasswordBox x:Name="PasswordInput"
                                         Style="{StaticResource LoginInnerPasswordBox}"/>
                        </Border>

                        <Button Content="Зарегистрироваться"
                                Command="{Binding RegisterCommand}"
                                Style="{StaticResource App.Button.Primary}"
                                Height="50" FontSize="16" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
