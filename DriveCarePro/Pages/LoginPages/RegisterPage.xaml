<Page x:Class="DriveCarePro.Pages.LoginPages.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Регистрация"
      Background="Transparent">

    <Page.Resources>
        <SolidColorBrush x:Key="Brush.Surface" Color="#252538"/>
        <SolidColorBrush x:Key="Brush.FieldBg" Color="#1B1B2A"/>
        <SolidColorBrush x:Key="Brush.Border" Color="#3D3D55"/>
        <SolidColorBrush x:Key="Brush.TextMuted" Color="#9AA0B0"/>
        <SolidColorBrush x:Key="Brush.Accent" Color="#7C6CF5"/>
        <SolidColorBrush x:Key="Brush.AccentHover" Color="#9488FF"/>

        <Style x:Key="FieldBorder" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{StaticResource Brush.FieldBg}"/>
            <Setter Property="Padding" Value="2"/>
        </Style>

        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="DarkPasswordBox" TargetType="PasswordBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0F0F1A" Offset="0"/>
                <GradientStop Color="#151528" Offset="0.5"/>
                <GradientStop Color="#1A1A32" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="24" VerticalAlignment="Center">
                <Border MaxWidth="460" HorizontalAlignment="Center" Padding="36,32" CornerRadius="20"
                        Background="{StaticResource Brush.Surface}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="32" ShadowDepth="0" Opacity="0.45" Color="#000000"/>
                    </Border.Effect>

                    <StackPanel>
                        <Button Content="←  Назад к входу"
                                Command="{Binding BackCommand}"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,20"
                                Padding="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="{StaticResource Brush.Accent}"
                                FontSize="14"
                                Cursor="Hand"
                                Focusable="False"/>

                        <TextBlock Text="Создать аккаунт" FontSize="26" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock Text="Заполните поля для регистрации в DriveCare Pro"
                                   FontSize="14" Foreground="{StaticResource Brush.TextMuted}"
                                   Margin="0,6,0,28" TextWrapping="Wrap"/>

                        <TextBlock Text="Email" Foreground="{StaticResource Brush.TextMuted}" FontSize="12" Margin="0,0,0,6"/>
                        <Border Style="{StaticResource FieldBorder}" Margin="0,0,0,16">
                            <TextBox Style="{StaticResource DarkTextBox}"
                                     Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
                        </Border>

                        <TextBlock Text="Логин" Foreground="{StaticResource Brush.TextMuted}" FontSize="12" Margin="0,0,0,6"/>
                        <Border Style="{StaticResource FieldBorder}" Margin="0,0,0,16">
                            <TextBox Style="{StaticResource DarkTextBox}"
                                     Text="{Binding UserLogin, UpdateSourceTrigger=PropertyChanged}"/>
                        </Border>

                        <TextBlock Text="Пароль" Foreground="{StaticResource Brush.TextMuted}" FontSize="12" Margin="0,0,0,6"/>
                        <Border Style="{StaticResource FieldBorder}" Margin="0,0,0,24">
                            <PasswordBox x:Name="PasswordInput"
                                         Style="{StaticResource DarkPasswordBox}"/>
                        </Border>

                        <Button Content="Зарегистрироваться"
                                Command="{Binding RegisterCommand}"
                                Height="50" FontSize="16" FontWeight="SemiBold"
                                Foreground="White" Cursor="Hand" BorderThickness="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" CornerRadius="12" Background="{StaticResource Brush.Accent}" Padding="16,0">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="{StaticResource Brush.AccentHover}"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="bd" Property="Opacity" Value="0.45"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
