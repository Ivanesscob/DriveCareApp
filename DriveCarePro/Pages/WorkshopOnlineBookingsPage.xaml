<Page x:Class="DriveCarePro.Pages.WorkshopOnlineBookingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Онлайн-записи"
      Background="{DynamicResource App.Brush.Panel}">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>
    <Grid Margin="24,18,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,12" LastChildFill="False">
            <Button DockPanel.Dock="Left" Content="← Назад" Style="{StaticResource App.Button.Outline}"
                    Height="40" MinWidth="110" Click="Back_Click"/>
            <TextBlock DockPanel.Dock="Left" Text="Онлайн-записи" FontSize="22" FontWeight="SemiBold"
                       Margin="16,0,0,0" VerticalAlignment="Center"
                       Foreground="{DynamicResource App.Brush.Foreground}"/>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <ComboBox x:Name="FilterCombo" Width="170" Height="36" Margin="0,0,8,0"
                          SelectionChanged="FilterCombo_SelectionChanged"/>
                <Button Content="Обновить" Style="{StaticResource App.Button.Outline}"
                        Height="36" MinWidth="100" Click="Refresh_Click"/>
            </StackPanel>
        </DockPanel>

        <TextBlock x:Name="HintText" Grid.Row="1" TextWrapping="Wrap" FontSize="12"
                   Foreground="{DynamicResource App.Brush.Muted}" Margin="0,0,0,10"/>

        <Border Grid.Row="2" CornerRadius="12" Padding="4"
                Background="{DynamicResource App.Brush.SurfaceCard}"
                BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">
            <Grid>
                <TextBlock x:Name="EmptyText" Text="Нет записей по выбранному фильтру."
                           FontSize="14" Foreground="{DynamicResource App.Brush.Muted}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="Collapsed"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="BookingsList" Margin="8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="12" Padding="16" Margin="0,0,0,10"
                                        Background="{DynamicResource App.Brush.Panel}"
                                        BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                <TextBlock Text="{Binding ClientDisplayName}" FontSize="16" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource App.Brush.Foreground}"/>
                                                <Border CornerRadius="8" Padding="8,3" Margin="12,0,0,0" VerticalAlignment="Center">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{DynamicResource App.Brush.SurfaceElevated}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsPending}" Value="True">
                                                                    <Setter Property="Background" Value="{DynamicResource App.Brush.AccentSoft}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StatusCode}" Value="1">
                                                                    <Setter Property="Background" Value="{DynamicResource App.Brush.AccentDim}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StatusCode}" Value="3">
                                                                    <Setter Property="Background" Value="#33C62828"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StatusCode}" Value="4">
                                                                    <Setter Property="Background" Value="#33FF9800"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding StatusLabel}" FontSize="11" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource App.Brush.Foreground}"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding WorkshopName}" FontSize="12"
                                                       Foreground="{DynamicResource App.Brush.Muted}" Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding CardSubtitle}" FontSize="13"
                                                       Foreground="{DynamicResource App.Brush.SecondaryText}" Margin="0,0,0,6"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="Телефон: " FontSize="12" Foreground="{DynamicResource App.Brush.Muted}"/>
                                                <TextBlock Text="{Binding ClientPhone}" FontSize="12"
                                                           Foreground="{DynamicResource App.Brush.Foreground}"/>
                                                <TextBlock Text="  ·  Заявка: " FontSize="12" Margin="8,0,0,0"
                                                           Foreground="{DynamicResource App.Brush.Muted}"/>
                                                <TextBlock Text="{Binding CreatedAtLabel}" FontSize="12"
                                                           Foreground="{DynamicResource App.Brush.Foreground}"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding ClientComment}" FontSize="12" TextWrapping="Wrap"
                                                       Foreground="{DynamicResource App.Brush.SecondaryText}" Margin="0,0,0,4"/>
                                            <TextBlock FontSize="12" TextWrapping="Wrap" Foreground="#C62828" Margin="0,4,0,0"
                                                       Text="{Binding RejectReason, StringFormat=Причина: {0}}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding StatusCode}" Value="3">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0">
                                            <Button Content="Принять" Style="{StaticResource App.Button.Primary}"
                                                    Height="36" MinWidth="110" Margin="0,0,0,8"
                                                    Tag="{Binding}" Click="Accept_Click"
                                                    Visibility="{Binding CanAccept, Converter={StaticResource BoolToVis}}"/>
                                            <Button Content="Отклонить" Style="{StaticResource App.Button.Outline}"
                                                    Height="36" MinWidth="110" Tag="{Binding}" Click="Reject_Click"
                                                    Visibility="{Binding CanReject, Converter={StaticResource BoolToVis}}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Page>
