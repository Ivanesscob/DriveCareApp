<Page x:Class="DriveCarePro.Pages.WorkshopOnlineBookingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Онлайн-записи"
      Background="{DynamicResource App.Brush.Panel}">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>
    <Grid Margin="24,18,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <DockPanel Grid.Row="0" Margin="0,0,0,12" LastChildFill="False">
            <Button DockPanel.Dock="Left" Content="← Назад" Style="{StaticResource App.Button.Outline}"
                    Height="40" MinWidth="110" Click="Back_Click"/>
            <TextBlock DockPanel.Dock="Left" Text="Онлайн-записи клиентов" FontSize="22" FontWeight="SemiBold"
                       Margin="16,0,0,0" VerticalAlignment="Center"
                       Foreground="{DynamicResource App.Brush.Foreground}"/>
            <Button DockPanel.Dock="Right" Content="Обновить" Style="{StaticResource App.Button.Outline}"
                    Height="36" MinWidth="100" Click="Refresh_Click"/>
        </DockPanel>
        <TextBlock x:Name="HintText" Grid.Row="1" TextWrapping="Wrap" FontSize="12"
                   Foreground="{DynamicResource App.Brush.Muted}" Margin="0,0,0,8"/>
        <DataGrid x:Name="BookingsGrid" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" HeadersVisibility="Column" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Дата" Binding="{Binding CreatedAtLabel}" Width="100"/>
                <DataGridTextColumn Header="Клиент" Binding="{Binding ClientDisplayName}" Width="120"/>
                <DataGridTextColumn Header="Автомобиль" Binding="{Binding CarDisplayName}" Width="*"/>
                <DataGridTextColumn Header="Проблема" Binding="{Binding IssueCategoryLabel}" Width="130"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding ClientPhone}" Width="95"/>
                <DataGridTextColumn Header="Комментарий" Binding="{Binding ClientComment}" Width="140"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding StatusLabel}" Width="130"/>
                <DataGridTemplateColumn Header="" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Подтвердить" Style="{StaticResource App.Button.Primary}" Height="28"
                                    Visibility="{Binding CanConfirm, Converter={StaticResource BoolToVis}}"
                                    Click="Confirm_Click" Tag="{Binding BookingId}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
