<Page x:Class="DriveCarePro.Pages.WorkshopServicesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Услуги мастерской">

    <Grid Background="{DynamicResource App.Brush.Panel}" Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,12" LastChildFill="False">
            <Button DockPanel.Dock="Left" Content="← На главную" Style="{StaticResource App.Button.Outline}"
                    Height="40" MinWidth="130" Click="Back_Click"/>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="Добавить услугу" Style="{StaticResource App.Button.Primary}"
                        Height="40" MinWidth="150" Margin="0,0,10,0" Click="Add_Click"/>
                <Button Content="Обновить" Style="{StaticResource App.Button.Outline}"
                        Height="40" MinWidth="110" Click="Refresh_Click"/>
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="1" Margin="0,0,0,12" CornerRadius="12" Padding="14,12"
                Background="{DynamicResource App.Brush.SurfaceCard}"
                BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0" Margin="0,0,0,8" LastChildFill="False">
                    <TextBlock DockPanel.Dock="Left" Text="Единицы измерения" FontWeight="SemiBold" FontSize="13"
                               Foreground="{DynamicResource App.Brush.Foreground}" VerticalAlignment="Center"/>
                    <Button DockPanel.Dock="Right" Content="+ Добавить" Style="{StaticResource App.Button.Outline}"
                            Height="32" MinWidth="100" Click="AddUnit_Click"/>
                </DockPanel>
                <DataGrid x:Name="UnitsGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                          SelectionMode="Single" HeadersVisibility="Column" MaxHeight="140"
                          AlternatingRowBackground="{DynamicResource App.Brush.Surface2}"
                          Foreground="{DynamicResource App.Brush.Foreground}" RowHeight="32"
                          Background="Transparent" BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Обозначение" Binding="{Binding Name}" Width="*" MinWidth="80"/>
                        <DataGridTextColumn Header="Активна" Binding="{Binding ActiveDisplay}" Width="70"/>
                        <DataGridTemplateColumn Header="" Width="160">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Изменить" Style="{StaticResource App.Button.Outline}"
                                                Height="26" MinWidth="72" Margin="0,0,6,0"
                                                Click="EditUnit_Click" Tag="{Binding}"/>
                                        <Button Content="Удалить" Style="{StaticResource App.Button.Outline}"
                                                Height="26" MinWidth="64"
                                                Click="DeleteUnit_Click" Tag="{Binding}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Row="2" CornerRadius="12" Padding="16,14"
                Background="{DynamicResource App.Brush.SurfaceCard}"
                BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock x:Name="HintText" Grid.Row="0" FontSize="13" Margin="0,0,0,10" TextWrapping="Wrap"
                           Foreground="{DynamicResource App.Brush.Muted}"/>
                <DataGrid x:Name="Grid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                          SelectionMode="Single" HeadersVisibility="Column" MinHeight="240"
                          MouseDoubleClick="Grid_MouseDoubleClick"
                          AlternatingRowBackground="{DynamicResource App.Brush.Surface2}"
                          Foreground="{DynamicResource App.Brush.Foreground}" RowHeight="36"
                          Background="Transparent" BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="2*" MinWidth="160"/>
                        <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="2*" MinWidth="140"/>
                        <DataGridTextColumn Header="Цена" Binding="{Binding PriceDisplay}" Width="90"/>
                        <DataGridTextColumn Header="Ед." Binding="{Binding UnitName}" Width="60"/>
                        <DataGridTextColumn Header="Активна" Binding="{Binding ActiveDisplay}" Width="70"/>
                        <DataGridTemplateColumn Header="" Width="200">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Изменить" Style="{StaticResource App.Button.Outline}"
                                                Height="28" MinWidth="80" Margin="0,0,6,0"
                                                Click="EditRow_Click" Tag="{Binding}"/>
                                        <Button Content="Удалить" Style="{StaticResource App.Button.Outline}"
                                                Height="28" MinWidth="70"
                                                Click="DeleteRow_Click" Tag="{Binding}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Page>
