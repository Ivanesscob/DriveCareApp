<Page x:Class="DriveCarePro.Pages.EmployeeTaskCardPage"

      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

      Title="Задание">



    <Grid Margin="24,20">

        <Grid x:Name="MainContentGrid" Background="{DynamicResource App.Brush.Panel}">

        <Grid.RowDefinitions>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="*"/>

        </Grid.RowDefinitions>



        <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,16">

            <Button DockPanel.Dock="Left" Content="← Назад" Style="{StaticResource App.Button.Outline}"

                    Height="40" MinWidth="120" Click="Back_Click"/>

        </DockPanel>



        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">

            <StackPanel MaxWidth="920">

                <TextBlock x:Name="TitleText" FontSize="20" FontWeight="SemiBold"

                           Foreground="{DynamicResource App.Brush.Foreground}" TextWrapping="Wrap"/>

                <TextBlock x:Name="ArchiveHintText" Visibility="Collapsed" Margin="0,6,0,0" FontSize="12"
                           Foreground="{DynamicResource App.Brush.Accent}" TextWrapping="Wrap"
                           Text="Архив: только просмотр. Можно скачать заказ-наряд."/>



                <Border Margin="0,16,0,0" CornerRadius="12" Padding="16,14"

                        Background="{DynamicResource App.Brush.SurfaceCard}"

                        BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">

                    <StackPanel>

                        <TextBlock Text="Что сделать" FontWeight="SemiBold" FontSize="14"

                                   Foreground="{DynamicResource App.Brush.Foreground}"/>

                        <TextBlock x:Name="TaskDescriptionText" Margin="0,8,0,0" FontSize="14" TextWrapping="Wrap"

                                   Foreground="{DynamicResource App.Brush.SecondaryText}"/>

                    </StackPanel>

                </Border>



                <Border x:Name="CarSectionBorder" Margin="0,12,0,0" CornerRadius="12" Padding="16,14"

                        Background="{DynamicResource App.Brush.SurfaceCard}"

                        BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">

                    <StackPanel>

                        <TextBlock Text="Автомобиль" FontWeight="SemiBold" FontSize="14"

                                   Foreground="{DynamicResource App.Brush.Foreground}"/>

                        <TextBlock x:Name="CarInfoText" Margin="0,8,0,0" FontSize="14" TextWrapping="Wrap"

                                   Foreground="{DynamicResource App.Brush.SecondaryText}"/>

                    </StackPanel>

                </Border>



                <Border Margin="0,12,0,0" CornerRadius="12" Padding="16,14"

                        Background="{DynamicResource App.Brush.SurfaceCard}"

                        BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">

                    <StackPanel>

                        <TextBlock Text="Клиент" FontWeight="SemiBold" FontSize="14"

                                   Foreground="{DynamicResource App.Brush.Foreground}"/>

                        <TextBlock x:Name="ClientInfoText" Margin="0,8,0,0" FontSize="14" TextWrapping="Wrap"

                                   Foreground="{DynamicResource App.Brush.SecondaryText}"/>

                    </StackPanel>

                </Border>



                <Border Margin="0,12,0,0" CornerRadius="12" Padding="16,14"

                        Background="{DynamicResource App.Brush.SurfaceCard}"

                        BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">

                    <StackPanel>

                        <TextBlock Text="Особые данные" FontWeight="SemiBold" FontSize="14"

                                   Foreground="{DynamicResource App.Brush.Foreground}"/>

                        <TextBlock x:Name="SpecialNotesText" Margin="0,8,0,0" FontSize="14" TextWrapping="Wrap"

                                   Foreground="{DynamicResource App.Brush.SecondaryText}"/>

                    </StackPanel>

                </Border>



                <Border Margin="0,12,0,0" CornerRadius="12" Padding="16,14"

                        Background="{DynamicResource App.Brush.SurfaceCard}"

                        BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">

                    <StackPanel>

                        <TextBlock Text="Отчёт — выполненные услуги" FontWeight="SemiBold" FontSize="14"

                                   Foreground="{DynamicResource App.Brush.Foreground}"/>

                        <TextBlock Text="Нажмите «Выбрать услугу» — откроется каталог. Цена и единица подставятся автоматически."

                                   FontSize="12" Foreground="{DynamicResource App.Brush.Muted}" TextWrapping="Wrap" Margin="0,4,0,8"/>



                        <DataGrid x:Name="ServicesGrid" AutoGenerateColumns="False" CanUserAddRows="False"

                                  HeadersVisibility="Column" MinHeight="120" MaxHeight="280"

                                  AlternatingRowBackground="{DynamicResource App.Brush.Surface2}"

                                  Foreground="{DynamicResource App.Brush.Foreground}" RowHeight="36"

                                  Background="Transparent" BorderThickness="0">

                            <DataGrid.Columns>

                                <DataGridTextColumn Header="Наименование" Binding="{Binding ServiceName}" Width="2*" MinWidth="180" IsReadOnly="True"/>

                                <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Width="70"/>

                                <DataGridTextColumn Header="Ед." Binding="{Binding UnitName, UpdateSourceTrigger=PropertyChanged}" Width="55"/>

                                <DataGridTextColumn Header="Цена" Binding="{Binding UnitPrice, UpdateSourceTrigger=PropertyChanged}" Width="80"/>

                                <DataGridTextColumn Header="Скидка %" Binding="{Binding DiscountPercent, UpdateSourceTrigger=PropertyChanged}" Width="75"/>

                                <DataGridTextColumn Header="Сумма" Binding="{Binding LineAmount, Mode=OneWay}" Width="85" IsReadOnly="True"/>

                            </DataGrid.Columns>

                        </DataGrid>

                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button x:Name="AddServiceLineButton" Content="+ Выбрать услугу"
                                    Style="{StaticResource App.Button.Outline}" Height="32" MinWidth="150" Margin="0,0,8,0"
                                    Click="AddServiceLine_Click"/>
                            <Button x:Name="RemoveServiceLineButton" Content="− Удалить услугу"
                                    Style="{StaticResource App.Button.Outline}" Height="32" MinWidth="150"
                                    Click="RemoveServiceLine_Click"/>
                        </StackPanel>



                        <TextBlock x:Name="PartsSectionTitleText" Text="Детали / запчасти" FontWeight="SemiBold" FontSize="14" Margin="0,16,0,0"

                                   Foreground="{DynamicResource App.Brush.Foreground}"/>

                        <TextBlock x:Name="PartsSectionHintText" Text="Нажмите «Выбрать деталь» — откроется склад мастерской. Списание — по кнопке «Сохранить». Если пусто — «Магазин»."

                                   FontSize="12" Foreground="{DynamicResource App.Brush.Muted}" TextWrapping="Wrap" Margin="0,4,0,4"/>

                        <DataGrid x:Name="PartsGrid" AutoGenerateColumns="False" CanUserAddRows="False"

                                  HeadersVisibility="Column" MinHeight="80" MaxHeight="200"

                                  AlternatingRowBackground="{DynamicResource App.Brush.Surface2}"

                                  Foreground="{DynamicResource App.Brush.Foreground}" RowHeight="36"

                                  Background="Transparent" BorderThickness="0">

                            <DataGrid.Columns>

                                <DataGridTextColumn x:Name="PartNameColumn" Header="Наименование" Binding="{Binding PartName}" Width="2*" MinWidth="180" IsReadOnly="True"/>

                                <DataGridTextColumn x:Name="PartQtyColumn" Header="Кол-во" Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Width="70"/>

                                <DataGridTextColumn x:Name="PartUnitColumn" Header="Ед." Binding="{Binding UnitName, UpdateSourceTrigger=PropertyChanged}" Width="55"/>

                                <DataGridTextColumn x:Name="PartPriceColumn" Header="Цена" Binding="{Binding UnitPrice, UpdateSourceTrigger=PropertyChanged}" Width="80"/>

                                <DataGridTextColumn x:Name="PartSumColumn" Header="Сумма" Binding="{Binding LineAmount, Mode=OneWay}" Width="85" IsReadOnly="True"/>

                            </DataGrid.Columns>

                        </DataGrid>

                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button x:Name="AddPartLineButton" Content="+ Выбрать деталь"
                                    Style="{StaticResource App.Button.Outline}" Height="32" MinWidth="140" Margin="0,0,8,0"
                                    Click="AddPartLine_Click"/>
                            <Button x:Name="RemovePartLineButton" Content="− Удалить деталь"
                                    Style="{StaticResource App.Button.Outline}" Height="32" MinWidth="140"
                                    Click="RemovePartLine_Click"/>
                        </StackPanel>



                        <TextBlock Text="Дополнительный комментарий" FontSize="12" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,14,0,4"/>

                        <TextBox x:Name="ReportTextBox" Style="{StaticResource App.FieldTextBox}" MinHeight="72"
                                 AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                 TextChanged="ReportTextBox_TextChanged"/>

                    </StackPanel>

                </Border>



                <Border x:Name="PurchaseStatusSection" Margin="0,12,0,0" CornerRadius="12" Padding="16,14"
                        Visibility="Collapsed"
                        Background="{DynamicResource App.Brush.SurfaceCard}"
                        BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Закупка запчастей" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{DynamicResource App.Brush.Foreground}"/>
                        <TextBlock x:Name="PurchaseStatusText" Margin="0,8,0,0" FontSize="13" TextWrapping="Wrap"
                                   Foreground="{DynamicResource App.Brush.SecondaryText}"/>
                    </StackPanel>
                </Border>

                <Border x:Name="DocumentSection" Margin="0,12,0,0" CornerRadius="12" Padding="16,14"
                        Visibility="Collapsed"
                        Background="{DynamicResource App.Brush.Surface2}"
                        BorderBrush="{DynamicResource App.Brush.Accent}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Документ заказ-наряда" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{DynamicResource App.Brush.Accent}"/>
                        <TextBlock x:Name="DocumentTitleText" Margin="0,6,0,0" FontSize="13" TextWrapping="Wrap"
                                   Foreground="{DynamicResource App.Brush.Foreground}"/>
                        <TextBlock x:Name="DocumentStatusText" Margin="0,4,0,0" FontSize="12" TextWrapping="Wrap"
                                   Foreground="{DynamicResource App.Brush.SecondaryText}"/>
                        <Button x:Name="ViewDocumentButton" Content="Посмотреть документ на текущем этапе"
                                Style="{StaticResource App.Button.Outline}" Height="36" MinWidth="280"
                                HorizontalAlignment="Left" Margin="0,10,0,0" Click="ViewDocument_Click"
                                ToolTip="Сохраняет ваши строки и показывает общий заказ-наряд по всей цепочке заданий"/>
                    </StackPanel>
                </Border>

                <Border x:Name="DelegationSection" Margin="0,12,0,0" CornerRadius="12" Padding="16,14"
                        Background="{DynamicResource App.Brush.SurfaceCard}"
                        BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Передача поручения" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{DynamicResource App.Brush.Foreground}"/>
                        <TextBlock x:Name="DelegationStatusText" Margin="0,8,0,6" FontSize="13" TextWrapping="Wrap"
                                   Foreground="{DynamicResource App.Brush.SecondaryText}"/>
                        <TextBlock x:Name="DelegationChainText" Margin="0,0,0,10" FontSize="12" TextWrapping="Wrap"
                                   Foreground="{DynamicResource App.Brush.Muted}"/>
                        <Button x:Name="OpenRootTaskButton" Content="Перейти к корневому заданию"
                                Style="{StaticResource App.Button.Outline}" Height="36" MinWidth="260"
                                HorizontalAlignment="Left" Margin="0,0,0,8" Visibility="Collapsed"
                                Click="OpenRootTask_Click"
                                ToolTip="Открыть исходное задание, с которого началась цепочка поручений"/>
                        <Button x:Name="DelegateTaskButton" Content="Передать дальше другому сотруднику"
                                Style="{StaticResource App.Button.Outline}" Height="40" MinWidth="280"
                                HorizontalAlignment="Left" Click="DelegateTask_Click"/>
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal" Margin="0,16,0,0">

                    <Button x:Name="SaveReportButton" Content="Сохранить" Style="{StaticResource App.Button.Outline}"
                            Height="40" MinWidth="130" Margin="0,0,10,0" Click="Save_Click"
                            ToolTip="Записать услуги, детали и комментарий. Нажмите перед выходом, чтобы продолжить задание позже."/>

                    <Button x:Name="ShopButton" Content="Магазин" Style="{StaticResource App.Button.Outline}"

                            Height="40" MinWidth="140" Margin="0,0,10,0" Click="Shop_Click"/>

                    <Button x:Name="WorkOrderButton" Content="Заказ-наряд для выдачи"

                            Style="{StaticResource App.Button.Outline}"

                            Height="40" MinWidth="200" Margin="0,0,10,0" Click="WorkOrder_Click"/>

                    <Button x:Name="ViewDocumentToolbarButton" Content="Документ (этап)"
                            Style="{StaticResource App.Button.Outline}"
                            Height="40" MinWidth="160" Click="ViewDocument_Click"
                            ToolTip="Текущий общий заказ-наряд по цепочке заданий"/>

                </StackPanel>



                <Border x:Name="CompletionSection" Margin="0,16,0,0" CornerRadius="12" Padding="16,14"

                        Background="{DynamicResource App.Brush.SurfaceCard}"

                        BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">

                    <StackPanel>

                        <TextBlock x:Name="CompletionTitleText" Text="Завершение ремонта" FontWeight="SemiBold" FontSize="14"

                                   Foreground="{DynamicResource App.Brush.Foreground}"/>

                        <StackPanel x:Name="CompletionMileagePanel" Visibility="Collapsed" Margin="0,10,0,0">
                            <TextBlock Text="Пробег при выдаче авто" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource App.Brush.Foreground}"/>
                            <TextBlock Text="Обязательно перед закрытием ремонта. Укажите показания одометра."
                                       FontSize="11" TextWrapping="Wrap" Margin="0,4,0,6"
                                       Foreground="{DynamicResource App.Brush.Muted}"/>
                            <TextBox x:Name="CompletionMileageBox" Style="{StaticResource App.FieldTextBox}"
                                     MinHeight="40" FontSize="15" MaxLength="9"
                                     InputMethod.IsInputMethodEnabled="False"/>
                        </StackPanel>

                        <Button x:Name="CompleteButton" Content="Завершить задание" Style="{StaticResource App.Button.Primary}"

                                Height="44" MinWidth="220" HorizontalAlignment="Left" Margin="0,12,0,0"

                                Click="Complete_Click"/>

                        <Button x:Name="ClientNoShowButton" Content="Клиент не пришёл"
                                Style="{StaticResource App.Button.Outline}"
                                Height="40" MinWidth="220" HorizontalAlignment="Left" Margin="0,10,0,0"
                                Visibility="Collapsed" Click="ClientNoShow_Click"/>

                        <TextBlock x:Name="OnlineBookingHintText" Visibility="Collapsed" Margin="0,8,0,0"
                                   FontSize="12" TextWrapping="Wrap"
                                   Foreground="{DynamicResource App.Brush.Muted}"
                                   Text="Задание создано из онлайн-записи. Если клиент не явился — отметьте неявку, задание будет снято."/>

                    </StackPanel>

                </Border>

                <Border x:Name="ClientStageSection" Margin="0,16,0,0" Padding="12,10" CornerRadius="10"
                        Background="{DynamicResource App.Brush.SurfaceCard}"
                        BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Статус для клиента" FontWeight="SemiBold" FontSize="13"
                                   Foreground="{DynamicResource App.Brush.Foreground}"/>
                        <TextBlock x:Name="ClientStageStatusText" Margin="0,6,0,10" FontSize="12"
                                   Foreground="{DynamicResource App.Brush.Muted}" TextWrapping="Wrap"/>
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="MarkAcceptedButton" Content="Машина принята"
                                    Style="{StaticResource App.Button.Outline}" Height="36" MinWidth="160"
                                    Margin="0,0,8,0" Visibility="Collapsed" Click="MarkAccepted_Click"/>
                            <Button x:Name="MarkInRepairButton" Content="Поступила в ремонт"
                                    Style="{StaticResource App.Button.Outline}" Height="36" MinWidth="170"
                                    Visibility="Collapsed" Click="MarkInRepair_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border x:Name="ClientHandoverSection" Margin="0,16,0,0" Padding="12,10" CornerRadius="10"
                        Background="{DynamicResource App.Brush.SurfaceCard}"
                        BorderBrush="{DynamicResource App.Brush.Accent}" BorderThickness="1"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Автомобиль готов к выдаче" FontWeight="SemiBold" FontSize="13"
                                   Foreground="{DynamicResource App.Brush.Foreground}"/>
                        <TextBlock Text="Клиент видит статус на главной. Нажмите, когда автомобиль передан клиенту."
                                   FontSize="12" TextWrapping="Wrap" Margin="0,6,0,10"
                                   Foreground="{DynamicResource App.Brush.Muted}"/>
                        <Button x:Name="DeliverToClientButton" Content="Выдать клиенту"
                                Style="{StaticResource App.Button.Primary}" Height="40" MinWidth="200"
                                HorizontalAlignment="Left" Click="DeliverToClient_Click"/>
                    </StackPanel>
                </Border>

            </StackPanel>

        </ScrollViewer>

        </Grid>

        <Border x:Name="PageBusyOverlay" Visibility="Collapsed"
                Panel.ZIndex="200" Background="#99000000"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MinWidth="260">
                <ProgressBar IsIndeterminate="True" Height="4" Width="220"
                             Foreground="{DynamicResource App.Brush.Accent}"
                             Background="{DynamicResource App.Brush.Border}"/>
                <TextBlock x:Name="BusyOverlayText" Text="Подождите…" Margin="0,14,0,0"
                           FontSize="14" FontWeight="SemiBold" TextAlignment="Center"
                           Foreground="{DynamicResource App.Brush.Foreground}"/>
            </StackPanel>
        </Border>

    </Grid>

</Page>

