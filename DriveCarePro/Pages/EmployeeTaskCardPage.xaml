<Page x:Class="DriveCarePro.Pages.EmployeeTaskCardPage"

      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

      Title="Задание">



    <Grid Background="{DynamicResource App.Brush.Panel}" Margin="24,20">

        <Grid.RowDefinitions>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="*"/>

        </Grid.RowDefinitions>



        <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,16">

            <Button DockPanel.Dock="Left" Content="← Назад" Style="{StaticResource App.Button.Outline}"

                    Height="40" MinWidth="120" Click="Back_Click"/>

        </DockPanel>



        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">

            <StackPanel MaxWidth="920">

                <TextBlock x:Name="TitleText" FontSize="20" FontWeight="SemiBold"

                           Foreground="{DynamicResource App.Brush.Foreground}" TextWrapping="Wrap"/>

                <TextBlock x:Name="ArchiveHintText" Visibility="Collapsed" Margin="0,6,0,0" FontSize="12"
                           Foreground="{DynamicResource App.Brush.Accent}" TextWrapping="Wrap"
                           Text="Архив: только просмотр. Можно скачать заказ-наряд."/>



                <Border Margin="0,16,0,0" CornerRadius="12" Padding="16,14"

                        Background="{DynamicResource App.Brush.SurfaceCard}"

                        BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">

                    <StackPanel>

                        <TextBlock Text="Что сделать" FontWeight="SemiBold" FontSize="14"

                                   Foreground="{DynamicResource App.Brush.Foreground}"/>

                        <TextBlock x:Name="TaskDescriptionText" Margin="0,8,0,0" FontSize="14" TextWrapping="Wrap"

                                   Foreground="{DynamicResource App.Brush.SecondaryText}"/>

                    </StackPanel>

                </Border>



                <Border x:Name="CarSectionBorder" Margin="0,12,0,0" CornerRadius="12" Padding="16,14"

                        Background="{DynamicResource App.Brush.SurfaceCard}"

                        BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">

                    <StackPanel>

                        <TextBlock Text="Автомобиль" FontWeight="SemiBold" FontSize="14"

                                   Foreground="{DynamicResource App.Brush.Foreground}"/>

                        <TextBlock x:Name="CarInfoText" Margin="0,8,0,0" FontSize="14" TextWrapping="Wrap"

                                   Foreground="{DynamicResource App.Brush.SecondaryText}"/>

                    </StackPanel>

                </Border>



                <Border Margin="0,12,0,0" CornerRadius="12" Padding="16,14"

                        Background="{DynamicResource App.Brush.SurfaceCard}"

                        BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">

                    <StackPanel>

                        <TextBlock Text="Клиент" FontWeight="SemiBold" FontSize="14"

                                   Foreground="{DynamicResource App.Brush.Foreground}"/>

                        <TextBlock x:Name="ClientInfoText" Margin="0,8,0,0" FontSize="14" TextWrapping="Wrap"

                                   Foreground="{DynamicResource App.Brush.SecondaryText}"/>

                    </StackPanel>

                </Border>



                <Border Margin="0,12,0,0" CornerRadius="12" Padding="16,14"

                        Background="{DynamicResource App.Brush.SurfaceCard}"

                        BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">

                    <StackPanel>

                        <TextBlock Text="Особые данные" FontWeight="SemiBold" FontSize="14"

                                   Foreground="{DynamicResource App.Brush.Foreground}"/>

                        <TextBlock x:Name="SpecialNotesText" Margin="0,8,0,0" FontSize="14" TextWrapping="Wrap"

                                   Foreground="{DynamicResource App.Brush.SecondaryText}"/>

                    </StackPanel>

                </Border>



                <Border Margin="0,12,0,0" CornerRadius="12" Padding="16,14"

                        Background="{DynamicResource App.Brush.SurfaceCard}"

                        BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">

                    <StackPanel>

                        <TextBlock Text="Отчёт — выполненные услуги" FontWeight="SemiBold" FontSize="14"

                                   Foreground="{DynamicResource App.Brush.Foreground}"/>

                        <TextBlock Text="Выберите услугу из каталога (поиск по названию) — цена и единица подставятся автоматически."

                                   FontSize="12" Foreground="{DynamicResource App.Brush.Muted}" TextWrapping="Wrap" Margin="0,4,0,8"/>



                        <DataGrid x:Name="ServicesGrid" AutoGenerateColumns="False" CanUserAddRows="False"

                                  HeadersVisibility="Column" MinHeight="120" MaxHeight="280"

                                  AlternatingRowBackground="{DynamicResource App.Brush.Surface2}"

                                  Foreground="{DynamicResource App.Brush.Foreground}" RowHeight="36"

                                  Background="Transparent" BorderThickness="0">

                            <DataGrid.Columns>

                                <DataGridTemplateColumn Header="Наименование" Width="2*" MinWidth="180">

                                    <DataGridTemplateColumn.CellTemplate>

                                        <DataTemplate>

                                            <ComboBox ItemsSource="{Binding Catalog}" DisplayMemberPath="Name"

                                                      SelectedItem="{Binding SelectedCatalog, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"

                                                      Text="{Binding ServiceName, UpdateSourceTrigger=PropertyChanged}"

                                                      IsEditable="True" IsTextSearchEnabled="True"

                                                      MinHeight="30" VerticalContentAlignment="Center"/>

                                        </DataTemplate>

                                    </DataGridTemplateColumn.CellTemplate>

                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Width="70"/>

                                <DataGridTextColumn Header="Ед." Binding="{Binding UnitName, UpdateSourceTrigger=PropertyChanged}" Width="55"/>

                                <DataGridTextColumn Header="Цена" Binding="{Binding UnitPrice, UpdateSourceTrigger=PropertyChanged}" Width="80"/>

                                <DataGridTextColumn Header="Скидка %" Binding="{Binding DiscountPercent, UpdateSourceTrigger=PropertyChanged}" Width="75"/>

                                <DataGridTextColumn Header="Сумма" Binding="{Binding LineAmount, Mode=OneWay}" Width="85" IsReadOnly="True"/>

                            </DataGrid.Columns>

                        </DataGrid>

                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button x:Name="AddServiceLineButton" Content="+ Добавить услугу"
                                    Style="{StaticResource App.Button.Outline}" Height="32" MinWidth="150" Margin="0,0,8,0"
                                    Click="AddServiceLine_Click"/>
                            <Button x:Name="RemoveServiceLineButton" Content="− Удалить услугу"
                                    Style="{StaticResource App.Button.Outline}" Height="32" MinWidth="150"
                                    Click="RemoveServiceLine_Click"/>
                        </StackPanel>



                        <TextBlock Text="Детали / запчасти" FontWeight="SemiBold" FontSize="14" Margin="0,16,0,0"

                                   Foreground="{DynamicResource App.Brush.Foreground}"/>

                        <TextBlock Text="Каталог как в магазине DriveCare (поиск по названию). Если нужно заказать — «Магазин» и запрос на покупку."

                                   FontSize="12" Foreground="{DynamicResource App.Brush.Muted}" TextWrapping="Wrap" Margin="0,4,0,8"/>



                        <DataGrid x:Name="PartsGrid" AutoGenerateColumns="False" CanUserAddRows="False"

                                  HeadersVisibility="Column" MinHeight="80" MaxHeight="200"

                                  AlternatingRowBackground="{DynamicResource App.Brush.Surface2}"

                                  Foreground="{DynamicResource App.Brush.Foreground}" RowHeight="36"

                                  Background="Transparent" BorderThickness="0">

                            <DataGrid.Columns>

                                <DataGridTemplateColumn Header="Наименование" Width="2*" MinWidth="180">

                                    <DataGridTemplateColumn.CellTemplate>

                                        <DataTemplate>

                                            <ComboBox ItemsSource="{Binding Catalog}" DisplayMemberPath="ListLabel"

                                                      SelectedItem="{Binding SelectedCatalog, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"

                                                      Text="{Binding PartName, UpdateSourceTrigger=PropertyChanged}"

                                                      IsEditable="True" IsTextSearchEnabled="True"

                                                      MinHeight="30" VerticalContentAlignment="Center"/>

                                        </DataTemplate>

                                    </DataGridTemplateColumn.CellTemplate>

                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Width="70"/>

                                <DataGridTextColumn Header="Ед." Binding="{Binding UnitName, UpdateSourceTrigger=PropertyChanged}" Width="55"/>

                                <DataGridTextColumn Header="Цена" Binding="{Binding UnitPrice, UpdateSourceTrigger=PropertyChanged}" Width="80"/>

                                <DataGridTextColumn Header="Сумма" Binding="{Binding LineAmount, Mode=OneWay}" Width="85" IsReadOnly="True"/>

                            </DataGrid.Columns>

                        </DataGrid>

                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button x:Name="AddPartLineButton" Content="+ Добавить деталь"
                                    Style="{StaticResource App.Button.Outline}" Height="32" MinWidth="140" Margin="0,0,8,0"
                                    Click="AddPartLine_Click"/>
                            <Button x:Name="RemovePartLineButton" Content="− Удалить деталь"
                                    Style="{StaticResource App.Button.Outline}" Height="32" MinWidth="140"
                                    Click="RemovePartLine_Click"/>
                        </StackPanel>



                        <TextBlock Text="Дополнительный комментарий" FontSize="12" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,14,0,4"/>

                        <TextBox x:Name="ReportTextBox" Style="{StaticResource App.FieldTextBox}" MinHeight="72"

                                 AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>

                    </StackPanel>

                </Border>



                <Border x:Name="PurchaseStatusSection" Margin="0,12,0,0" CornerRadius="12" Padding="16,14"
                        Visibility="Collapsed"
                        Background="{DynamicResource App.Brush.SurfaceCard}"
                        BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Закупка запчастей" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{DynamicResource App.Brush.Foreground}"/>
                        <TextBlock x:Name="PurchaseStatusText" Margin="0,8,0,0" FontSize="13" TextWrapping="Wrap"
                                   Foreground="{DynamicResource App.Brush.SecondaryText}"/>
                    </StackPanel>
                </Border>

                <Border x:Name="DelegationSection" Margin="0,12,0,0" CornerRadius="12" Padding="16,14"
                        Background="{DynamicResource App.Brush.SurfaceCard}"
                        BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Передача поручения" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{DynamicResource App.Brush.Foreground}"/>
                        <TextBlock x:Name="DelegationStatusText" Margin="0,8,0,6" FontSize="13" TextWrapping="Wrap"
                                   Foreground="{DynamicResource App.Brush.SecondaryText}"/>
                        <TextBlock x:Name="DelegationChainText" Margin="0,0,0,10" FontSize="12" TextWrapping="Wrap"
                                   Foreground="{DynamicResource App.Brush.Muted}"/>
                        <Button x:Name="DelegateTaskButton" Content="Передать дальше другому сотруднику"
                                Style="{StaticResource App.Button.Outline}" Height="40" MinWidth="280"
                                HorizontalAlignment="Left" Click="DelegateTask_Click"/>
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal" Margin="0,16,0,0">

                    <Button x:Name="ShopButton" Content="Магазин" Style="{StaticResource App.Button.Outline}"

                            Height="40" MinWidth="140" Margin="0,0,10,0" Click="Shop_Click"/>

                    <Button x:Name="WorkOrderButton" Content="Заказ-наряд для выдачи"

                            Style="{StaticResource App.Button.Outline}"

                            Height="40" MinWidth="200" Click="WorkOrder_Click"/>

                </StackPanel>



                <Border x:Name="CompletionSection" Margin="0,16,0,0" CornerRadius="12" Padding="16,14"

                        Background="{DynamicResource App.Brush.SurfaceCard}"

                        BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">

                    <StackPanel>

                        <TextBlock x:Name="CompletionTitleText" Text="Завершение ремонта" FontWeight="SemiBold" FontSize="14"

                                   Foreground="{DynamicResource App.Brush.Foreground}"/>

                        <Button x:Name="CompleteButton" Content="Завершить задание" Style="{StaticResource App.Button.Primary}"

                                Height="44" MinWidth="220" HorizontalAlignment="Left" Margin="0,12,0,0"

                                Click="Complete_Click"/>

                    </StackPanel>

                </Border>

            </StackPanel>

        </ScrollViewer>

    </Grid>

</Page>

