<Page x:Class="DriveCarePro.Pages.WorkshopWorkSchedulePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Расписание работы"
      Background="{DynamicResource App.Brush.Panel}">
    <Grid Margin="24,18,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,12" LastChildFill="False">
            <Button DockPanel.Dock="Left" Content="← Назад" Style="{StaticResource App.Button.Outline}"
                    Height="40" MinWidth="110" Click="Back_Click"/>
            <TextBlock DockPanel.Dock="Left" Text="Расписание работы сервиса" FontSize="22" FontWeight="SemiBold"
                       Margin="16,0,0,0" VerticalAlignment="Center"
                       Foreground="{DynamicResource App.Brush.Foreground}"/>
        </DockPanel>

        <TextBlock x:Name="HintText" Grid.Row="1" TextWrapping="Wrap" FontSize="12"
                   Foreground="{DynamicResource App.Brush.Muted}" Margin="0,0,0,10"/>

        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <StackPanel x:Name="WorkshopPickerPanel" Orientation="Horizontal" Margin="0,0,0,12"
                        Visibility="Collapsed">
                <TextBlock Text="Мастерская:" VerticalAlignment="Center" Margin="0,0,8,0"
                           Foreground="{DynamicResource App.Brush.Foreground}"/>
                <ComboBox x:Name="WorkshopCombo" MinWidth="280" Height="36"
                          DisplayMemberPath="Name" SelectionChanged="WorkshopCombo_SelectionChanged"/>
            </StackPanel>

            <Border x:Name="CapacityPanel" Padding="14,12" CornerRadius="10"
                    Background="{DynamicResource App.Brush.SurfaceCard}"
                    BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="Сколько машин принимаем в день (онлайн-запись)" FontWeight="SemiBold" FontSize="14"
                               Foreground="{DynamicResource App.Brush.Foreground}" Margin="0,0,0,6"/>
                    <TextBlock x:Name="CapacityHintText" TextWrapping="Wrap" FontSize="12"
                               Foreground="{DynamicResource App.Brush.Muted}"
                               Text="Лимит записей в DriveCare на один день. При достижении лимита день скрывается из выбора у клиента."/>
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <TextBlock Text="Машин в день:" VerticalAlignment="Center" Margin="0,0,12,0"
                                   Foreground="{DynamicResource App.Brush.Foreground}" FontSize="14"/>
                        <Button Content="−" Style="{StaticResource App.Button.Outline}" Width="40" Height="36"
                                FontSize="18" FontWeight="Bold" Click="MaxCarsDecrease_Click"/>
                        <TextBox x:Name="MaxBookingsPerDayBox" Width="64" Height="36" Margin="8,0"
                                 VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                 MaxLength="3" FontSize="16" FontWeight="SemiBold"/>
                        <Button Content="+" Style="{StaticResource App.Button.Outline}" Width="40" Height="36"
                                FontSize="18" FontWeight="Bold" Margin="8,0,0,0" Click="MaxCarsIncrease_Click"/>
                        <Button Content="Сохранить лимит" Style="{StaticResource App.Button.Primary}"
                                Height="36" MinWidth="140" Margin="16,0,0,0" Click="SaveCapacityOnly_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <Border Grid.Row="3" CornerRadius="12" Padding="12"
                Background="{DynamicResource App.Brush.SurfaceCard}"
                BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">
            <DataGrid x:Name="ScheduleGrid" AutoGenerateColumns="False" CanUserAddRows="False"
                      HeadersVisibility="Column" SelectionMode="Single" RowHeight="40">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="День" Binding="{Binding DayName}" Width="130" IsReadOnly="True"/>
                    <DataGridCheckBoxColumn Header="Выходной" Binding="{Binding IsClosed, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                    <DataGridTextColumn Header="С" Binding="{Binding OpenTimeText, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                    <DataGridTextColumn Header="До" Binding="{Binding CloseTimeText, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <TextBlock x:Name="StatusText" Grid.Row="4" Margin="0,10,0,8" TextWrapping="Wrap" FontSize="12"
                   Foreground="{DynamicResource App.Brush.Muted}"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,36,0,0">
            <Button Content="Сбросить по умолчанию" Style="{StaticResource App.Button.Outline}"
                    Height="40" MinWidth="160" Margin="0,0,10,0" Click="ResetDefault_Click"/>
            <Button Content="Сохранить" Style="{StaticResource App.Button.Primary}"
                    Height="40" MinWidth="140" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Page>
