<Page x:Class="DriveCarePro.Pages.OwnerEmployeesManagePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Управление сотрудниками">

    <Grid Background="{DynamicResource App.Brush.Panel}" Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,16" LastChildFill="False">
            <Button DockPanel.Dock="Left" Content="← На главную" Style="{StaticResource App.Button.Outline}"
                    Height="40" MinWidth="130" Click="Back_Click"/>
            <Button DockPanel.Dock="Right" Content="Обновить" Style="{StaticResource App.Button.Outline}"
                    Height="40" MinWidth="120" Click="Refresh_Click"/>
        </DockPanel>

        <Border Grid.Row="1" CornerRadius="12" Padding="16,14"
                Background="{DynamicResource App.Brush.SurfaceCard}"
                BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock x:Name="HintText" Grid.Row="0" FontSize="13" Margin="0,0,0,10" TextWrapping="Wrap"
                           Foreground="{DynamicResource App.Brush.Muted}"/>
                <DataGrid x:Name="Grid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                          SelectionMode="Single" HeadersVisibility="Column" MinHeight="200" MaxHeight="320"
                          AlternatingRowBackground="{DynamicResource App.Brush.Surface2}"
                          Foreground="{DynamicResource App.Brush.Foreground}" RowHeight="36"
                          Background="Transparent" BorderThickness="0"
                          SelectionChanged="Grid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="2*" MinWidth="140"/>
                        <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="110"/>
                        <DataGridTextColumn Header="Мастерская" Binding="{Binding WorkshopName}" Width="*" MinWidth="100"/>
                        <DataGridTextColumn Header="Роли" Binding="{Binding RolesDisplay}" Width="*" MinWidth="120"/>
                        <DataGridTextColumn Header="Активен" Binding="{Binding ActiveDisplay}" Width="70"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border x:Name="EditPanel" Grid.Row="2" Margin="0,16,0,0" CornerRadius="12" Padding="20,16"
                Background="{DynamicResource App.Brush.SurfaceCard}"
                BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1" Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="Карточка сотрудника" FontSize="15" FontWeight="SemiBold"
                           Foreground="{DynamicResource App.Brush.Foreground}" Margin="0,0,0,12"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,10">
                        <TextBlock Text="Фамилия" FontSize="12" Foreground="{DynamicResource App.Brush.Muted}"/>
                        <TextBox x:Name="LastNameBox" Style="{StaticResource App.FieldTextBox}" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,10">
                        <TextBlock Text="Имя" FontSize="12" Foreground="{DynamicResource App.Brush.Muted}"/>
                        <TextBox x:Name="FirstNameBox" Style="{StaticResource App.FieldTextBox}" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,10">
                        <TextBlock Text="Отчество" FontSize="12" Foreground="{DynamicResource App.Brush.Muted}"/>
                        <TextBox x:Name="MidNameBox" Style="{StaticResource App.FieldTextBox}" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,10">
                        <TextBlock Text="Логин" FontSize="12" Foreground="{DynamicResource App.Brush.Muted}"/>
                        <TextBox x:Name="LoginBox" Style="{StaticResource App.FieldTextBox}" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,10">
                        <TextBlock Text="Email" FontSize="12" Foreground="{DynamicResource App.Brush.Muted}"/>
                        <TextBox x:Name="EmailBox" Style="{StaticResource App.FieldTextBox}" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,10">
                        <TextBlock Text="Телефон" FontSize="12" Foreground="{DynamicResource App.Brush.Muted}"/>
                        <TextBox x:Name="PhoneBox" Style="{StaticResource App.FieldTextBox}" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3">
                        <TextBlock Text="Мастерская" FontSize="12" Foreground="{DynamicResource App.Brush.Muted}"/>
                        <ComboBox x:Name="WorkshopCombo" Height="36" Margin="0,4,0,0"
                                  DisplayMemberPath="Name" SelectedValuePath="RowId"/>
                        <CheckBox x:Name="IsActiveCheck" Content="Сотрудник активен" Margin="0,12,0,0"
                                  Foreground="{DynamicResource App.Brush.Foreground}"/>
                    </StackPanel>
                </Grid>
                <Button Content="Сохранить изменения" Style="{StaticResource App.Button.Primary}"
                        Height="44" MinWidth="200" HorizontalAlignment="Left" Margin="0,16,0,0"
                        Click="Save_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
