<Page x:Class="DriveCarePro.Pages.OwnerEmployeesManagePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Управление сотрудниками">

    <Grid Background="{DynamicResource App.Brush.Panel}" Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,12" LastChildFill="False">
            <Button DockPanel.Dock="Left" Content="← На главную" Style="{StaticResource App.Button.Outline}"
                    Height="40" MinWidth="130" Click="Back_Click"/>
            <WrapPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button x:Name="BtnAdd" Content="Добавить сотрудника" Style="{StaticResource App.Button.Primary}"
                        Height="40" MinWidth="170" Margin="0,0,8,0" Click="Add_Click"/>
                <Button x:Name="BtnEdit" Content="Изменить" Style="{StaticResource App.Button.Outline}"
                        Height="40" MinWidth="110" Margin="0,0,8,0" Click="Edit_Click"/>
                <Button x:Name="BtnRefresh" Content="Обновить" Style="{StaticResource App.Button.Outline}"
                        Height="40" MinWidth="110" Margin="0,0,8,0" Click="Refresh_Click"/>
                <Button x:Name="BtnDelete" Content="Удалить" Style="{StaticResource App.Button.Outline}"
                        Height="40" MinWidth="100" Margin="0,0,8,0" Click="Delete_Click"/>
                <Button x:Name="BtnAssignRoles" Content="Назначить роли" Style="{StaticResource App.Button.Outline}"
                        Height="40" MinWidth="140" Click="AssignRoles_Click"/>
            </WrapPanel>
        </DockPanel>

        <TextBlock x:Name="HintText" Grid.Row="1" FontSize="13" Margin="0,0,0,10" TextWrapping="Wrap"
                   Foreground="{DynamicResource App.Brush.Muted}"/>

        <Border Grid.Row="2" CornerRadius="12" Padding="16,14"
                Background="{DynamicResource App.Brush.SurfaceCard}"
                BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">
            <DataGrid x:Name="Grid" AutoGenerateColumns="False" IsReadOnly="True"
                      SelectionMode="Single" HeadersVisibility="Column"
                      AlternatingRowBackground="{DynamicResource App.Brush.Surface2}"
                      Foreground="{DynamicResource App.Brush.Foreground}" RowHeight="36"
                      Background="Transparent" BorderThickness="0"
                      SelectionChanged="Grid_SelectionChanged"
                      MouseDoubleClick="Grid_MouseDoubleClick"
                      PreviewMouseRightButtonDown="Grid_PreviewMouseRightButtonDown">
                <DataGrid.ContextMenu>
                    <ContextMenu Opened="GridContextMenu_Opened">
                        <MenuItem x:Name="CtxAddItem" Header="Добавить сотрудника" Click="Add_Click"/>
                        <MenuItem x:Name="CtxEditItem" Header="Изменить" Click="Edit_Click"/>
                        <MenuItem x:Name="CtxAssignRolesItem" Header="Назначить роли" Click="AssignRoles_Click"/>
                        <MenuItem x:Name="CtxDeleteItem" Header="Удалить" Click="Delete_Click"/>
                        <Separator/>
                        <MenuItem Header="Обновить список" Click="Refresh_Click"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="2*" MinWidth="140"/>
                    <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="100"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*" MinWidth="120"/>
                    <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="110"/>
                    <DataGridTextColumn Header="Мастерская" Binding="{Binding WorkshopName}" Width="*" MinWidth="90"/>
                    <DataGridTextColumn Header="Роли" Binding="{Binding RolesDisplay}" Width="*" MinWidth="100"/>
                    <DataGridTextColumn Header="Активен" Binding="{Binding ActiveDisplay}" Width="64"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>
