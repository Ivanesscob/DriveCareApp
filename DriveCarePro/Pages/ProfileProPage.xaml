<Page x:Class="DriveCarePro.Pages.ProfileProPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Профиль">

    <Grid Background="{DynamicResource App.Brush.Panel}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="24,18,24,12" LastChildFill="False">
            <Button DockPanel.Dock="Left" Content="← Назад" Style="{StaticResource App.Button.Outline}"
                    Height="40" MinWidth="120" Click="Back_Click"/>
            <TextBlock DockPanel.Dock="Left" Margin="20,0,0,0" VerticalAlignment="Center"
                       Text="Профиль и настройки" FontSize="22" FontWeight="SemiBold"
                       Foreground="{DynamicResource App.Brush.Foreground}"/>
        </DockPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,0,24,28">
            <StackPanel MaxWidth="720">
                <Border CornerRadius="14" Padding="20" Background="{DynamicResource App.Brush.SurfaceCard}"
                        BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Сотрудник" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource App.Brush.Foreground}"/>
                        <TextBlock x:Name="EmployeeNameText" Margin="0,8,0,0" FontSize="15"
                                   Foreground="{DynamicResource App.Brush.SecondaryText}" TextWrapping="Wrap"/>
                        <TextBlock x:Name="EmployeeLoginText" Margin="0,4,0,0" FontSize="13"
                                   Foreground="{DynamicResource App.Brush.Muted}" TextWrapping="Wrap"/>
                        <TextBlock x:Name="EmployeeEmailText" Margin="0,4,0,0" FontSize="13"
                                   Foreground="{DynamicResource App.Brush.Muted}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border CornerRadius="14" Padding="20" Background="{DynamicResource App.Brush.SurfaceCard}"
                        BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Тема оформления" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource App.Brush.Foreground}"/>
                        <TextBlock Text="Сохраняется отдельно для каждого вошедшего сотрудника на этом компьютере."
                                   FontSize="12" Foreground="{DynamicResource App.Brush.Muted}" TextWrapping="Wrap" Margin="0,6,0,16"/>

                        <RadioButton x:Name="RadioThemeDark" GroupName="UiTheme" Content="Тёмная"
                                     Foreground="{DynamicResource App.Brush.Foreground}" FontSize="14"
                                     Margin="0,0,0,8" Checked="ThemeDark_Checked"/>
                        <RadioButton x:Name="RadioThemeLight" GroupName="UiTheme" Content="Светлая"
                                     Foreground="{DynamicResource App.Brush.Foreground}" FontSize="14"
                                     Margin="0,0,0,16" Checked="ThemeLight_Checked"/>

                        <Button Content="Выйти из аккаунта" Style="{StaticResource App.Button.Outline}"
                                Height="42" MinWidth="200" HorizontalAlignment="Left" Click="SignOut_Click"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
