<Page x:Class="DriveCarePro.Pages.ProfileProPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
      Title="Профиль">

    <Page.Resources>
        <LinearGradientBrush x:Key="ProProfile.HeroGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF4F46E5" Offset="0"/>
            <GradientStop Color="#FF6366F1" Offset="0.55"/>
            <GradientStop Color="#FF818CF8" Offset="1"/>
        </LinearGradientBrush>
    </Page.Resources>

    <Grid Background="{DynamicResource App.Brush.Panel}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="24,18,24,32" MaxWidth="800">

                <Button Content="← Назад" Style="{StaticResource App.Button.Outline}"
                        Height="40" MinWidth="120" HorizontalAlignment="Left" Margin="0,0,0,16"
                        Click="Back_Click"/>

                <!-- Hero -->
                <Border CornerRadius="20" ClipToBounds="True" Margin="0,0,0,20">
                    <Border.Background>
                        <StaticResource ResourceKey="ProProfile.HeroGradient"/>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="18" ShadowDepth="3" Opacity="0.18" Color="#40000000"/>
                    </Border.Effect>
                    <Grid Margin="26,22">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="76" Height="76" CornerRadius="38"
                                Background="#30FFFFFF" BorderBrush="#55FFFFFF" BorderThickness="2">
                            <TextBlock x:Name="HeroInitials" Text="PR"
                                       FontSize="26" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="18,6,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="EmployeeNameText" FontSize="24" FontWeight="Bold"
                                       Foreground="White" TextWrapping="Wrap"/>
                            <TextBlock x:Name="RoleBadgeText" FontSize="12" Foreground="#E0E7FF"
                                       Margin="0,8,0,0" TextWrapping="Wrap"/>
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <Border Background="#28FFFFFF" CornerRadius="8" Padding="10,5" Margin="0,0,8,0">
                                    <TextBlock x:Name="EmployeeLoginText" FontSize="12" Foreground="#F1F5FF"/>
                                </Border>
                                <Border Background="#28FFFFFF" CornerRadius="8" Padding="10,5">
                                    <TextBlock x:Name="EmployeeEmailText" FontSize="12" Foreground="#F1F5FF"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Контакты -->
                <Border CornerRadius="16" Padding="20" Margin="0,0,0,16"
                        Background="{DynamicResource App.Brush.SurfaceCard}"
                        BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Контакты" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource App.Brush.Foreground}" Margin="0,0,0,14"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <iconPacks:PackIconModern Kind="Phone" Width="18" Height="18"
                                        Foreground="{DynamicResource App.Brush.Accent}" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="EmployeePhoneText" Margin="10,0,0,0" FontSize="14"
                                               Foreground="{DynamicResource App.Brush.SecondaryText}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconModern Kind="Office" Width="18" Height="18"
                                        Foreground="{DynamicResource App.Brush.Accent}" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="WorkshopText" Margin="10,0,0,0" FontSize="14"
                                               Foreground="{DynamicResource App.Brush.SecondaryText}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Тема -->
                <Border CornerRadius="16" Padding="20" Margin="0,0,0,16"
                        Background="{DynamicResource App.Brush.SurfaceCard}"
                        BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Тема оформления" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource App.Brush.Foreground}"/>
                        <TextBlock Text="Сохраняется для каждого сотрудника на этом компьютере."
                                   FontSize="12" Foreground="{DynamicResource App.Brush.Muted}"
                                   TextWrapping="Wrap" Margin="0,6,0,16"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border x:Name="ThemeDarkCard" Grid.Column="0" CornerRadius="14" Padding="16" Cursor="Hand"
                                    MouseLeftButtonUp="ThemeDarkCard_Click"
                                    Background="#FF1E293B" BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="2">
                                <StackPanel>
                                    <iconPacks:PackIconModern Kind="Moon" Width="26" Height="26" Foreground="#94A3B8"/>
                                    <TextBlock Text="Тёмная" FontSize="15" FontWeight="SemiBold" Foreground="White" Margin="0,8,0,2"/>
                                    <Border x:Name="ThemeDarkCheck" Margin="0,8,0,0" CornerRadius="8" Padding="8,4"
                                            Background="{DynamicResource App.Brush.Accent}" Visibility="Collapsed">
                                        <TextBlock Text="Выбрано" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Border x:Name="ThemeLightCard" Grid.Column="2" CornerRadius="14" Padding="16" Cursor="Hand"
                                    MouseLeftButtonUp="ThemeLightCard_Click"
                                    Background="#FFF8FAFC" BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="2">
                                <StackPanel>
                                    <iconPacks:PackIconModern Kind="WeatherSun" Width="26" Height="26" Foreground="#F59E0B"/>
                                    <TextBlock Text="Светлая" FontSize="15" FontWeight="SemiBold" Foreground="#0F172A" Margin="0,8,0,2"/>
                                    <Border x:Name="ThemeLightCheck" Margin="0,8,0,0" CornerRadius="8" Padding="8,4"
                                            Background="{DynamicResource App.Brush.Accent}" Visibility="Collapsed">
                                        <TextBlock Text="Выбрано" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <RadioButton x:Name="RadioThemeDark" GroupName="UiTheme" Visibility="Collapsed"
                                     Checked="ThemeDark_Checked"/>
                        <RadioButton x:Name="RadioThemeLight" GroupName="UiTheme" Visibility="Collapsed"
                                     Checked="ThemeLight_Checked"/>
                    </StackPanel>
                </Border>

                <!-- Выход -->
                <Border CornerRadius="16" Padding="20"
                        Background="{DynamicResource App.Brush.SurfaceCard}"
                        BorderBrush="{DynamicResource App.Brush.DangerBorder}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Сеанс" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource App.Brush.Foreground}"/>
                            <TextBlock Text="Выйти из DriveCare Pro на этом устройстве."
                                       FontSize="12" Foreground="{DynamicResource App.Brush.Muted}"
                                       Margin="0,6,12,0" TextWrapping="Wrap"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Выйти" Style="{StaticResource App.Button.Outline}"
                                Height="44" MinWidth="130" Click="SignOut_Click"/>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
