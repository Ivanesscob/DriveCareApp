<Window x:Class="DriveCarePro.Windows.WorkshopServiceEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Услуга"
        Width="520" Height="440" MinWidth="480" MinHeight="400" MaxHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource App.Brush.Panel}"
        ResizeMode="CanResizeWithGrip">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="HeaderText" Grid.Row="0" Text="Новая услуга" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource App.Brush.Foreground}" Margin="0,0,0,14"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Название *" FontSize="12" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,0,0,4"/>
                <TextBox x:Name="NameBox" Style="{StaticResource App.FieldTextBox}" MaxLength="300" Margin="0,0,0,10"/>

                <TextBlock Text="Описание" FontSize="12" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,0,0,4"/>
                <TextBox x:Name="DescriptionBox" Style="{StaticResource App.FieldTextBox}"
                         MaxLength="500" MinHeight="72" MaxHeight="96"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" Margin="0,0,0,4"/>
                <TextBlock x:Name="DescriptionCounter" FontSize="11"
                           Foreground="{DynamicResource App.Brush.Muted}" Margin="0,0,0,10"/>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="160"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Цена, ₽ *" FontSize="12" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,0,0,4"/>
                        <TextBox x:Name="PriceBox" Style="{StaticResource App.FieldTextBox}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Единица измерения *" FontSize="12" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="UnitCombo" MinHeight="36" DisplayMemberPath="Name"
                                  SelectedValuePath="RowId" VerticalContentAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <CheckBox x:Name="ActiveCheck" Content="Услуга активна (доступна при выборе в отчёте)"
                          Foreground="{DynamicResource App.Brush.Foreground}" IsChecked="True"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Отмена" Style="{StaticResource App.Button.Outline}" MinWidth="110" Height="40" Margin="0,0,10,0"
                    Click="Cancel_Click"/>
            <Button Content="Сохранить" Style="{StaticResource App.Button.Primary}" MinWidth="120" Height="40"
                    Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
