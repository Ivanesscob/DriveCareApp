<Window x:Class="DriveCarePro.Windows.PermissionEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Разрешение"
        Width="520" Height="360" MinWidth="460" MinHeight="320"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource App.Brush.Panel}"
        ResizeMode="CanResizeWithGrip">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="HeaderText" Grid.Row="0" Text="Изменить разрешение"
                   FontSize="16" FontWeight="SemiBold"
                   Foreground="{DynamicResource App.Brush.Foreground}" Margin="0,0,0,14"/>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Группа" FontSize="12" Foreground="{DynamicResource App.Brush.Muted}"/>
            <ComboBox x:Name="GroupPicker" MinHeight="36" Margin="0,4,0,10" DisplayMemberPath="Name"/>

            <TextBlock Text="Код" FontSize="12" Foreground="{DynamicResource App.Brush.Muted}"/>
            <TextBox x:Name="CodeBox" Style="{StaticResource App.FieldTextBox}" MinHeight="36" Margin="0,4,0,10"/>

            <TextBlock Text="Название" FontSize="12" Foreground="{DynamicResource App.Brush.Muted}"/>
            <TextBox x:Name="NameBox" Style="{StaticResource App.FieldTextBox}" MinHeight="36" Margin="0,4,0,10"/>

            <TextBlock Text="Описание" FontSize="12" Foreground="{DynamicResource App.Brush.Muted}"/>
            <TextBox x:Name="DescriptionBox" Style="{StaticResource App.FieldTextBox}" MinHeight="56"
                     AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Margin="0,4,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Отмена" Style="{StaticResource App.Button.Outline}" MinWidth="100" Height="36" Margin="0,0,8,0"
                    Click="Cancel_Click"/>
            <Button Content="Сохранить" Style="{StaticResource App.Button.Primary}" MinWidth="110" Height="36"
                    Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
