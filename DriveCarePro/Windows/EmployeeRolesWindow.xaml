<Window x:Class="DriveCarePro.Windows.EmployeeRolesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Роли сотрудника"
        Width="480" Height="520" MinWidth="420" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource App.Brush.Panel}"
        ResizeMode="CanResizeWithGrip">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="HeaderText" Grid.Row="0" FontSize="17" FontWeight="SemiBold"
                   Foreground="{DynamicResource App.Brush.Foreground}" TextWrapping="Wrap"/>
        <TextBlock Grid.Row="1" FontSize="12" Margin="0,6,0,10" TextWrapping="Wrap"
                   Foreground="{DynamicResource App.Brush.Muted}"
                   Text="Отметьте роли для сотрудника. Сохранение обновит таблицу EmployeeRolesMap."/>

        <StackPanel Grid.Row="2">
            <TextBox x:Name="RoleSearchBox" Style="{StaticResource App.FieldTextBox}"
                     MinHeight="36" Margin="0,0,0,8"
                     TextChanged="RoleSearchBox_TextChanged"/>
            <TextBlock x:Name="RolesEmptyText" FontSize="12" Margin="0,0,0,8"
                       Foreground="{DynamicResource App.Brush.Muted}" TextWrapping="Wrap"
                       Visibility="Collapsed"
                       Text="Нет ролей организации. Создайте роли в конструкторе ролей."/>
            <Border Padding="10" CornerRadius="8" MinHeight="200"
                    Background="{DynamicResource App.Brush.SurfaceCard}"
                    BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="RolesItems">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding DisplayText}"
                                          IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Margin="0,6" Foreground="{DynamicResource App.Brush.Foreground}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Конструктор ролей" Style="{StaticResource App.Button.Outline}"
                    Height="40" MinWidth="150" Margin="0,0,10,0" Click="OpenRoleConstructor_Click"/>
            <Button Content="Отмена" Style="{StaticResource App.Button.Outline}"
                    Height="40" MinWidth="100" Margin="0,0,10,0" Click="Cancel_Click"/>
            <Button Content="Сохранить" Style="{StaticResource App.Button.Primary}"
                    Height="40" MinWidth="120" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
