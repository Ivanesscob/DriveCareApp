<Window x:Class="DriveCarePro.Windows.BookingRejectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Отклонить запись" Height="320" Width="440"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource App.Brush.PageBackground}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Отклонение записи" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource App.Brush.Foreground}" Margin="0,0,0,8"/>
        <TextBlock x:Name="SummaryText" Grid.Row="1" TextWrapping="Wrap" FontSize="13"
                   Foreground="{DynamicResource App.Brush.SecondaryText}" Margin="0,0,0,12"/>
        <TextBlock Grid.Row="2" Text="Причина отклонения *" FontSize="12"
                   Foreground="{DynamicResource App.Brush.Muted}" Margin="0,0,0,4"/>
        <TextBox x:Name="ReasonBox" Grid.Row="3" Style="{StaticResource App.FieldTextBox}"
                 MinHeight="80" AcceptsReturn="True" TextWrapping="Wrap"/>
        <TextBlock Grid.Row="4" Text="Причина будет отправлена клиенту в чат."
                   FontSize="11" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,8,0,0"/>
        <TextBlock x:Name="ErrorText" Grid.Row="4" Foreground="#C62828" TextWrapping="Wrap"
                   Visibility="Collapsed"/>
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Отмена" Style="{StaticResource App.Button.Outline}" Width="100" Height="36"
                    Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="Отклонить" Width="120" Height="36" Click="Reject_Click">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource App.Button.Outline}">
                        <Setter Property="Foreground" Value="#C62828"/>
                        <Setter Property="BorderBrush" Value="#C62828"/>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>
