<Window x:Class="DriveCarePro.Windows.WorkshopPaintColorEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Цвет покраски"
        Width="400" Height="200" MinWidth="360"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource App.Brush.Panel}">
    <Border Padding="20">
        <StackPanel>
            <TextBlock Text="Название цвета" FontSize="12" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,0,0,4"/>
            <TextBox x:Name="ColorNameBox" Style="{StaticResource App.FieldTextBox}" MinHeight="40"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="Отмена" Style="{StaticResource App.Button.Outline}" MinWidth="90" Height="36"
                        Margin="0,0,8,0" IsCancel="True" Click="Cancel_Click"/>
                <Button Content="Добавить" Style="{StaticResource App.Button.Primary}" MinWidth="100" Height="36"
                        IsDefault="True" Click="Save_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
