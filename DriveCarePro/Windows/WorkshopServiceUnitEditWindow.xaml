<Window x:Class="DriveCarePro.Windows.WorkshopServiceUnitEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Единица измерения"
        Width="400" Height="220" MinWidth="360" MinHeight="200"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource App.Brush.Panel}"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="HeaderText" Grid.Row="0" Text="Новая единица" FontSize="16" FontWeight="SemiBold"
                   Foreground="{DynamicResource App.Brush.Foreground}" Margin="0,0,0,12"/>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Краткое обозначение *" FontSize="12" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,0,0,4"/>
            <TextBox x:Name="NameBox" Style="{StaticResource App.FieldTextBox}" MaxLength="30" Margin="0,0,0,8"/>
            <TextBlock Text="Например: усл., ч., шт." FontSize="11" Foreground="{DynamicResource App.Brush.Muted}"/>
            <CheckBox x:Name="ActiveCheck" Content="Активна" Margin="0,10,0,0"
                      Foreground="{DynamicResource App.Brush.Foreground}" IsChecked="True"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Отмена" Style="{StaticResource App.Button.Outline}" MinWidth="100" Height="36" Margin="0,0,8,0"
                    Click="Cancel_Click"/>
            <Button Content="Сохранить" Style="{StaticResource App.Button.Primary}" MinWidth="110" Height="36"
                    Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
