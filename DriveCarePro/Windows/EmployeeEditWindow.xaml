<Window x:Class="DriveCarePro.Windows.EmployeeEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Сотрудник"
        Width="640" Height="720" MinWidth="560" MinHeight="600"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource App.Brush.Panel}"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource App.Brush.Muted}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock x:Name="HeaderText" Text="Новый сотрудник" FontSize="18" FontWeight="SemiBold"
                       Foreground="{DynamicResource App.Brush.Foreground}"/>
            <TextBlock x:Name="SubHeaderText" FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap"
                       Foreground="{DynamicResource App.Brush.Muted}"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,10">
                        <TextBlock Text="Фамилия *" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="LastNameBox" Style="{StaticResource App.FieldTextBox}" Margin="0,0,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,10">
                        <TextBlock Text="Имя *" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="FirstNameBox" Style="{StaticResource App.FieldTextBox}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,10">
                        <TextBlock Text="Отчество" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="MidNameBox" Style="{StaticResource App.FieldTextBox}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,10">
                        <TextBlock Text="Логин *" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="LoginBox" Style="{StaticResource App.FieldTextBox}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,10">
                        <TextBlock x:Name="PasswordLabel" Text="Пароль *" Style="{StaticResource FieldLabel}"/>
                        <PasswordBox x:Name="PasswordBox" Style="{StaticResource App.FieldPasswordBox}" MinHeight="36"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,10">
                        <TextBlock Text="Email" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="EmailBox" Style="{StaticResource App.FieldTextBox}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,0,10">
                        <TextBlock Text="Телефон" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="PhoneBox" Style="{StaticResource App.FieldTextBox}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="3" Grid.Column="2" Margin="0,0,0,10">
                        <TextBlock Text="Мастерская *" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="WorkshopCombo" MinHeight="36"
                                  DisplayMemberPath="Name" SelectedValuePath="RowId"/>
                    </StackPanel>
                    <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,0,0,10">
                        <TextBlock Text="Дата рождения" Style="{StaticResource FieldLabel}"/>
                        <DatePicker x:Name="BirthDatePicker" Height="36"/>
                    </StackPanel>
                    <StackPanel Grid.Row="4" Grid.Column="2" Margin="0,0,0,10">
                        <TextBlock Text="Дата приёма" Style="{StaticResource FieldLabel}"/>
                        <DatePicker x:Name="HireDatePicker" Height="36"/>
                    </StackPanel>
                    <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,10">
                        <TextBlock Text="Описание" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="DescriptionBox" Style="{StaticResource App.FieldTextBox}"
                                 MinHeight="52" AcceptsReturn="True" TextWrapping="Wrap"/>
                        <CheckBox x:Name="IsActiveCheck" Content="Сотрудник активен" Margin="0,12,0,0"
                                  Foreground="{DynamicResource App.Brush.Foreground}" IsChecked="True"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Роли сотрудника" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource App.Brush.Foreground}" Margin="0,4,0,4"/>
                <TextBlock FontSize="11" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,0,0,8"
                           Text="Отметьте одну или несколько ролей — права подтянутся при входе сотрудника."/>
                <TextBox x:Name="RoleSearchBox" Style="{StaticResource App.FieldTextBox}"
                         MinHeight="34" Margin="0,0,0,8" TextChanged="RoleSearchBox_TextChanged"/>
                <TextBlock x:Name="RolesEmptyText" FontSize="12" Margin="0,0,0,8"
                           Foreground="{DynamicResource App.Brush.Muted}" TextWrapping="Wrap"
                           Visibility="Collapsed"
                           Text="Нет ролей в организации. Создайте их в «Конструктор ролей» на главной."/>
                <Border MaxHeight="180" Padding="8" CornerRadius="8"
                        Background="{DynamicResource App.Brush.SurfaceCard}"
                        BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="RolesItems">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding DisplayText}"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              Margin="0,5" Foreground="{DynamicResource App.Brush.Foreground}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Отмена" Style="{StaticResource App.Button.Outline}"
                    Height="42" MinWidth="110" Margin="0,0,10,0" Click="Cancel_Click"/>
            <Button Content="Сохранить" Style="{StaticResource App.Button.Primary}"
                    Height="42" MinWidth="130" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
