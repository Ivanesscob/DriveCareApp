<Window x:Class="DriveCarePro.Windows.ServiceManualClientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Клиент и автомобиль" SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" MinWidth="460">

    <Border Padding="24,20" Background="{DynamicResource App.Brush.SurfaceCard}">
        <StackPanel HorizontalAlignment="Center" MinWidth="400" MaxWidth="440">
            <TextBlock x:Name="HeaderText" Text="Данные без регистрации" FontSize="16" FontWeight="SemiBold"
                       HorizontalAlignment="Center" Margin="0,0,0,12"/>
            <StackPanel x:Name="ClientPanel">
                <TextBlock Text="ФИО / имя клиента" FontSize="12" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,0,0,4"/>
                <TextBox x:Name="NameBox" MinHeight="34" Margin="0,0,0,10"/>
                <TextBlock Text="Телефон" FontSize="12" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,0,0,4"/>
                <TextBox x:Name="PhoneBox" MinHeight="34" Margin="0,0,0,10"/>
                <TextBlock Text="Email" FontSize="12" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,0,0,4"/>
                <TextBox x:Name="EmailBox" MinHeight="34" Margin="0,0,0,10"/>
            </StackPanel>
            <TextBlock Text="Марка и модель" FontSize="12" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,0,0,4"/>
            <TextBox x:Name="CarDescriptionBox" MinHeight="34" Margin="0,0,0,10"/>
            <TextBlock Text="VIN" FontSize="12" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,0,0,4"/>
            <TextBox x:Name="VinBox" MinHeight="34" Margin="0,0,0,10"/>
            <TextBlock Text="Гос. номер" FontSize="12" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,0,0,4"/>
            <TextBox x:Name="PlateBox" MinHeight="34" Margin="0,0,0,16"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Отмена" Style="{StaticResource App.Button.Outline}" MinWidth="110" Height="36" Margin="0,0,10,0" Click="Cancel_Click"/>
                <Button Content="Продолжить" Style="{StaticResource App.Button.Primary}" MinWidth="130" Height="36" Click="Save_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
