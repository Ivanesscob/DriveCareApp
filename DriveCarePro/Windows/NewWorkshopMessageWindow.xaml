<Window x:Class="DriveCarePro.Windows.NewWorkshopMessageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Написать клиенту"
        Width="520" Height="500" MinWidth="480" MinHeight="460"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource App.Brush.Panel}">
    <Grid Margin="24,20,24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Новое сообщение посетителю" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource App.Brush.Foreground}"/>
        <TextBlock Grid.Row="1" Text="Клиент должен быть зарегистрирован в DriveCare (запись в сервис или профиль)."
                   FontSize="12" TextWrapping="Wrap" Margin="0,8,0,12"
                   Foreground="{DynamicResource App.Brush.Muted}"/>

        <TextBlock Grid.Row="2" Text="Клиент" FontSize="13" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,0,0,6"/>
        <ComboBox Grid.Row="3" x:Name="VisitorCombo" MinHeight="44" DisplayMemberPath="DisplayName" Margin="0,0,0,12"/>

        <TextBlock Grid.Row="4" Text="Сообщение" FontSize="13" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,0,0,6"/>
        <TextBox Grid.Row="5" x:Name="MessageText" MinHeight="100"
                 AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                 Style="{StaticResource App.FieldTextBox}"/>

        <TextBlock Grid.Row="6" x:Name="ErrorText" Margin="0,8,0,0" FontSize="12" TextWrapping="Wrap"
                   Foreground="{DynamicResource App.Brush.DangerBorder}" Visibility="Collapsed"/>

        <Border Grid.Row="7" Padding="0,12,0,0"
                BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена" Style="{StaticResource App.Button.Outline}" MinWidth="120" Height="40"
                        Margin="0,0,12,0" IsCancel="True" Click="Cancel_Click"/>
                <Button Content="Отправить" Style="{StaticResource App.Button.Primary}" MinWidth="130" Height="40"
                        IsDefault="True" Click="Send_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
