<Window x:Class="DriveCarePro.Windows.BookingAcceptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Подтвердить запись" Height="340" Width="440"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource App.Brush.PageBackground}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Подтверждение записи" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource App.Brush.Foreground}" Margin="0,0,0,8"/>
        <TextBlock x:Name="SummaryText" Grid.Row="1" TextWrapping="Wrap" FontSize="13"
                   Foreground="{DynamicResource App.Brush.SecondaryText}" Margin="0,0,0,14"/>
        <TextBlock Grid.Row="2" Text="Когда ждать клиента *" FontSize="12"
                   Foreground="{DynamicResource App.Brush.Muted}" Margin="0,0,0,4"/>
        <TextBox x:Name="VisitWhenBox" Grid.Row="3" Style="{StaticResource App.FieldTextBox}"
                 MinHeight="56" AcceptsReturn="True" TextWrapping="Wrap"
                 ToolTip="Например: 23.05.2026 в 10:00"/>
        <TextBlock Grid.Row="4" Text="Этот текст уйдёт клиенту в чат DriveCare."
                   FontSize="11" TextWrapping="Wrap" Foreground="{DynamicResource App.Brush.Muted}"
                   VerticalAlignment="Bottom" Margin="0,8,0,0"/>
        <TextBlock x:Name="ErrorText" Grid.Row="4" Foreground="#C62828" TextWrapping="Wrap"
                   Visibility="Collapsed" VerticalAlignment="Top"/>
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Отмена" Style="{StaticResource App.Button.Outline}" Width="100" Height="36"
                    Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="Принять" Style="{StaticResource App.Button.Primary}" Width="120" Height="36"
                    Click="Accept_Click"/>
        </StackPanel>
    </Grid>
</Window>
