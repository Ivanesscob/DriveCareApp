<Window x:Class="DriveCarePro.Windows.CreateCompanyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Создание компании"
        Width="760" Height="680" MinWidth="680" MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource App.Brush.Panel}"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource App.Brush.Foreground}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource App.Brush.Muted}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Новая компания" FontSize="20" FontWeight="SemiBold"
                       Foreground="{DynamicResource App.Brush.Foreground}"/>
            <TextBlock Text="Обязательные поля отмечены *. Адрес: введите в поиске и выберите из списка, квартира — отдельно. Будут созданы компания, мастерская и владелец (сотрудник с ролью владельца автосервиса)."
                       FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap"
                       Foreground="{DynamicResource App.Brush.Muted}"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>

                <Border CornerRadius="12" Padding="14" Margin="0,0,0,12"
                        Background="{DynamicResource App.Brush.SurfaceCard}"
                        BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Компания" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="Название *" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="CompanyNameBox" Style="{StaticResource App.FieldTextBox}" Margin="0,0,0,8"/>
                        <TextBlock Text="Описание" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="CompanyDescriptionBox" Style="{StaticResource App.FieldTextBox}"
                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="44"/>
                    </StackPanel>
                </Border>

                <Border CornerRadius="12" Padding="14" Margin="0,0,0,12"
                        Background="{DynamicResource App.Brush.SurfaceCard}"
                        BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Первая мастерская / точка" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="Название цеха *" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="WorkshopNameBox" Style="{StaticResource App.FieldTextBox}" Margin="0,0,0,8"/>
                        <TextBlock Text="Описание" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="WorkshopDescriptionBox" Style="{StaticResource App.FieldTextBox}"
                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="40"/>
                        <TextBlock Text="Типы услуг * (можно несколько)" Style="{StaticResource FieldLabel}" Margin="0,8,0,0"/>
                        <CheckBox x:Name="ChkCreateAuto" Content="Автосервис" Margin="0,6,0,4" IsChecked="True"/>
                        <CheckBox x:Name="ChkCreatePaint" Content="Покраска" Margin="0,0,0,4"/>
                        <CheckBox x:Name="ChkCreateTire" Content="Шиномонтаж"/>
                    </StackPanel>
                </Border>

                <Border CornerRadius="12" Padding="14" Margin="0,0,0,12"
                        Background="{DynamicResource App.Brush.SurfaceCard}"
                        BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Адрес" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="Поиск адреса (город, улица, дом) *" Style="{StaticResource FieldLabel}"/>
                        <TextBlock FontSize="11" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,0,0,4"
                                   TextWrapping="Wrap"
                                   Text="Например: Санкт-Петербург, СПб, Москва, Невский проспект 1"/>
                        <TextBox x:Name="AddressSearchBox" Style="{StaticResource App.FieldTextBox}"
                                 MinHeight="36" TextChanged="AddressSearchBox_TextChanged"/>

                        <Border x:Name="SuggestionsPanel" Margin="0,6,0,0" MaxHeight="200"
                                Background="{DynamicResource App.Brush.SurfaceCard}"
                                BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1"
                                CornerRadius="8" Visibility="Collapsed">
                            <ListBox x:Name="AddressSuggestionsList" BorderThickness="0"
                                     Background="Transparent" MaxHeight="190"
                                     SelectionChanged="AddressSuggestionsList_SelectionChanged"
                                     MouseLeftButtonUp="AddressSuggestionsList_MouseLeftButtonUp"
                                     PreviewKeyDown="AddressSuggestionsList_PreviewKeyDown">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Label}" TextWrapping="Wrap" Padding="8,6"
                                                   Foreground="{DynamicResource App.Brush.Foreground}"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>

                        <TextBlock x:Name="AddressSearchStatus" FontSize="11"
                                   Foreground="{DynamicResource App.Brush.Muted}" Margin="0,6,0,6"
                                   TextWrapping="Wrap"/>

                        <TextBlock Text="Выбранный адрес" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="AddressLineBox" Style="{StaticResource App.FieldTextBox}"
                                 MinHeight="36" IsReadOnly="True" Margin="0,0,0,10"/>

                        <TextBlock Text="Квартира / офис" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="ApartmentBox" Style="{StaticResource App.FieldTextBox}" Margin="0,0,0,10"/>

                        <TextBlock Text="Страна *" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="CountryCombo" DisplayMemberPath="Name"
                                  SelectedValuePath="RowId" MinHeight="34" Margin="0,0,0,0"/>
                    </StackPanel>
                </Border>

                <Border CornerRadius="12" Padding="14" Margin="0,0,0,12"
                        Background="{DynamicResource App.Brush.SurfaceCard}"
                        BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Владелец (сотрудник)" Style="{StaticResource SectionTitle}"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Фамилия *" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="LastNameBox" Style="{StaticResource App.FieldTextBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Имя *" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="FirstNameBox" Style="{StaticResource App.FieldTextBox}"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Отчество" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="MidNameBox" Style="{StaticResource App.FieldTextBox}" Margin="0,0,0,8"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Логин *" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="LoginBox" Style="{StaticResource App.FieldTextBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Пароль *" Style="{StaticResource FieldLabel}"/>
                                <PasswordBox x:Name="PasswordBox" Style="{StaticResource App.FieldPasswordBox}"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Email *" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="EmailBox" Style="{StaticResource App.FieldTextBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Телефон *" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="PhoneBox" Style="{StaticResource App.FieldTextBox}"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Дата рождения * (не младше 18 лет)" Style="{StaticResource FieldLabel}"/>
                        <DatePicker x:Name="BirthDatePicker" Margin="0,0,0,8"/>

                        <TextBlock Text="Описание сотрудника" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="EmployeeDescriptionBox" Style="{StaticResource App.FieldTextBox}"
                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="40"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Отмена" Style="{StaticResource App.Button.Outline}"
                    Width="120" Height="38" Margin="0,0,10,0" IsCancel="True" Click="Cancel_Click"/>
            <Button Content="Сохранить" Style="{StaticResource App.Button.Primary}"
                    Width="140" Height="38" IsDefault="True" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
