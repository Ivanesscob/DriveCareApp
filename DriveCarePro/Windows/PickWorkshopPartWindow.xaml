<Window x:Class="DriveCarePro.Windows.PickWorkshopPartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выбор детали со склада"
        Width="720" Height="500" MinWidth="560" MinHeight="380"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource App.Brush.Panel}"
        ResizeMode="CanResizeWithGrip">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Склад мастерской"
                       FontSize="16" FontWeight="SemiBold"
                       Foreground="{DynamicResource App.Brush.Foreground}"/>
            <TextBlock Text="Показаны только позиции с остатком на складе."
                       FontSize="12" Foreground="{DynamicResource App.Brush.Muted}"
                       TextWrapping="Wrap" Margin="0,6,0,0"/>
        </StackPanel>

        <TextBox x:Name="SearchBox" Grid.Row="1" Margin="0,12,0,10"
                 Style="{StaticResource App.FieldTextBox}" Height="36"
                 ToolTip="Поиск по названию или артикулу"/>

        <DataGrid x:Name="ItemsGrid" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" HeadersVisibility="Column"
                  AlternatingRowBackground="{DynamicResource App.Brush.Surface2}"
                  Foreground="{DynamicResource App.Brush.Foreground}" RowHeight="36"
                  Background="{DynamicResource App.Brush.SurfaceCard}"
                  BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1"
                  MouseDoubleClick="ItemsGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Наименование" Binding="{Binding ListLabel}" Width="2*" MinWidth="200"/>
                <DataGridTextColumn Header="Ед." Binding="{Binding UnitName}" Width="55"/>
                <DataGridTextColumn Header="На складе" Binding="{Binding QuantityOnHand}" Width="85"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding PriceLabel}" Width="90"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Отмена" Style="{StaticResource App.Button.Outline}" MinWidth="110" Height="40" Margin="0,0,10,0"
                    Click="Cancel_Click"/>
            <Button Content="Добавить" Style="{StaticResource App.Button.Primary}" MinWidth="120" Height="40"
                    Click="Confirm_Click"/>
        </StackPanel>
    </Grid>
</Window>
