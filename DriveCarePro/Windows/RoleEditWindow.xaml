<Window x:Class="DriveCarePro.Windows.RoleEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Роль"
        Width="640" Height="620" MinWidth="560" MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource App.Brush.Panel}"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource App.Brush.Muted}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock x:Name="HeaderText" Text="Новая роль" FontSize="18" FontWeight="SemiBold"
                       Foreground="{DynamicResource App.Brush.Foreground}"/>
            <TextBlock x:Name="SubHeaderText" FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap"
                       Foreground="{DynamicResource App.Brush.Muted}"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border CornerRadius="12" Padding="14" Margin="0,0,0,12"
                        Background="{DynamicResource App.Brush.SurfaceCard}"
                        BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Данные роли" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource App.Brush.Foreground}" Margin="0,0,0,10"/>

                        <TextBlock Text="Название *" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="NameBox" Style="{StaticResource App.FieldTextBox}" MaxLength="100" Margin="0,0,0,10"/>

                        <TextBlock Text="Описание" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="DescriptionBox" Style="{StaticResource App.FieldTextBox}"
                                 MinHeight="48" MaxLength="255" AcceptsReturn="True" TextWrapping="Wrap" Margin="0,0,0,10"/>

                        <StackPanel x:Name="ScopePanel" Margin="0,0,0,10">
                            <TextBlock Text="Область действия *" Style="{StaticResource FieldLabel}"/>
                            <RadioButton x:Name="ScopeCompanyRadio" Content="Вся компания"
                                         GroupName="RoleScope" Margin="0,4,0,4"
                                         Foreground="{DynamicResource App.Brush.Foreground}"
                                         Checked="ScopeRadio_Changed"/>
                            <RadioButton x:Name="ScopeWorkshopRadio" Content="Конкретный салон (мастерская)"
                                         GroupName="RoleScope" Margin="0,0,0,8"
                                         Foreground="{DynamicResource App.Brush.Foreground}"
                                         Checked="ScopeRadio_Changed"/>
                            <ComboBox x:Name="WorkshopCombo" MinHeight="36"
                                      DisplayMemberPath="Name" SelectedValuePath="RowId"/>
                        </StackPanel>

                        <CheckBox x:Name="IsActiveCheck" Content="Роль активна" Margin="0,4,0,0"
                                  Foreground="{DynamicResource App.Brush.Foreground}"/>
                    </StackPanel>
                </Border>

                <Border CornerRadius="12" Padding="14"
                        Background="{DynamicResource App.Brush.SurfaceCard}"
                        BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Разрешения" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource App.Brush.Foreground}" Margin="0,0,0,8"/>
                        <TextBlock Text="Назначенные:" Style="{StaticResource FieldLabel}"/>
                        <Border MinHeight="48" Padding="8" CornerRadius="8" Margin="0,0,0,10"
                                Background="{DynamicResource App.Brush.Surface2}"
                                BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">
                            <WrapPanel x:Name="PermissionChipsPanel" Orientation="Horizontal"/>
                        </Border>
                        <TextBlock Text="Поиск и добавление:" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="PermissionSearchBox" Style="{StaticResource App.FieldTextBox}"
                                 Margin="0,0,0,4" TextChanged="PermissionSearchBox_TextChanged"/>
                        <TextBlock x:Name="PermissionSearchHint" FontSize="11" Margin="0,0,0,6"
                                   Foreground="{DynamicResource App.Brush.Muted}"
                                   Text="Поиск по названию, коду, группе или описанию"/>
                        <TextBlock x:Name="PermissionSearchStatus" FontSize="11" Margin="0,0,0,6"
                                   Foreground="{DynamicResource App.Brush.SecondaryText}"/>
                        <ListBox x:Name="PermissionPickerList" MaxHeight="180" MinHeight="96"
                                 BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1"
                                 Background="{DynamicResource App.Brush.FieldInputBg}"
                                 MouseDoubleClick="PermissionPickerList_MouseDoubleClick">
                            <ListBox.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12"
                                                       Foreground="{DynamicResource App.Brush.Accent}"
                                                       Margin="4,8,4,4"/>
                                        </DataTemplate>
                                    </GroupStyle.HeaderTemplate>
                                </GroupStyle>
                            </ListBox.GroupStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="4,2">
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource App.Brush.Foreground}"/>
                                        <TextBlock Text="{Binding Subtitle}" FontSize="11"
                                                   Foreground="{DynamicResource App.Brush.Muted}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <TextBlock Text="Двойной щелчок — добавить разрешение." FontSize="11"
                                   Foreground="{DynamicResource App.Brush.Muted}" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Отмена" Style="{StaticResource App.Button.Outline}"
                    Height="42" MinWidth="110" Margin="0,0,10,0" Click="Cancel_Click"/>
            <Button x:Name="DeleteButton" Content="Удалить" Style="{StaticResource App.Button.Outline}"
                    Height="42" MinWidth="110" Margin="0,0,10,0" Click="Delete_Click" Visibility="Collapsed"/>
            <Button x:Name="SaveButton" Content="Сохранить" Style="{StaticResource App.Button.Primary}"
                    Height="42" MinWidth="130" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
