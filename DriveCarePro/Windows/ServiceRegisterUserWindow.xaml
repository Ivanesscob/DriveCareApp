<Window x:Class="DriveCarePro.Windows.ServiceRegisterUserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация клиента" SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" MinWidth="420">

    <Border Padding="24,20" Background="{DynamicResource App.Brush.SurfaceCard}">
        <StackPanel HorizontalAlignment="Center" MinWidth="360" MaxWidth="400">
            <TextBlock Text="Новая учётная запись клиента" FontSize="16" FontWeight="SemiBold"
                       HorizontalAlignment="Center" Margin="0,0,0,12"/>
            <TextBlock Text="Логин" FontSize="12" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,0,0,4"/>
            <TextBox x:Name="LoginBox" MinHeight="34" Margin="0,0,0,10"/>
            <TextBlock Text="Email" FontSize="12" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,0,0,4"/>
            <TextBox x:Name="EmailBox" MinHeight="34" Margin="0,0,0,10"/>
            <TextBlock Text="Телефон" FontSize="12" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,0,0,4"/>
            <TextBox x:Name="PhoneBox" MinHeight="34" Margin="0,0,0,10"/>
            <TextBlock Text="Пароль" FontSize="12" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,0,0,4"/>
            <PasswordBox x:Name="PasswordBox" MinHeight="34" Margin="0,0,0,16"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Отмена" Style="{StaticResource App.Button.Outline}" MinWidth="110" Height="36" Margin="0,0,10,0" Click="Cancel_Click"/>
                <Button Content="Зарегистрировать" Style="{StaticResource App.Button.Primary}" MinWidth="150" Height="36" Click="Save_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
