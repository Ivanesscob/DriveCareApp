<Window x:Class="DriveCarePro.Windows.WorkshopPaintServiceEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Услуга покраски"
        Width="500" Height="460" MinWidth="460" MinHeight="400"
        MaxHeight="700"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
        SizeToContent="Manual"
        Background="{DynamicResource App.Brush.Panel}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="20,20,20,8">
            <StackPanel>
                <TextBlock Text="Тип работы" FontSize="12" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,0,0,4"/>
                <ComboBox x:Name="KindCombo" MinHeight="40" HorizontalContentAlignment="Stretch"
                          MaxDropDownHeight="280"/>

                <TextBlock Text="Название" FontSize="12" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,12,0,4"/>
                <TextBox x:Name="NameBox" Style="{StaticResource App.FieldTextBox}" MinHeight="40"
                         TextWrapping="Wrap"/>

                <TextBlock Text="Описание" FontSize="12" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,12,0,4"/>
                <TextBox x:Name="DescriptionBox" Style="{StaticResource App.FieldTextBox}"
                         MinHeight="72" MaxHeight="140" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" AcceptsReturn="True"/>

                <TextBlock Text="Цена от, ₽" FontSize="12" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,12,0,4"/>
                <TextBox x:Name="PriceBox" Style="{StaticResource App.FieldTextBox}" MinHeight="40"/>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1" Padding="20,12,20,16"
                BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена" Style="{StaticResource App.Button.Outline}" MinWidth="96" Height="38"
                        Margin="0,0,10,0" IsCancel="True" Click="Cancel_Click"/>
                <Button Content="Добавить" Style="{StaticResource App.Button.Primary}" MinWidth="110" Height="38"
                        IsDefault="True" Click="Save_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
