<Window x:Class="DriveCarePro.Windows.PickWorkshopServiceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выбор услуги"
        Width="640" Height="480" MinWidth="520" MinHeight="360"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource App.Brush.Panel}"
        ResizeMode="CanResizeWithGrip">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Каталог услуг мастерской"
                   FontSize="16" FontWeight="SemiBold"
                   Foreground="{DynamicResource App.Brush.Foreground}"/>

        <TextBox x:Name="SearchBox" Grid.Row="1" Margin="0,12,0,10"
                 Style="{StaticResource App.FieldTextBox}" Height="36"
                 ToolTip="Поиск по названию или описанию"/>

        <DataGrid x:Name="ItemsGrid" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" HeadersVisibility="Column"
                  AlternatingRowBackground="{DynamicResource App.Brush.Surface2}"
                  Foreground="{DynamicResource App.Brush.Foreground}" RowHeight="36"
                  Background="{DynamicResource App.Brush.SurfaceCard}"
                  BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1"
                  MouseDoubleClick="ItemsGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="2*" MinWidth="180"/>
                <DataGridTextColumn Header="Ед." Binding="{Binding UnitName}" Width="60"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding PriceDisplay}" Width="90"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Отмена" Style="{StaticResource App.Button.Outline}" MinWidth="110" Height="40" Margin="0,0,10,0"
                    Click="Cancel_Click"/>
            <Button Content="Добавить" Style="{StaticResource App.Button.Primary}" MinWidth="120" Height="40"
                    Click="Confirm_Click"/>
        </StackPanel>
    </Grid>
</Window>
