    <GradientStop Color="#FF0A0A12" Offset="0"/>
    <GradientStop Color="#FF12101C" Offset="0.5"/>
    <GradientStop Color="#FF0F0F1A" Offset="1"/>
  </LinearGradientBrush>

  <LinearGradientBrush x:Key="App.Brush.LoginShellBackground" StartPoint="0,0" EndPoint="1,1">
    <GradientStop Color="#FF0F0F1A" Offset="0"/>
    <GradientStop Color="#FF151528" Offset="0.45"/>
    <GradientStop Color="#FF1A1A32" Offset="1"/>
  </LinearGradientBrush>

