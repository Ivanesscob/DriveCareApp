<Page x:Class="DriveCare.Pages.LoginPages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Вход"
      Background="Transparent"
      PreviewKeyDown="Page_PreviewKeyDown">

    <Page.Resources>
        <SolidColorBrush x:Key="Brush.Surface" Color="{DynamicResource App.Color.LoginSurface}"/>
        <SolidColorBrush x:Key="Brush.FieldBg" Color="{DynamicResource App.Color.LoginFieldBg}"/>
        <SolidColorBrush x:Key="Brush.Border" Color="{DynamicResource App.Color.LoginBorder}"/>
        <SolidColorBrush x:Key="Brush.TextMuted" Color="{DynamicResource App.Color.Muted}"/>
        <SolidColorBrush x:Key="Brush.Accent" Color="{DynamicResource App.Color.Accent}"/>
        <SolidColorBrush x:Key="Brush.AccentHover" Color="{DynamicResource App.Color.AccentHover}"/>
        <SolidColorBrush x:Key="Brush.AccentSoft" Color="{DynamicResource App.Color.AccentSoft}"/>

        <Style x:Key="FieldBorder" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{StaticResource Brush.FieldBg}"/>
            <Setter Property="Padding" Value="2"/>
        </Style>

        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Foreground" Value="{DynamicResource App.Brush.LoginText}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource App.Brush.LoginText}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="DarkPasswordBox" TargetType="PasswordBox">
            <Setter Property="Foreground" Value="{DynamicResource App.Brush.LoginText}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource App.Brush.LoginText}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Page.Resources>

    <Grid Background="{DynamicResource App.Brush.LoginShellBackground}">

        <Ellipse Width="420" Height="420" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-120,-120,0"
                 IsHitTestVisible="False" Opacity="0.22">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="{DynamicResource App.Color.LoginGlowA}" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>
        <Ellipse Width="320" Height="320" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-80,0,0,-80"
                 IsHitTestVisible="False" Opacity="0.15">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="{DynamicResource App.Color.LoginGlowB}" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="24" VerticalAlignment="Center">
                <Border MaxWidth="440" HorizontalAlignment="Center" Padding="40,36" CornerRadius="20"
                        Background="{StaticResource Brush.Surface}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="36" ShadowDepth="0" Opacity="0.5" Color="#000000"/>
                    </Border.Effect>

                    <StackPanel>
                        <StackPanel HorizontalAlignment="Center" Margin="0,0,0,8">
                            <Border Width="56" Height="56" CornerRadius="16" Background="{StaticResource Brush.AccentSoft}"
                                    BorderBrush="{DynamicResource App.Brush.AccentDim}" BorderThickness="1" HorizontalAlignment="Center" Margin="0,0,0,16"
                                    ClipToBounds="True" Padding="6">
                                <Image Source="/DriveCareCore;component/Data/Pics/AppIcon.ico"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Добро пожаловать" FontSize="26" FontWeight="SemiBold"
                                       Foreground="{DynamicResource App.Brush.Foreground}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Войдите в DriveCare" FontSize="15" Foreground="{StaticResource Brush.TextMuted}"
                                       HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>

                        <TextBlock Text="Логин" Foreground="{StaticResource Brush.TextMuted}" FontSize="12" Margin="0,28,0,6"/>
                        <Border Style="{StaticResource FieldBorder}" Margin="0,0,0,16">
                            <TextBox x:Name="UsernameInput" Style="{StaticResource DarkTextBox}"
                                     Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>
                        </Border>

                        <TextBlock Text="Пароль" Foreground="{StaticResource Brush.TextMuted}" FontSize="12" Margin="0,0,0,6"/>
                        <Border Style="{StaticResource FieldBorder}" Margin="0,0,0,8">
                            <PasswordBox x:Name="PasswordInput"
                                         Style="{StaticResource DarkPasswordBox}"
                                         KeyDown="PasswordInput_KeyDown"/>
                        </Border>

                        <TextBlock Text="Забыли пароль? Свяжитесь с администратором."
                                   Foreground="{StaticResource Brush.TextMuted}" FontSize="12"
                                   Margin="0,0,0,24" TextWrapping="Wrap" HorizontalAlignment="Right"/>

                        <Button Content="Войти"
                                Command="{Binding LoginCommand}"
                                IsDefault="True"
                                Height="50" FontSize="16" FontWeight="SemiBold"
                                Foreground="{DynamicResource App.Brush.LoginText}"
                                Cursor="Hand" BorderThickness="0" Margin="0,0,0,12">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" CornerRadius="12" Background="{StaticResource Brush.Accent}" Padding="16,0">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="{StaticResource Brush.AccentHover}"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="bd" Property="Opacity" Value="0.45"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Content="Регистрация"
                                Command="{Binding RegisterCommand}"
                                Height="48" FontSize="15" FontWeight="SemiBold"
                                Foreground="{StaticResource Brush.Accent}"
                                Cursor="Hand" BorderThickness="1"
                                BorderBrush="{DynamicResource App.Brush.AccentDim}"
                                Background="Transparent">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" CornerRadius="12" Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                            Padding="16,0">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="{StaticResource Brush.AccentSoft}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <TextBlock Text="Нажимая «Войти», вы соглашаетесь с правилами использования приложения."
                                   Foreground="{DynamicResource App.Brush.Muted}" FontSize="11" Margin="0,20,0,0"
                                   TextWrapping="Wrap" TextAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
