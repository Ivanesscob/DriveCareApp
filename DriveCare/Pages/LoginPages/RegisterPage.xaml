<Page x:Class="DriveCare.Pages.LoginPages.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
      Title="Регистрация"
      Background="Transparent">

    <Page.Resources>
        <SolidColorBrush x:Key="Brush.Surface" Color="{DynamicResource App.Color.LoginSurface}"/>
        <SolidColorBrush x:Key="Brush.FieldBg" Color="{DynamicResource App.Color.LoginFieldBg}"/>
        <SolidColorBrush x:Key="Brush.Border" Color="{DynamicResource App.Color.LoginBorder}"/>
        <SolidColorBrush x:Key="Brush.TextMuted" Color="{DynamicResource App.Color.Muted}"/>
        <SolidColorBrush x:Key="Brush.Accent" Color="{DynamicResource App.Color.Accent}"/>
        <SolidColorBrush x:Key="Brush.AccentHover" Color="{DynamicResource App.Color.AccentHover}"/>

        <Style x:Key="FieldBorder" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{StaticResource Brush.FieldBg}"/>
            <Setter Property="Padding" Value="2"/>
        </Style>

        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Foreground" Value="{DynamicResource App.Brush.LoginText}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource App.Brush.LoginText}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="DarkPasswordBox" TargetType="PasswordBox">
            <Setter Property="Foreground" Value="{DynamicResource App.Brush.LoginText}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource App.Brush.LoginText}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="DarkCalendarStyle" TargetType="Calendar">
            <Setter Property="Background" Value="{DynamicResource App.Brush.LoginSurface}"/>
            <Setter Property="Foreground" Value="{DynamicResource App.Brush.LoginText}"/>
        </Style>

        <Style x:Key="DarkDatePicker" TargetType="DatePicker">
            <Setter Property="Foreground" Value="{DynamicResource App.Brush.LoginText}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="4,4,4,4"/>
            <Setter Property="Background" Value="{DynamicResource App.Brush.LoginFieldBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CalendarStyle" Value="{StaticResource DarkCalendarStyle}"/>
            <Setter Property="SelectedDateFormat" Value="Long"/>
        </Style>
    </Page.Resources>

    <Grid Background="{DynamicResource App.Brush.LoginShellBackground}">

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="24" VerticalAlignment="Center">
                <Border MaxWidth="480" HorizontalAlignment="Center" Padding="36,32" CornerRadius="20"
                        Background="{StaticResource Brush.Surface}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="32" ShadowDepth="0" Opacity="0.45" Color="#000000"/>
                    </Border.Effect>

                    <StackPanel>
                        <Button Content="←  Назад ко входу"
                                Command="{Binding BackCommand}"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,20"
                                Padding="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="{StaticResource Brush.Accent}"
                                FontSize="14"
                                Cursor="Hand"
                                Focusable="False"/>

                        <TextBlock Text="Создать аккаунт" FontSize="26" FontWeight="SemiBold"
                                   Foreground="{DynamicResource App.Brush.Foreground}"/>
                        <TextBlock Text="Заполните данные и подтвердите почту кодом из письма."
                                   FontSize="14" Foreground="{StaticResource Brush.TextMuted}"
                                   Margin="0,6,0,20" TextWrapping="Wrap"/>

                        <StackPanel Visibility="{Binding FormStepVisibility}">
                            <TextBlock Text="Логин" Foreground="{StaticResource Brush.TextMuted}" FontSize="12" Margin="0,0,0,6"/>
                            <Border Style="{StaticResource FieldBorder}" Margin="0,0,0,14">
                                <TextBox Style="{StaticResource DarkTextBox}"
                                         Text="{Binding UserLogin, UpdateSourceTrigger=PropertyChanged}"/>
                            </Border>

                            <TextBlock Text="Email" Foreground="{StaticResource Brush.TextMuted}" FontSize="12" Margin="0,0,0,6"/>
                            <Border Style="{StaticResource FieldBorder}" Margin="0,0,0,6">
                                <TextBox Style="{StaticResource DarkTextBox}"
                                         Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
                            </Border>
                            <TextBlock Text="Формат: имя@домен.ru. Латиница, без пробелов."
                                       Foreground="{DynamicResource App.Brush.Muted}" FontSize="11" Margin="0,0,0,14" TextWrapping="Wrap"/>

                            <TextBlock Text="Телефон" Foreground="{StaticResource Brush.TextMuted}" FontSize="12" Margin="0,0,0,6"/>
                            <Border Style="{StaticResource FieldBorder}" Margin="0,0,0,6">
                                <TextBox Style="{StaticResource DarkTextBox}"
                                         Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"/>
                            </Border>
                            <TextBlock Text="РФ: +7, 8 или 10 цифр с 9… Другие страны: 10–15 цифр (+ допускается)."
                                       Foreground="{DynamicResource App.Brush.Muted}" FontSize="11" Margin="0,0,0,14" TextWrapping="Wrap"/>

                            <TextBlock Text="Дата рождения (не моложе 18 лет)" Foreground="{StaticResource Brush.TextMuted}" FontSize="12" Margin="0,0,0,6"/>
                            <Border Style="{StaticResource FieldBorder}" Margin="0,0,0,14" Padding="4,2,4,2">
                                <DatePicker x:Name="BirthDatePicker"
                                            Style="{StaticResource DarkDatePicker}"
                                            SelectedDate="{Binding BirthDate}">
                                    <DatePicker.Resources>
                                        <Style TargetType="{x:Type primitives:DatePickerTextBox}">
                                            <Setter Property="Foreground" Value="{DynamicResource App.Brush.LoginText}"/>
                                            <Setter Property="CaretBrush" Value="{DynamicResource App.Brush.LoginText}"/>
                                            <Setter Property="Background" Value="{DynamicResource App.Brush.LoginFieldBg}"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Padding" Value="4,2"/>
                                            <Setter Property="FontSize" Value="15"/>
                                        </Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="{DynamicResource App.Brush.AccentSoft}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource App.Brush.LoginText}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource App.Brush.AccentDim}"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Setter Property="Padding" Value="8,4"/>
                                        </Style>
                                    </DatePicker.Resources>
                                </DatePicker>
                            </Border>

                            <TextBlock Text="Пароль" Foreground="{StaticResource Brush.TextMuted}" FontSize="12" Margin="0,0,0,6"/>
                            <Border Style="{StaticResource FieldBorder}" Margin="0,0,0,14">
                                <PasswordBox x:Name="PasswordInput"
                                             Style="{StaticResource DarkPasswordBox}"/>
                            </Border>

                            <TextBlock Text="Пароль ещё раз" Foreground="{StaticResource Brush.TextMuted}" FontSize="12" Margin="0,0,0,6"/>
                            <Border Style="{StaticResource FieldBorder}" Margin="0,0,0,20">
                                <PasswordBox x:Name="PasswordConfirmInput"
                                             Style="{StaticResource DarkPasswordBox}"/>
                            </Border>

                            <Button Content="Готово — отправить код на почту"
                                    Command="{Binding SendCodeCommand}"
                                    Height="50" FontSize="15" FontWeight="SemiBold"
                                    Foreground="{DynamicResource App.Brush.LoginText}" Cursor="Hand" BorderThickness="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" CornerRadius="12" Background="{StaticResource Brush.Accent}" Padding="16,0">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="{StaticResource Brush.AccentHover}"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="bd" Property="Opacity" Value="0.45"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>

                        <StackPanel Margin="0,16,0,0" Visibility="{Binding VerificationStepVisibility}">
                            <Border Background="{DynamicResource App.Brush.LoginFieldBg}" CornerRadius="10" Padding="16" Margin="0,0,0,16"
                                    BorderBrush="{DynamicResource App.Brush.AccentDim}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Проверка почты" FontSize="18" FontWeight="SemiBold"
                                               Foreground="{DynamicResource App.Brush.Foreground}" Margin="0,0,0,8"/>
                                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource Brush.TextMuted}" FontSize="13"
                                               Text="На указанный email отправлено письмо с 5-значным кодом. Введите его ниже."/>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Код из письма" Foreground="{StaticResource Brush.TextMuted}" FontSize="12" Margin="0,0,0,6"/>
                            <Border Style="{StaticResource FieldBorder}" Margin="0,0,0,20">
                                <TextBox Style="{StaticResource DarkTextBox}"
                                         MaxLength="5"
                                         Text="{Binding VerificationCode, UpdateSourceTrigger=PropertyChanged}"/>
                            </Border>

                            <Button Content="Зарегистрироваться"
                                    Command="{Binding CompleteRegistrationCommand}"
                                    Height="50" FontSize="16" FontWeight="SemiBold"
                                    Foreground="{DynamicResource App.Brush.LoginText}" Cursor="Hand" BorderThickness="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd2" CornerRadius="12" Background="{StaticResource Brush.Accent}" Padding="16,0">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd2" Property="Background" Value="{StaticResource Brush.AccentHover}"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="bd2" Property="Opacity" Value="0.45"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
