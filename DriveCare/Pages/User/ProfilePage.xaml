<Page x:Class="DriveCare.Pages.User.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
      Title="Профиль"
      Background="{DynamicResource App.Brush.PageBackground}">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <LinearGradientBrush x:Key="Profile.HeroGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF2563EB" Offset="0"/>
            <GradientStop Color="#FF3B82F6" Offset="0.5"/>
            <GradientStop Color="#FF60A5FA" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="Profile.NavButton" TargetType="Button">
            <Setter Property="Height" Value="48"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="ActiveBar" Width="3" HorizontalAlignment="Left"
                                    CornerRadius="2" Background="{DynamicResource App.Brush.Accent}"
                                    Visibility="Collapsed"/>
                            <Border x:Name="bd" Margin="4,0,0,0" CornerRadius="12" Padding="10,0"
                                    Background="Transparent">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource App.Brush.MenuHover}"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Active">
                                <Setter TargetName="ActiveBar" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource App.Brush.MenuBgActive}"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Profile.InfoCard" TargetType="Border">
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Background" Value="{DynamicResource App.Brush.SurfaceCard}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource App.Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,12,12"/>
        </Style>

        <Style x:Key="Profile.SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource App.Brush.Foreground}"/>
        </Style>
        <Style x:Key="Profile.FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource App.Brush.Muted}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="Profile.FieldBox" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="22,18,22,28" MaxWidth="1100">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Hero -->
            <Border Grid.Row="0" CornerRadius="20" Margin="0,0,0,18" ClipToBounds="True">
                <Border.Background>
                    <StaticResource ResourceKey="Profile.HeroGradient"/>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.2" Color="#40000000"/>
                </Border.Effect>
                <Grid Margin="28,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Width="80" Height="80" CornerRadius="40"
                            Background="#30FFFFFF" BorderBrush="#50FFFFFF" BorderThickness="2">
                        <TextBlock x:Name="HeroInitials" Text="DC"
                                   FontSize="28" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="20,4,16,0" VerticalAlignment="Center">
                        <TextBlock x:Name="HeroLogin" Text="Профиль"
                                   FontSize="26" FontWeight="Bold" Foreground="White"/>
                        <TextBlock x:Name="HeroEmail" FontSize="14" Foreground="#E8F4FF" Margin="0,6,0,0"
                                   TextWrapping="Wrap"/>
                        <TextBlock x:Name="HeroMemberSince" FontSize="12" Foreground="#C7E2FF" Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Orientation="Horizontal">
                        <Border Background="#25FFFFFF" CornerRadius="12" Padding="14,10" Margin="0,0,10,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock x:Name="HeroCarsCount" Text="0" FontSize="22" FontWeight="Bold"
                                           Foreground="White" HorizontalAlignment="Center"/>
                                <TextBlock Text="авто в гараже" FontSize="11" Foreground="#D0E8FF"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Button Content="← Главная" Height="40" MinWidth="110" Cursor="Hand"
                                Click="BackToHome_Click" VerticalAlignment="Center">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="hb" CornerRadius="10" Padding="14,0"
                                            Background="#30FFFFFF" BorderBrush="#60FFFFFF" BorderThickness="1">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                          TextBlock.Foreground="White" TextBlock.FontWeight="SemiBold"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="hb" Property="Background" Value="#45FFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Nav + content -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" CornerRadius="16" Padding="10,12"
                        Background="{DynamicResource App.Brush.Surface}"
                        BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Разделы" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource App.Brush.Muted}" Margin="12,4,0,10"/>

                        <Button x:Name="BtnMainInfo" Tag="Active" Style="{StaticResource Profile.NavButton}"
                                Click="BtnMainInfo_Click">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconModern Kind="User" Width="18" Height="18"
                                    Foreground="{DynamicResource App.Brush.Accent}" VerticalAlignment="Center"/>
                                <TextBlock Text="Основное" Margin="10,0,0,0" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource App.Brush.Foreground}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnCars" Style="{StaticResource Profile.NavButton}" Click="BtnCars_Click">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconModern Kind="TransitCar" Width="18" Height="18"
                                    Foreground="{DynamicResource App.Brush.Accent}" VerticalAlignment="Center"/>
                                <TextBlock Text="Мои машины" Margin="10,0,0,0" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource App.Brush.Foreground}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnSettings" Style="{StaticResource Profile.NavButton}" Click="BtnSettings_Click">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconModern Kind="Settings" Width="18" Height="18"
                                    Foreground="{DynamicResource App.Brush.Accent}" VerticalAlignment="Center"/>
                                <TextBlock Text="Настройки" Margin="10,0,0,0" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource App.Brush.Foreground}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" CornerRadius="16" Padding="22,20"
                        Background="{DynamicResource App.Brush.Surface}"
                        BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1"
                        MinHeight="420">
                    <Grid>
                        <!-- Профиль (редактирование) -->
                        <StackPanel x:Name="TabMainInfo" Visibility="Visible">
                            <TextBlock Text="Личные данные" Style="{StaticResource Profile.SectionTitle}"/>
                            <TextBlock Text="Все поля можно изменить. При смене email придёт код, как при регистрации."
                                       FontSize="13" Foreground="{DynamicResource App.Brush.Muted}"
                                       TextWrapping="Wrap" Margin="0,6,0,16"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Логин *" Style="{StaticResource Profile.FieldLabel}"/>
                                    <TextBox x:Name="EditLoginBox" Style="{StaticResource Profile.FieldBox}"/>
                                    <TextBlock Text="Телефон *" Style="{StaticResource Profile.FieldLabel}"/>
                                    <TextBox x:Name="EditPhoneBox" Style="{StaticResource Profile.FieldBox}"/>
                                    <TextBlock Text="Дата рождения *" Style="{StaticResource Profile.FieldLabel}"/>
                                    <DatePicker x:Name="EditBirthDatePicker" Height="38" Margin="0,0,0,12"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Email *" Style="{StaticResource Profile.FieldLabel}"/>
                                    <TextBox x:Name="EditEmailBox" Style="{StaticResource Profile.FieldBox}"/>
                                    <Button x:Name="BtnSendEmailCode" Content="Отправить код на почту"
                                            Height="36" Margin="0,0,0,12" Click="BtnSendEmailCode_Click"/>
                                    <Border x:Name="EmailVerifyPanel" CornerRadius="12" Padding="12" Margin="0,0,0,12"
                                            Background="{DynamicResource App.Brush.Surface2}"
                                            BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1"
                                            Visibility="Collapsed">
                                        <StackPanel>
                                            <TextBlock Text="Код из письма (5 цифр)" Style="{StaticResource Profile.FieldLabel}"/>
                                            <TextBox x:Name="EditEmailCodeBox" Style="{StaticResource Profile.FieldBox}" Margin="0,0,0,0"/>
                                            <TextBlock x:Name="EmailVerifyHint" FontSize="12"
                                                       Foreground="{DynamicResource App.Brush.Muted}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                    <TextBlock x:Name="RegisteredAtText" FontSize="12"
                                               Foreground="{DynamicResource App.Brush.Muted}" Margin="0,0,0,12"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="О себе" Style="{StaticResource Profile.FieldLabel}"/>
                            <TextBox x:Name="EditDescriptionBox" Height="64" Padding="10,8" TextWrapping="Wrap"
                                     AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,16"/>

                            <TextBlock Text="Смена пароля" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource App.Brush.Foreground}" Margin="0,0,0,8"/>
                            <TextBlock Text="Оставьте пустым, если пароль менять не нужно."
                                       FontSize="12" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Новый пароль" Style="{StaticResource Profile.FieldLabel}"/>
                                    <PasswordBox x:Name="EditNewPasswordBox" Height="38" Padding="10,0" Margin="0,0,0,12"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Повтор пароля" Style="{StaticResource Profile.FieldLabel}"/>
                                    <PasswordBox x:Name="EditConfirmPasswordBox" Height="38" Padding="10,0" Margin="0,0,0,12"/>
                                </StackPanel>
                            </Grid>

                            <Button x:Name="BtnSaveProfile" Content="Сохранить профиль" Height="44" MinWidth="200"
                                    HorizontalAlignment="Left" Margin="0,8,0,0" Click="BtnSaveProfile_Click"
                                    Foreground="White" Background="{DynamicResource App.Brush.Accent}"/>
                        </StackPanel>

                        <!-- Машины -->
                        <StackPanel x:Name="TabCars" Visibility="Collapsed">
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Мои машины" Style="{StaticResource Profile.SectionTitle}"/>
                                    <TextBlock Text="Автомобили в вашем гараже"
                                               FontSize="13" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,6,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="1" x:Name="BtnAddCar" Content="+ Добавить авто"
                                        Height="38" MinWidth="150" Cursor="Hand"
                                        Click="BtnAddCar_Click" VerticalAlignment="Center"
                                        Foreground="White" Background="{DynamicResource App.Brush.Accent}"/>
                            </Grid>

                            <Border x:Name="CarsEmptyPanel" CornerRadius="14" Padding="32"
                                    Background="{DynamicResource App.Brush.Surface2}"
                                    BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1"
                                    Visibility="Collapsed">
                                <StackPanel HorizontalAlignment="Center">
                                    <iconPacks:PackIconModern Kind="TransitCar" Width="48" Height="48"
                                        Foreground="{DynamicResource App.Brush.Muted}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="В гараже пока нет машин" FontSize="16" FontWeight="SemiBold"
                                               Foreground="{DynamicResource App.Brush.Foreground}"
                                               HorizontalAlignment="Center" Margin="0,14,0,6"/>
                                    <Button Content="Добавить автомобиль" Height="40" MinWidth="200" Margin="0,12,0,0"
                                            Click="BtnAddCar_Click" Foreground="White"
                                            Background="{DynamicResource App.Brush.Accent}"/>
                                </StackPanel>
                            </Border>

                            <ItemsControl x:Name="CarsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10" CornerRadius="14" Padding="14"
                                                Background="{DynamicResource App.Brush.SurfaceCard}"
                                                BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding DisplayName}" FontSize="16" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource App.Brush.Foreground}"/>
                                                    <TextBlock FontSize="12" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,6,0,0">
                                                        <Run Text="Гос. номер: "/><Run Text="{Binding PlateNumber, TargetNullValue=—}"/>
                                                        <Run Text="  ·  VIN: "/><Run Text="{Binding Vin, TargetNullValue=—}"/>
                                                    </TextBlock>
                                                    <TextBlock FontSize="12" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,2,0,0">
                                                        <Run Text="{Binding CarTypeName}"/><Run Text=" · "/><Run Text="{Binding FuelTypeName}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Button Content="Изменить" Tag="{Binding UserCarId}" Height="32" MinWidth="90"
                                                            Margin="0,0,8,0" Click="EditGarageCar_Click"/>
                                                    <Button Content="Удалить" Tag="{Binding UserCarId}" Height="32" MinWidth="80"
                                                            Click="DeleteGarageCar_Click"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Настройки -->
                        <StackPanel x:Name="TabSettings" Visibility="Collapsed">
                            <TextBlock Text="Настройки" Style="{StaticResource Profile.SectionTitle}"/>
                            <TextBlock Text="Тема и выход из аккаунта"
                                       FontSize="13" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,6,0,20"/>

                            <TextBlock Text="Тема оформления" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource App.Brush.Foreground}" Margin="0,0,0,10"/>
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border x:Name="ThemeDarkCard" Grid.Column="0" CornerRadius="14" Padding="16" Cursor="Hand"
                                        MouseLeftButtonUp="ThemeDarkCard_Click"
                                        Background="#FF1E293B" BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="2">
                                    <StackPanel>
                                        <iconPacks:PackIconModern Kind="Moon" Width="28" Height="28" Foreground="#94A3B8"/>
                                        <TextBlock Text="Тёмная" FontSize="16" FontWeight="SemiBold" Foreground="White" Margin="0,10,0,4"/>
                                        <TextBlock Text="Комфортно вечером" FontSize="12" Foreground="#94A3B8"/>
                                        <Border x:Name="ThemeDarkCheck" Margin="0,12,0,0" HorizontalAlignment="Left"
                                                Background="{DynamicResource App.Brush.Accent}" CornerRadius="8" Padding="8,4"
                                                Visibility="Collapsed">
                                            <TextBlock Text="Выбрано" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <Border x:Name="ThemeLightCard" Grid.Column="2" CornerRadius="14" Padding="16" Cursor="Hand"
                                        MouseLeftButtonUp="ThemeLightCard_Click"
                                        Background="#FFF8FAFC" BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="2">
                                    <StackPanel>
                                        <iconPacks:PackIconModern Kind="WeatherSun" Width="28" Height="28" Foreground="#F59E0B"/>
                                        <TextBlock Text="Светлая" FontSize="16" FontWeight="SemiBold" Foreground="#0F172A" Margin="0,10,0,4"/>
                                        <TextBlock Text="Ярко днём" FontSize="12" Foreground="#64748B"/>
                                        <Border x:Name="ThemeLightCheck" Margin="0,12,0,0" HorizontalAlignment="Left"
                                                Background="{DynamicResource App.Brush.Accent}" CornerRadius="8" Padding="8,4"
                                                Visibility="Collapsed">
                                            <TextBlock Text="Выбрано" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <RadioButton x:Name="RbThemeDark" GroupName="UiThemeChoice" Visibility="Collapsed"
                                         Checked="RbThemeDark_Checked"/>
                            <RadioButton x:Name="RbThemeLight" GroupName="UiThemeChoice" Visibility="Collapsed"
                                         Checked="RbThemeLight_Checked"/>

                            <Border CornerRadius="14" Padding="20"
                                    Background="{DynamicResource App.Brush.Surface2}"
                                    BorderBrush="{DynamicResource App.Brush.DangerBorder}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Выйти из аккаунта" FontSize="16" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource App.Brush.Foreground}"/>
                                        <TextBlock Text="Вернуться на экран входа. Данные на сервере сохранятся."
                                                   FontSize="13" Foreground="{DynamicResource App.Brush.Muted}"
                                                   TextWrapping="Wrap" Margin="0,6,12,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" x:Name="BtnSignOut" Content="Выйти"
                                            Height="44" MinWidth="120" Click="BtnSignOut_Click" VerticalAlignment="Center">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" CornerRadius="10" Padding="16,0"
                                                        Background="Transparent"
                                                        BorderBrush="{DynamicResource App.Brush.DangerBorder}" BorderThickness="1">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                      TextBlock.Foreground="{DynamicResource App.Brush.Foreground}"
                                                                      TextBlock.FontWeight="SemiBold"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource App.Brush.DangerHover}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
