<Page x:Class="DriveCare.Pages.User.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Профиль">

    <Page.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0A0A12" Offset="0"/>
            <GradientStop Color="#12101C" Offset="0.5"/>
            <GradientStop Color="#0F0F1A" Offset="1"/>
        </LinearGradientBrush>
    </Page.Background>

    <Page.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="46"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Foreground" Value="#D0D5E0"/>
            <Setter Property="Background" Value="#1A1A28"/>
            <Setter Property="BorderBrush" Value="#2E2E44"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                CornerRadius="12"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#7C6CF5"/>
                                <Setter TargetName="bd" Property="Background" Value="#222236"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="22">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="18"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левое меню -->
        <Border Grid.Column="0" Background="#14141F" BorderBrush="#2E2E44" BorderThickness="1" CornerRadius="16" Padding="14">
            <StackPanel>
                <TextBlock Text="Профиль" Foreground="White" FontSize="21" FontWeight="SemiBold" Margin="4,2,0,18"/>

                <Button x:Name="BtnMainInfo" Style="{StaticResource MenuButtonStyle}" Click="BtnMainInfo_Click">
                    Основная информация
                </Button>
                <Button x:Name="BtnCars" Style="{StaticResource MenuButtonStyle}" Click="BtnCars_Click">
                    Машины
                </Button>
                <Button x:Name="BtnEdit" Style="{StaticResource MenuButtonStyle}" Click="BtnEdit_Click">
                    Редактировать
                </Button>
                <Button x:Name="BtnSettings" Style="{StaticResource MenuButtonStyle}" Click="BtnSettings_Click">
                    Настройки
                </Button>

                <Separator Margin="0,6,0,12" Background="#2E2E44"/>

                <Button Style="{StaticResource MenuButtonStyle}" Click="BackToHome_Click">
                    ← Назад на главную
                </Button>
            </StackPanel>
        </Border>

        <!-- Правая область вкладок -->
        <Border Grid.Column="2" Background="#14141F" BorderBrush="#2E2E44" BorderThickness="1" CornerRadius="16" Padding="18">
            <Grid>
                <Border x:Name="TabMainInfo" Visibility="Visible">
                    <StackPanel>
                        <TextBlock Text="Основная информация" Foreground="White" FontSize="24" FontWeight="SemiBold"/>
                        <TextBlock Text="Здесь будет основная информация о пользователе."
                                   Foreground="#9AA0B0" FontSize="14" Margin="0,10,0,18"/>

                        <UniformGrid Columns="2" Margin="0,0,0,8">
                            <Border Margin="0,0,10,10" Padding="12" CornerRadius="12" Background="#1A1A28" BorderBrush="#2E2E44" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Логин" Foreground="#9AA0B0"/>
                                    <TextBlock Text="{Binding CurrentUser.Login}" Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                            <Border Margin="0,0,0,10" Padding="12" CornerRadius="12" Background="#1A1A28" BorderBrush="#2E2E44" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Email" Foreground="#9AA0B0"/>
                                    <TextBlock Text="{Binding CurrentUser.Email}" Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                            <Border Margin="0,0,10,10" Padding="12" CornerRadius="12" Background="#1A1A28" BorderBrush="#2E2E44" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Телефон" Foreground="#9AA0B0"/>
                                    <TextBlock Text="{Binding CurrentUser.Phone, TargetNullValue=—}" Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                            <Border Margin="0,0,0,10" Padding="12" CornerRadius="12" Background="#1A1A28" BorderBrush="#2E2E44" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Дата рождения" Foreground="#9AA0B0"/>
                                    <TextBlock Text="{Binding CurrentUser.BirthDate, StringFormat=dd.MM.yyyy, TargetNullValue=—}" Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <Border x:Name="TabCars" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Машины" Foreground="White" FontSize="24" FontWeight="SemiBold"/>
                        <TextBlock Text="Список машин пользователя будет здесь."
                                   Foreground="#9AA0B0" FontSize="14" Margin="0,10,0,18"/>
                    </StackPanel>
                </Border>

                <Border x:Name="TabEdit" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Редактировать" Foreground="White" FontSize="24" FontWeight="SemiBold"/>
                        <TextBlock Text="Вкладка для редактирования данных профиля."
                                   Foreground="#9AA0B0" FontSize="14" Margin="0,10,0,18"/>
                    </StackPanel>
                </Border>

                <Border x:Name="TabSettings" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Настройки" Foreground="White" FontSize="24" FontWeight="SemiBold"/>
                        <TextBlock Text="Настройки аккаунта и приложения."
                                   Foreground="#9AA0B0" FontSize="14" Margin="0,10,0,18"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>

