<Page x:Class="DriveCare.Pages.User.UserHomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Главная">

    <Page.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0A0A12" Offset="0"/>
            <GradientStop Color="#12101C" Offset="0.5"/>
            <GradientStop Color="#0F0F1A" Offset="1"/>
        </LinearGradientBrush>
    </Page.Background>

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <SolidColorBrush x:Key="Brush.Accent" Color="#7C6CF5"/>
        <SolidColorBrush x:Key="Brush.AccentDim" Color="#5548C8"/>
        <SolidColorBrush x:Key="Brush.Surface" Color="#1B1B2A"/>
        <SolidColorBrush x:Key="Brush.Muted" Color="#9AA0B0"/>

        <!-- Кнопки ‹ › -->
        <Style x:Key="HeroNavButton" TargetType="Button">
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" CornerRadius="24" Background="#35FFFFFF" BorderBrush="#55FFFFFF" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-2,0,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#55FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#28FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="QuickActionButton" TargetType="Button">
            <Setter Property="Background" Value="#14141F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2E2E44"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="92"/>
            <Setter Property="Height" Value="92"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                CornerRadius="22"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#7C6CF5"/>
                                <Setter TargetName="bd" Property="Background" Value="#1B1B2A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#252538"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ProfileIconButton" TargetType="Button">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Background" Value="#14141F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2E2E44"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                CornerRadius="22"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#7C6CF5"/>
                                <Setter TargetName="bd" Property="Background" Value="#1B1B2A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Миниатюра в ленте -->
        <DataTemplate x:Key="CarStripItemTemplate">
            <Border CornerRadius="10" Padding="8,8,8,6" MinWidth="84" MaxWidth="112"
                    Background="#18182A" SnapsToDevicePixels="True">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.4" Color="#000000"/>
                </Border.Effect>
                <StackPanel>
                    <Border Height="46" CornerRadius="8" Background="#0F0F18" ClipToBounds="True">
                        <Image Source="{Binding Photo}" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="{Binding Name}" Foreground="#D0D5E0" FontSize="10" FontWeight="Medium"
                               TextTrimming="CharacterEllipsis" TextAlignment="Center" Margin="0,6,0,0" MaxWidth="96" LineHeight="13"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <Style x:Key="CarStripListBoxItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Chrome" CornerRadius="16" Padding="0" Background="Transparent" SnapsToDevicePixels="True">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Chrome" Property="Padding" Value="2"/>
                                <Setter TargetName="Chrome" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#8B7CF8" Offset="0"/>
                                            <GradientStop Color="#5B4DC4" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="False"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Chrome" Property="Background" Value="#252538"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верх: гараж -->
        <Grid Grid.Row="0" Margin="0,20,0,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="28,0,28,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" MaxWidth="920" HorizontalAlignment="Center">
                    <TextBlock Text="Мои автомобили" FontSize="22" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock Text="Выберите машину в ленте ниже или листайте стрелками"
                               FontSize="13" Foreground="{StaticResource Brush.Muted}" Margin="0,6,0,0"
                               Visibility="{Binding ShowNavChrome, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>

                <!-- Профиль (пока заглушка, повесим навигацию позже) -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="BtnNotifications"
                            Style="{StaticResource ProfileIconButton}"
                            Margin="0,0,10,0"
                            Click="NotificationsButton_Click"
                            ToolTip="Уведомления">
                        <Grid>
                            <Image Width="20" Height="20" Stretch="Uniform"
                                   Source="pack://application:,,,/DriveCareCore;component/Data/Pics/Notification.png"/>
                        </Grid>
                    </Button>

                    <Button x:Name="BtnProfile"
                            Style="{StaticResource ProfileIconButton}"
                            Click="ProfileButton_Click"
                            ToolTip="Профиль">
                        <Grid>
                            <Image x:Name="IconProfile" Width="20" Height="20" Stretch="Uniform" Visibility="Collapsed"/>
                            <TextBlock x:Name="TxtProfileFallback"
                                       Text="П"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Button>
                </StackPanel>

                <Popup x:Name="NotificationsPopup"
                       PlacementTarget="{Binding ElementName=BtnNotifications}"
                       Placement="Bottom"
                       StaysOpen="False"
                       AllowsTransparency="True">
                    <Border Background="#1B1B2A" BorderBrush="#3D3D55" BorderThickness="1" CornerRadius="12"
                            MinWidth="330" MaxWidth="360" Padding="10" Margin="0,8,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Уведомления" Foreground="White" FontSize="15" FontWeight="SemiBold" Margin="4,2,0,8"/>

                            <Grid Grid.Row="1">
                                <TextBlock Text="Нет уведомлений"
                                           Foreground="#9AA0B0"
                                           FontSize="13"
                                           TextAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding NoNotificationsVisibility}"/>

                                <ListBox ItemsSource="{Binding NotificationItems}"
                                         Visibility="{Binding NotificationsListVisibility}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         MaxHeight="260">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Margin" Value="0,0,0,8"/>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#232338" BorderBrush="#2E2E44" BorderThickness="1" CornerRadius="8" Padding="10">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}" Foreground="White" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding Text}" Foreground="#9AA0B0" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Grid>
                    </Border>
                </Popup>
            </Grid>

            <!-- Карточка героя -->
            <Grid Grid.Row="1" MaxWidth="920" HorizontalAlignment="Center" Margin="28,12,28,0"
                  Visibility="{Binding HeroVisibility}">
                <!-- Обводка-градиент -->
                <Border CornerRadius="24" Padding="2" HorizontalAlignment="Stretch">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#5548C8" Offset="0"/>
                            <GradientStop Color="#3D2D80" Offset="0.5"/>
                            <GradientStop Color="#7C6CF5" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border CornerRadius="22" Background="#14141F"
                            MouseLeftButtonDown="HeroCar_MouseLeftButtonDown">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.55" Color="#1A1040"/>
                        </Border.Effect>
                        <Grid MinHeight="230">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.15*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Фото -->
                            <Border Grid.Column="0" Margin="14,16,10,16" CornerRadius="18" ClipToBounds="True">
                                <Border.Background>
                                    <RadialGradientBrush GradientOrigin="0.4,0.3" Center="0.4,0.35" RadiusX="0.85" RadiusY="0.85">
                                        <GradientStop Color="#2A2548" Offset="0"/>
                                        <GradientStop Color="#12101C" Offset="1"/>
                                    </RadialGradientBrush>
                                </Border.Background>
                                <Image Source="{Binding CarImage}" Stretch="Uniform" Margin="16"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <!-- Текст -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,14,22,14">
                                <TextBlock Text="{Binding PositionText}" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource Brush.Accent}" Margin="0,0,0,10"
                                           Visibility="{Binding ShowNavChrome, Converter={StaticResource BoolToVis}}"/>
                                <TextBlock Text="{Binding CarTitle}" FontSize="22" FontWeight="SemiBold"
                                           Foreground="White" TextWrapping="Wrap" LineHeight="28"/>
                                <TextBlock Text="Ваш активный автомобиль в DriveCare"
                                           FontSize="13" Foreground="{StaticResource Brush.Muted}" Margin="0,14,0,0" TextWrapping="Wrap"/>
                            </StackPanel>

                            <!-- Стрелки поверх -->
                            <Button Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource HeroNavButton}"
                                    HorizontalAlignment="Left" VerticalAlignment="Center" Margin="16,0,0,0"
                                    Command="{Binding PrevCommand}" ToolTip="Предыдущая"
                                    Visibility="{Binding ShowNavChrome, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="‹" Margin="0,-2,2,0"/>
                            </Button>
                            <Button Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource HeroNavButton}"
                                    HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,16,0"
                                    Command="{Binding NextCommand}" ToolTip="Следующая"
                                    Visibility="{Binding ShowNavChrome, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="›" Margin="2,-2,0,0"/>
                            </Button>
                        </Grid>
                    </Border>
                </Border>
            </Grid>

            <!-- Лента-селектор -->
            <StackPanel Grid.Row="2" MaxWidth="920" HorizontalAlignment="Center" Margin="28,16,28,0"
                        Visibility="{Binding HeroVisibility}">
                <WrapPanel Margin="0,0,0,12" HorizontalAlignment="Center">
                    <Button x:Name="BtnToolsStore"
                            Style="{StaticResource QuickActionButton}"
                            Click="QuickActionButton_Click"
                            Tag="ToolsStore">
                        <StackPanel Orientation="Vertical">
                            <Image x:Name="IconToolsStore"
                                   Width="40" Height="40"
                                   Stretch="Uniform"
                                   Margin="0,8,0,6"
                                   Source="pack://application:,,,/DriveCareCore;component/Data/Pics/MainMenu/Bascket.png"/>
                            <TextBlock Text="Магазин" FontSize="12" FontWeight="SemiBold" Foreground="#D0D5E0" TextAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnServiceSelect"
                            Style="{StaticResource QuickActionButton}"
                            Click="QuickActionButton_Click"
                            Tag="ServiceSelect">
                        <StackPanel Orientation="Vertical">
                            <Image x:Name="IconServiceSelect"
                                   Width="40" Height="40"
                                   Stretch="Uniform"
                                   Margin="0,8,0,6"
                                   Source="pack://application:,,,/DriveCareCore;component/Data/Pics/MainMenu/STO.png"/>
                            <TextBlock Text="СТО" FontSize="12" FontWeight="SemiBold" Foreground="#D0D5E0" TextAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnPaintCar"
                            Style="{StaticResource QuickActionButton}"
                            Click="QuickActionButton_Click"
                            Tag="PaintCar">
                        <StackPanel Orientation="Vertical">
                            <Image x:Name="IconPaintCar"
                                   Width="40" Height="40"
                                   Stretch="Uniform"
                                   Margin="0,8,0,6"
                                   Source="pack://application:,,,/DriveCareCore;component/Data/Pics/MainMenu/SprayGun.png"/>
                            <TextBlock Text="Покраска" FontSize="12" FontWeight="SemiBold" Foreground="#D0D5E0" TextAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnServiceCar"
                            Style="{StaticResource QuickActionButton}"
                            Click="QuickActionButton_Click"
                            Tag="ServiceCar">
                        <StackPanel Orientation="Vertical">
                            <Image x:Name="IconServiceCar"
                                   Width="40" Height="40"
                                   Stretch="Uniform"
                                   Margin="0,8,0,6"
                                   Source="pack://application:,,,/DriveCareCore;component/Data/Pics/MainMenu/CarRepair.png"/>
                            <TextBlock Text="Обслуживание" FontSize="12" FontWeight="SemiBold" Foreground="#D0D5E0" TextAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnBuyCar"
                            Style="{StaticResource QuickActionButton}"
                            Click="QuickActionButton_Click"
                            Tag="BuyCar">
                        <StackPanel Orientation="Vertical">
                            <Image x:Name="IconBuyCar"
                                   Width="40" Height="40"
                                   Stretch="Uniform"
                                   Margin="0,8,0,6"
                                   Source="pack://application:,,,/DriveCareCore;component/Data/Pics/MainMenu/BuyCar.png"/>
                            <TextBlock Text="Покупка" FontSize="12" FontWeight="SemiBold" Foreground="#D0D5E0" TextAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </WrapPanel>
            </StackPanel>

            <Border Grid.Row="1" Grid.RowSpan="2" MaxWidth="520" HorizontalAlignment="Center" VerticalAlignment="Center"
                    CornerRadius="20" Background="#1B1B2A" BorderBrush="#3D3D55" BorderThickness="1" Padding="32,36"
                    Margin="28,40" Visibility="{Binding EmptyStatePanelVisibility}">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.4" Color="#000"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="У вас пока нет привязанных машин" FontSize="16" Foreground="White" TextWrapping="Wrap"
                               TextAlignment="Center" Visibility="{Binding EmptyHintVisibility}"/>
                    <TextBlock Text="Добавьте автомобиль в профиле или обратитесь в сервис — здесь появятся карточки с фото и названием."
                               FontSize="13" Foreground="{StaticResource Brush.Muted}" TextWrapping="Wrap" TextAlignment="Center"
                               Margin="0,12,0,0" Visibility="{Binding EmptyHintVisibility}"/>
                    <TextBlock Text="Войдите в систему, чтобы увидеть свои автомобили."
                               FontSize="15" Foreground="White" TextWrapping="Wrap" TextAlignment="Center"
                               Visibility="{Binding AuthHintVisibility}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Низ -->
        <TextBlock Grid.Row="1" Text="DriveCare" FontSize="13" Foreground="#4A5060"
                   VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,20" Opacity="0.85"/>
    </Grid>
</Page>
