<Page x:Class="DriveCare.Pages.User.ActionPages.ToolsStorePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Магазин инструментов">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="QuickActionButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource App.Brush.Surface}"/>
            <Setter Property="Foreground" Value="{DynamicResource App.Brush.Foreground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource App.Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="92"/>
            <Setter Property="Height" Value="92"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="10,0"/>
        </Style>
    </Page.Resources>

    <Grid Background="{DynamicResource App.Brush.Panel}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,24,0,8" HorizontalAlignment="Center">
            <TextBlock Text="Магазин инструментов" Foreground="{DynamicResource App.Brush.Foreground}" FontSize="30" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            <TextBlock Text="Добавьте товары в корзину — пункт выдачи и оплата на следующем шаге"
                       Foreground="{DynamicResource App.Brush.Muted}" FontSize="13" HorizontalAlignment="Center" Margin="0,6,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="24,0,24,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <WrapPanel Grid.Row="0" HorizontalAlignment="Center">
                    <Button Style="{StaticResource QuickActionButton}" Tag="Engine" Click="Category_Click"><TextBlock Text="Двигатель" Foreground="{DynamicResource App.Brush.Foreground}" TextAlignment="Center"/></Button>
                    <Button Style="{StaticResource QuickActionButton}" Tag="Transmission" Click="Category_Click"><TextBlock Text="Трансмиссия" Foreground="{DynamicResource App.Brush.Foreground}" TextAlignment="Center"/></Button>
                    <Button Style="{StaticResource QuickActionButton}" Tag="Body" Click="Category_Click"><TextBlock Text="Кузов" Foreground="{DynamicResource App.Brush.Foreground}" TextAlignment="Center"/></Button>
                    <Button Style="{StaticResource QuickActionButton}" Tag="Tires" Click="Category_Click"><TextBlock Text="Шины" Foreground="{DynamicResource App.Brush.Foreground}" TextAlignment="Center"/></Button>
                    <Button Style="{StaticResource QuickActionButton}" Tag="Accessories" Click="Category_Click"><TextBlock Text="Аксессуары" Foreground="{DynamicResource App.Brush.Foreground}" TextAlignment="Center"/></Button>
                </WrapPanel>

                <ListView Grid.Row="2"
                          ItemsSource="{Binding VisibleProducts}"
                          Background="{DynamicResource App.Brush.Panel}"
                          BorderBrush="{DynamicResource App.Brush.Border}"
                          BorderThickness="1"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.CanContentScroll="False">
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel IsItemsHost="True"/>
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,0,12,12"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Width="240" Height="290" Background="{DynamicResource App.Brush.Surface2}" BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1" CornerRadius="12" Padding="12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="130"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" CornerRadius="10" Background="{DynamicResource App.Brush.PhotoMat}" ClipToBounds="True" Margin="0,0,0,10">
                                        <Grid>
                                            <Image Source="{Binding Photo}" Stretch="UniformToFill"/>
                                            <Border VerticalAlignment="Bottom" Background="{DynamicResource App.Brush.OverlayScrim}" Padding="6" Visibility="{Binding IsPhotoLoading, Converter={StaticResource BoolToVis}}">
                                                <ProgressBar Minimum="0" Maximum="100" Value="{Binding PhotoLoadProgressPercent}" Height="6"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                    <StackPanel Grid.Row="1">
                                        <TextBlock Text="{Binding Name}" Foreground="{DynamicResource App.Brush.Foreground}" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding Description}" Foreground="{DynamicResource App.Brush.Muted}" FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap" MaxHeight="42"/>
                                    </StackPanel>
                                    <Grid Grid.Row="2" Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="{DynamicResource App.Brush.PriceChipBg}" BorderBrush="{DynamicResource App.Brush.Accent}" BorderThickness="1" CornerRadius="10" Padding="10,6">
                                            <TextBlock Text="{Binding PriceLabel}" Foreground="{DynamicResource App.Brush.Foreground}" FontSize="14" FontWeight="SemiBold"/>
                                        </Border>
                                        <Button Grid.Column="1" Content="В корзину" Margin="8,0,0,0" Padding="10,6" Tag="{Binding}" Click="AddToCart_Click"
                                                Style="{StaticResource App.Button.Outline}"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <Border Grid.Column="2" Background="{DynamicResource App.Brush.Surface2}" BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1" CornerRadius="12" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="{Binding CartTitle}" Foreground="{DynamicResource App.Brush.Foreground}" FontSize="18" FontWeight="SemiBold"/>
                    <ListView Grid.Row="1" Margin="0,10,0,10" ItemsSource="{Binding CartItems}" MinHeight="120"
                              Background="{DynamicResource App.Brush.Panel}" BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="6,4">
                                    <Button DockPanel.Dock="Right" Content="−" Width="24" Height="24" Tag="{Binding}" Click="RemoveFromCart_Click"
                                            Style="{StaticResource App.Button.Outline}" Padding="0"/>
                                    <TextBlock Text="{Binding DisplayText}" Foreground="{DynamicResource App.Brush.Foreground}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                </DockPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <TextBlock Grid.Row="2" Text="{Binding CartTotalText}" Foreground="{DynamicResource App.Brush.Foreground}" FontSize="14" FontWeight="SemiBold"/>
                    <Button Grid.Row="3" Content="Оформить заказ" Margin="0,12,0,0" Height="42"
                            Style="{StaticResource App.Button.Primary}" Click="Checkout_Click"/>
                </Grid>
            </Border>
        </Grid>

        <Button Grid.Row="2"
                Content="Назад на главную"
                Width="220"
                Height="40"
                Margin="0,0,0,16"
                HorizontalAlignment="Center"
                Style="{StaticResource App.Button.Outline}"
                Click="Back_Click"/>
    </Grid>
</Page>
