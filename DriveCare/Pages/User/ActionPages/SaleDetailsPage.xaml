<Page x:Class="DriveCare.Pages.User.ActionPages.SaleDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:oxy="http://oxyplot.org/wpf"
      Background="#14141F"
      Title="Карточка объявления">
    <Grid Background="#14141F" Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="{Binding TitleText}" Foreground="White" FontSize="24" FontWeight="SemiBold" TextWrapping="Wrap"/>
            <TextBlock Text="{Binding CarText}" Foreground="#9AA0B0" FontSize="14" Margin="0,6,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.15*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="12" Background="#1A1A28" BorderBrush="#2E2E44" BorderThickness="1" Padding="12" Margin="0,0,14,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" CornerRadius="10" Background="#101018" ClipToBounds="True">
                        <Image Source="{Binding CurrentPhoto}" Stretch="Uniform"/>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="◀"
                                Width="42"
                                Height="32"
                                Margin="0,0,8,0"
                                Background="#222236"
                                Foreground="White"
                                BorderBrush="#2E2E44"
                                BorderThickness="1"
                                Cursor="Hand"
                                Click="PrevPhoto_Click"/>

                        <TextBlock Grid.Column="1"
                                   Text="{Binding PhotoPositionText}"
                                   Foreground="#9AA0B0"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>

                        <Button Grid.Column="2"
                                Content="▶"
                                Width="42"
                                Height="32"
                                Margin="8,0,0,0"
                                Background="#222236"
                                Foreground="White"
                                BorderBrush="#2E2E44"
                                BorderThickness="1"
                                Cursor="Hand"
                                Click="NextPhoto_Click"/>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="1" CornerRadius="12" Background="#1A1A28" BorderBrush="#2E2E44" BorderThickness="1" Padding="14">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="{Binding PriceText}" Foreground="White" FontSize="28" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding SellerText}" Foreground="#9AA0B0" FontSize="13" Margin="0,8,0,0"/>

                        <TextBlock Text="Описание" Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="0,16,0,8"/>
                        <TextBlock Text="{Binding DescriptionText}" Foreground="#D0D5E0" TextWrapping="Wrap"/>

                        <TextBlock Text="Характеристики модели" Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="0,16,0,8"/>
                        <TextBlock Text="{Binding ModelInfoText}" Foreground="#D0D5E0" TextWrapping="Wrap"/>

                        <TextBlock Text="Динамика цены" Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="0,16,0,8"/>
                        <Border Background="#101018" BorderBrush="#2E2E44" BorderThickness="1" CornerRadius="8" Padding="8">
                            <oxy:PlotView Height="180"
                                          Background="Transparent"
                                          Model="{Binding PricePlotModel}"/>
                        </Border>

                        <Button Content="Написать продавцу"
                                Height="40"
                                Margin="0,22,0,0"
                                Background="#7C6CF5"
                                Foreground="White"
                                BorderBrush="#7C6CF5"
                                BorderThickness="1"
                                Cursor="Hand"
                                FontWeight="SemiBold"
                                Click="WriteSeller_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Button Grid.Row="2"
                Content="Назад к объявлениям"
                Width="230"
                Height="40"
                Margin="0,14,0,0"
                HorizontalAlignment="Center"
                Background="#1A1A28"
                Foreground="White"
                BorderBrush="#2E2E44"
                BorderThickness="1"
                Cursor="Hand"
                Click="Back_Click"/>
    </Grid>
</Page>
