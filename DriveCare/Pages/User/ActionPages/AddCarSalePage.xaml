<Page x:Class="DriveCare.Pages.User.ActionPages.AddCarSalePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Добавить объявление"
      Background="#14141F">
    <Page.Resources>
        <Style x:Key="LightComboItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="8,4"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#E9ECFF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#D9DEFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LightComboStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#A6A6A6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource LightComboItemStyle}"/>
        </Style>
    </Page.Resources>
    <Grid Background="#14141F" Margin="20">
        <Border Background="#1A1A28" BorderBrush="Transparent" BorderThickness="0" CornerRadius="12" Padding="18">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
                <StackPanel>
                    <TextBlock Text="Добавить объявление" Foreground="White" FontSize="26" FontWeight="SemiBold"/>
                    <TextBlock Text="Создайте объявление о продаже авто" Foreground="#9AA0B0" Margin="0,8,0,18"/>

                    <TextBlock Text="Автомобиль" Foreground="#9AA0B0" Margin="0,0,0,6"/>
                    <ComboBox x:Name="CarComboBox"
                              ItemsSource="{Binding UserCars}"
                              SelectedItem="{Binding SelectedUserCar}"
                              DisplayMemberPath="DisplayName"
                              Style="{StaticResource LightComboStyle}"/>

                    <TextBlock Text="Заголовок объявления" Foreground="#9AA0B0" Margin="0,14,0,6"/>
                    <TextBox x:Name="TitleTextBox"
                             Text="{Binding SaleTitle, UpdateSourceTrigger=PropertyChanged}"
                             Background="#14141F"
                             Foreground="White"
                             BorderBrush="#2E2E44"
                             BorderThickness="1"
                             Padding="10,8"/>

                    <TextBlock Text="Описание" Foreground="#9AA0B0" Margin="0,14,0,6"/>
                    <TextBox x:Name="DescriptionTextBox"
                             Text="{Binding SaleDescription, UpdateSourceTrigger=PropertyChanged}"
                             Background="#14141F"
                             Foreground="White"
                             BorderBrush="#2E2E44"
                             BorderThickness="1"
                             Padding="10,8"
                             Height="100"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"/>

                    <TextBlock Text="Цена, ₽" Foreground="#9AA0B0" Margin="0,14,0,6"/>
                    <TextBox x:Name="PriceTextBox"
                             Text="{Binding PriceText, UpdateSourceTrigger=PropertyChanged}"
                             Background="#14141F"
                             Foreground="White"
                             BorderBrush="#2E2E44"
                             BorderThickness="1"
                             Padding="10,8"/>

                    <TextBlock Text="Путь к фото (необязательно)" Foreground="#9AA0B0" Margin="0,14,0,6"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="PhotoPathTextBox"
                                 Grid.Column="0"
                                 Text="{Binding PhotoPath, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#14141F"
                                 Foreground="White"
                                 BorderBrush="#2E2E44"
                                 BorderThickness="1"
                                 Padding="10,8"
                                 IsReadOnly="True"/>
                        <Button Grid.Column="2"
                                Content="Выбрать фото"
                                Height="36"
                                Padding="14,0"
                                Background="#222236"
                                Foreground="White"
                                BorderBrush="#2E2E44"
                                BorderThickness="1"
                                Cursor="Hand"
                                Click="SelectPhoto_Click"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                        <Button Content="Сохранить объявление"
                                Width="220"
                                Height="40"
                                Background="#7C6CF5"
                                Foreground="White"
                                BorderBrush="#7C6CF5"
                                BorderThickness="1"
                                Cursor="Hand"
                                Click="Save_Click"/>
                        <Button Content="Отмена"
                                Width="130"
                                Height="40"
                                Margin="10,0,0,0"
                                Background="#222236"
                                Foreground="White"
                                BorderBrush="#2E2E44"
                                BorderThickness="1"
                                Cursor="Hand"
                                Click="Back_Click"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
