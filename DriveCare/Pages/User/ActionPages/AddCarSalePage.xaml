<Page x:Class="DriveCare.Pages.User.ActionPages.AddCarSalePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Добавить объявление">
    <Grid Background="{DynamicResource App.Brush.Panel}" Margin="20">
        <Border Background="{DynamicResource App.Brush.Surface2}" BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1" CornerRadius="12" Padding="18">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
                <StackPanel>
                    <TextBlock Text="Добавить объявление" Foreground="{DynamicResource App.Brush.Foreground}" FontSize="26" FontWeight="SemiBold"/>
                    <TextBlock Text="Создайте объявление о продаже авто" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,8,0,18"/>

                    <TextBlock Text="Автомобиль" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,0,0,6"/>
                    <ComboBox x:Name="CarComboBox"
                              ItemsSource="{Binding UserCars}"
                              SelectedItem="{Binding SelectedUserCar}"
                              DisplayMemberPath="DisplayName"/>

                    <TextBlock Text="Заголовок объявления" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,14,0,6"/>
                    <TextBox x:Name="TitleTextBox"
                             Text="{Binding SaleTitle, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource App.FieldTextBox}"
                             Padding="10,8"/>

                    <TextBlock Text="Описание" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,14,0,6"/>
                    <TextBox x:Name="DescriptionTextBox"
                             Text="{Binding SaleDescription, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource App.FieldTextBox}"
                             Padding="10,8"
                             Height="100"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"/>

                    <TextBlock Text="Цена, ₽" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,14,0,6"/>
                    <TextBox x:Name="PriceTextBox"
                             Text="{Binding PriceText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource App.FieldTextBox}"
                             Padding="10,8"/>

                    <TextBlock Text="Фото объявления (можно несколько)" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,14,0,6"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="PhotoPathTextBox"
                                 Grid.Column="0"
                                 Text="{Binding PhotoPath, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource App.FieldTextBox}"
                                 Padding="10,8"
                                 IsReadOnly="True"/>
                        <Button Grid.Column="2"
                                Content="Добавить фото"
                                Height="36"
                                Padding="14,0"
                                Style="{StaticResource App.Button.Outline}"
                                Click="SelectPhoto_Click"/>
                    </Grid>

                    <Border Background="{DynamicResource App.Brush.FieldInputBg}" BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1" CornerRadius="8" Padding="8" Margin="0,10,0,0">
                        <ListBox ItemsSource="{Binding SelectedPhotoPaths}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{DynamicResource App.Brush.Foreground}"
                                 MaxHeight="140"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2,0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding}"
                                                   Foreground="{DynamicResource App.Brush.SecondaryText}"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"/>
                                        <Button Grid.Column="1"
                                                Width="24"
                                                Height="24"
                                                Margin="8,0,0,0"
                                                Content="✕"
                                                Tag="{Binding}"
                                                Style="{StaticResource App.Button.Outline}"
                                                Padding="0"
                                                Click="RemovePhoto_Click"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                        <Button Content="Сохранить объявление"
                                Width="220"
                                Height="40"
                                Style="{StaticResource App.Button.Primary}"
                                Click="Save_Click"/>
                        <Button Content="Отмена"
                                Width="130"
                                Height="40"
                                Margin="10,0,0,0"
                                Style="{StaticResource App.Button.Outline}"
                                Click="Back_Click"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
