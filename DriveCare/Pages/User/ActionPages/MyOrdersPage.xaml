<Page x:Class="DriveCare.Pages.User.ActionPages.MyOrdersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:shop="clr-namespace:DriveCareCore.Shop;assembly=DriveCareCore"
      Title="Мои заказы">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>

    <Grid Background="{DynamicResource App.Brush.Panel}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="24,18,24,12" LastChildFill="False">
            <Button DockPanel.Dock="Left" Content="← Назад" Style="{StaticResource App.Button.Outline}"
                    Height="40" MinWidth="120" Click="Back_Click"/>
            <StackPanel DockPanel.Dock="Left" Margin="20,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="Мои заказы" FontSize="22" FontWeight="SemiBold"
                           Foreground="{DynamicResource App.Brush.Foreground}"/>
                <TextBlock Text="Магазин · пункты выдачи по Санкт-Петербургу"
                           FontSize="13" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,4,0,0"/>
            </StackPanel>
        </DockPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,0,24,28">
            <StackPanel MaxWidth="720">
                <TextBlock x:Name="EmptyText" Text="Заказов пока нет. Оформите заказ в магазине."
                           Foreground="{DynamicResource App.Brush.Muted}" FontSize="14" Margin="0,8,0,0"
                           Visibility="Collapsed"/>
                <ItemsControl x:Name="OrdersList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type shop:StoreOrderListItem}">
                            <Border Background="{DynamicResource App.Brush.Surface2}"
                                    BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1"
                                    CornerRadius="12" Padding="14,12" Margin="0,0,0,10">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding OrderNumber}" FontSize="16" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource App.Brush.Foreground}"/>
                                            <TextBlock Text="{Binding DateLabel}" FontSize="12" Margin="0,4,0,0"
                                                       Foreground="{DynamicResource App.Brush.Muted}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding TotalLabel}" FontSize="15" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource App.Brush.Accent}" VerticalAlignment="Center"/>
                                    </Grid>
                                    <TextBlock Text="{Binding StatusLabel}" FontSize="13" Margin="0,8,0,0"
                                               Foreground="{DynamicResource App.Brush.SecondaryText}"/>
                                    <TextBlock Text="{Binding PickupName}" FontSize="13" Margin="0,4,0,0"
                                               Foreground="{DynamicResource App.Brush.Foreground}"/>
                                    <TextBlock Text="{Binding PickupAddress}" FontSize="12" TextWrapping="Wrap"
                                               Foreground="{DynamicResource App.Brush.Muted}"/>
                                    <Button Content="Оплатить по QR" Margin="0,12,0,0" HorizontalAlignment="Left"
                                            Style="{StaticResource App.Button.Primary}" Height="36" MinWidth="140"
                                            Tag="{Binding}" Click="PayOrder_Click"
                                            Visibility="{Binding CanPay, Converter={StaticResource BoolToVis}}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
