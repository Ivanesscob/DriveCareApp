<Page x:Class="DriveCare.Pages.User.ActionPages.StoreCheckoutPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:DriveCare.Controls"
      Title="Оформление заказа"
      Background="{DynamicResource App.Brush.PageBackground}">
    <Grid Margin="20,16,20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,10" LastChildFill="False">
            <Button DockPanel.Dock="Left" Content="← Назад" Style="{StaticResource App.Button.Outline}"
                    Height="40" MinWidth="110" Click="Back_Click"/>
            <StackPanel DockPanel.Dock="Left" Margin="16,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="Оформление заказа" FontSize="22" FontWeight="SemiBold"
                           Foreground="{DynamicResource App.Brush.Foreground}"/>
                <TextBlock Text="Шаг 1 — пункт на карте · шаг 2 — оплата справа"
                           FontSize="13" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,4,0,0"/>
            </StackPanel>
        </DockPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,8">
            <TextBlock x:Name="TotalHintText" FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource App.Brush.Foreground}"/>
            <WrapPanel x:Name="DistrictFilterPanel" Margin="0,8,0,0"/>
            <TextBlock x:Name="MapStatusText" FontSize="12" TextWrapping="Wrap" Margin="0,6,0,0"
                       Foreground="{DynamicResource App.Brush.Muted}"/>
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="360" MinWidth="320"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="14" BorderBrush="{DynamicResource App.Brush.Border}"
                    BorderThickness="1" Background="{DynamicResource App.Brush.SurfaceCard}" ClipToBounds="True">
                <controls:YandexWorkshopMapView x:Name="PickupMap"/>
            </Border>

            <Border Grid.Column="2" CornerRadius="14" Padding="16"
                    Background="{DynamicResource App.Brush.SurfaceCard}"
                    BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Куда забрать заказ" FontSize="17" FontWeight="SemiBold"
                               Foreground="{DynamicResource App.Brush.Foreground}"/>
                    <TextBlock x:Name="PickupHintText" Grid.Row="1" Margin="0,8,0,12" FontSize="13" TextWrapping="Wrap"
                               Foreground="{DynamicResource App.Brush.Muted}"
                               Text="Нажмите метку на карте или «Выбрать» в подсказке."/>

                    <StackPanel x:Name="PaymentPanel" Grid.Row="2" Visibility="Collapsed">
                        <TextBlock x:Name="SelectedPickupTitle" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap"
                                   Foreground="{DynamicResource App.Brush.Foreground}"/>
                        <TextBlock x:Name="SelectedPickupAddress" FontSize="12" TextWrapping="Wrap" Margin="0,6,0,12"
                                   Foreground="{DynamicResource App.Brush.SecondaryText}"/>
                        <TextBlock Text="Оплата по QR (демо)" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource App.Brush.Foreground}" Margin="0,0,0,8"/>
                        <Border Background="White" CornerRadius="8" Padding="8" HorizontalAlignment="Left"
                                BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">
                            <Image x:Name="QrImage" Width="160" Height="160" Stretch="Uniform"/>
                        </Border>
                        <TextBlock x:Name="PaymentErrorText" FontSize="12" TextWrapping="Wrap" Margin="0,10,0,0"
                                   Foreground="{DynamicResource App.Brush.DangerFg}" Visibility="Collapsed"/>
                    </StackPanel>

                    <Button x:Name="PayButton" Grid.Row="3" Content="Оплатил" Height="42" Margin="0,12,0,0"
                            Style="{StaticResource App.Button.Primary}" IsEnabled="False" Click="PayButton_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
