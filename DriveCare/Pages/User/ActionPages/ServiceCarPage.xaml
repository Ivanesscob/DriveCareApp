<Page x:Class="DriveCare.Pages.User.ActionPages.ServiceCarPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Обслуживание">
    <Grid Background="{DynamicResource App.Brush.Panel}">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="24">
            <TextBlock Text="Обслуживание" Foreground="{DynamicResource App.Brush.Foreground}" FontSize="26" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            <TextBlock Text="Страница-заглушка" Foreground="{DynamicResource App.Brush.Muted}" FontSize="14" Margin="0,8,0,12" HorizontalAlignment="Center"/>
            <Button Content="Назад на главную"
                    Style="{StaticResource App.Button.Outline}"
                    Width="220" Height="40"
                    HorizontalAlignment="Center"
                    Click="Back_Click"/>
        </StackPanel>
    </Grid>
</Page>
