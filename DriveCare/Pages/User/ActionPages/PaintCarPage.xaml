<Page x:Class="DriveCare.Pages.User.ActionPages.PaintCarPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Покраска машины">
    <Grid Background="#14141F">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,24,0,0" HorizontalAlignment="Center">
            <TextBlock Text="Покраска машины" Foreground="White" FontSize="30" FontWeight="SemiBold" HorizontalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Страница-заглушка" Foreground="#9AA0B0" FontSize="14" Margin="0,8,0,20" HorizontalAlignment="Center"/>
            <Button Content="Назад на главную" Width="220" Height="42" Click="Back_Click"/>
        </StackPanel>
    </Grid>
</Page>

