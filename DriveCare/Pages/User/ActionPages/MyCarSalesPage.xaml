<Page x:Class="DriveCare.Pages.User.ActionPages.MyCarSalesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Мои объявления">
    <Grid Background="{DynamicResource App.Brush.Panel}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="24,18,24,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource App.Brush.Surface2}" BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1" CornerRadius="10" Padding="10,4">
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="{DynamicResource App.Brush.Foreground}"
                         FontSize="14"
                         CaretBrush="{DynamicResource App.Brush.Foreground}"
                         VerticalContentAlignment="Center"
                         ToolTip="Поиск по названию, марке, модели, цвету"/>
            </Border>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0">
                <Button Content="Каталог"
                        Height="40"
                        Margin="0,0,10,0"
                        Style="{StaticResource App.Button.Outline}"
                        Click="Catalog_Click"/>
                <Button Content="Добавить объявление"
                        Height="40"
                        Style="{StaticResource App.Button.Primary}"
                        Click="AddAd_Click"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="24,0,24,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="270"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource App.Brush.Surface2}" BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1" CornerRadius="12" Padding="14">
                <StackPanel>
                    <TextBlock Text="Фильтры" Foreground="{DynamicResource App.Brush.Foreground}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>

                    <TextBlock Text="Цена, ₽" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding MinPriceText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource App.FieldTextBox}"/>
                        <TextBox Grid.Column="2" Text="{Binding MaxPriceText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource App.FieldTextBox}"/>
                    </Grid>

                    <TextBlock Text="Марка" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{Binding Brands}"
                              SelectedItem="{Binding SelectedBrand}"
                              Margin="0,0,0,10"/>

                    <TextBlock Text="Модель" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{Binding Models}"
                              SelectedItem="{Binding SelectedModel}"
                              Margin="0,0,0,10"/>

                    <TextBlock Text="Год выпуска" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding MinYearText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource App.FieldTextBox}"/>
                        <TextBox Grid.Column="2" Text="{Binding MaxYearText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource App.FieldTextBox}"/>
                    </Grid>

                    <Button Content="Сбросить фильтры"
                            Height="36"
                            Style="{StaticResource App.Button.Outline}"
                            Click="ClearFilters_Click"/>
                </StackPanel>
            </Border>

            <Grid Grid.Column="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.45*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <ListView Grid.Column="0"
                          ItemsSource="{Binding SalesItems}"
                          SelectedItem="{Binding SelectedSale, Mode=TwoWay}"
                          Background="{DynamicResource App.Brush.Panel}"
                          BorderBrush="{DynamicResource App.Brush.Border}"
                          BorderThickness="1"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.CanContentScroll="False">
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel IsItemsHost="True"/>
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,0,12,12"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Width="260" Height="300" Background="{DynamicResource App.Brush.Surface2}" BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1" CornerRadius="12" Padding="12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="140"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" CornerRadius="10" Background="{DynamicResource App.Brush.PhotoMat}" ClipToBounds="True" Margin="0,0,0,10">
                                        <Image Source="{Binding Photo}" Stretch="UniformToFill"/>
                                    </Border>

                                    <StackPanel Grid.Row="1">
                                        <TextBlock Text="{Binding CarLabel}" Foreground="{DynamicResource App.Brush.Foreground}" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding SellerLabel}" Foreground="{DynamicResource App.Brush.Muted}" FontSize="13" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding ModerationStatus}" Foreground="{DynamicResource App.Brush.Accent}" FontSize="12" FontWeight="SemiBold" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding ModelInfoLabel}"
                                                   Foreground="{DynamicResource App.Brush.TextDim}"
                                                   FontSize="12"
                                                   Margin="0,6,0,0"
                                                   TextWrapping="Wrap"
                                                   MaxHeight="48"/>
                                    </StackPanel>

                                    <Border Grid.Row="2" Background="{DynamicResource App.Brush.PriceChipBg}" BorderBrush="{DynamicResource App.Brush.Accent}" BorderThickness="1" CornerRadius="10" Padding="12,6" HorizontalAlignment="Left" Margin="0,10,0,0">
                                        <TextBlock Text="{Binding PriceLabel}" Foreground="{DynamicResource App.Brush.Foreground}" FontSize="15" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <EventSetter Event="MouseLeftButtonDown" Handler="SaleCard_MouseLeftButtonDown"/>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Border Grid.Column="2" Background="{DynamicResource App.Brush.Surface2}" BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1" CornerRadius="12" Padding="12">
                    <StackPanel>
                        <TextBlock Text="Редактирование" Foreground="{DynamicResource App.Brush.Foreground}" FontSize="18" FontWeight="SemiBold"/>
                        <TextBlock Text="Выберите объявление слева" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,4,0,12"/>

                        <TextBlock Text="Описание" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding EditableDescription, UpdateSourceTrigger=PropertyChanged}"
                                 Height="80"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 Style="{StaticResource App.FieldTextBox}"
                                 Padding="8,6"/>

                        <TextBlock Text="Новая цена, ₽" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,10,0,6"/>
                        <TextBox Text="{Binding EditablePriceText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource App.FieldTextBox}"/>

                        <TextBlock Text="{Binding SelectedSaleTitle}" Foreground="{DynamicResource App.Brush.Foreground}" Margin="0,10,0,6" TextWrapping="Wrap"/>

                        <TextBlock Text="Фото" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,0,0,6"/>
                        <ListBox ItemsSource="{Binding EditablePhotos}"
                                 Background="{DynamicResource App.Brush.FieldInputBg}"
                                 Foreground="{DynamicResource App.Brush.FieldInputFg}"
                                 BorderBrush="{DynamicResource App.Brush.Border}"
                                 BorderThickness="1"
                                 Height="120">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="4,2">
                                        <Button Content="Удалить"
                                                Tag="{Binding}"
                                                Click="RemoveEditPhoto_Click"
                                                DockPanel.Dock="Right"
                                                Margin="8,0,0,0"
                                                Height="24"
                                                Padding="8,0"
                                                Style="{StaticResource App.Button.Outline}"/>
                                        <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource App.Brush.Foreground}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    </DockPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Button Content="Добавить фото"
                                Height="32"
                                Margin="0,8,0,0"
                                Style="{StaticResource App.Button.Outline}"
                                Click="AddEditPhoto_Click"/>

                        <Button Content="Сохранить изменения"
                                Height="36"
                                Margin="0,12,0,0"
                                Style="{StaticResource App.Button.Primary}"
                                Click="SaveChanges_Click"/>

                        <Button Content="Удалить объявление"
                                Height="36"
                                Margin="0,8,0,0"
                                Background="{DynamicResource App.Brush.DangerPanel}"
                                Foreground="{DynamicResource App.Brush.DangerFg}"
                                BorderBrush="{DynamicResource App.Brush.DangerAccentBorder}"
                                BorderThickness="1"
                                Cursor="Hand"
                                Click="DeleteSale_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <Button Grid.Row="2"
                Content="Назад к объявлениям"
                Width="220"
                Height="40"
                Margin="0,0,0,16"
                HorizontalAlignment="Center"
                Style="{StaticResource App.Button.Outline}"
                Click="Back_Click"/>
    </Grid>
</Page>
