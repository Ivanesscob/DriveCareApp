<Window x:Class="DriveCare.Windows.StoreOrderPaymentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Оплата заказа"
        Width="480" Height="520" MinWidth="420" MinHeight="480"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource App.Brush.Panel}">
    <Border Padding="20" Background="{DynamicResource App.Brush.Panel}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="8"
                    BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1"
                    VerticalAlignment="Top">
                <Image x:Name="QrImage" Width="180" Height="180" Stretch="Uniform"/>
            </Border>

            <StackPanel Grid.Column="2" VerticalAlignment="Top">
                <TextBlock Text="Оплата по QR" FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource App.Brush.Foreground}"/>
                <TextBlock Text="Демо-режим: отсканируйте код в приложении банка или нажмите «Оплатил»."
                           FontSize="12" TextWrapping="Wrap" Margin="0,8,0,12"
                           Foreground="{DynamicResource App.Brush.Muted}"/>
                <TextBlock x:Name="OrderNumberText" FontSize="15" FontWeight="SemiBold"
                           Foreground="{DynamicResource App.Brush.Foreground}"/>
                <TextBlock x:Name="TotalText" FontSize="14" Margin="0,6,0,0"
                           Foreground="{DynamicResource App.Brush.Accent}"/>
                <TextBlock x:Name="PickupText" FontSize="13" TextWrapping="Wrap" Margin="0,10,0,0"
                           Foreground="{DynamicResource App.Brush.SecondaryText}"/>
                <TextBlock x:Name="ErrorText" FontSize="12" TextWrapping="Wrap" Margin="0,12,0,0"
                           Foreground="{DynamicResource App.Brush.DangerFg}" Visibility="Collapsed"/>
            </StackPanel>

            <StackPanel Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal"
                        HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,24,0,0">
                <Button Content="Отмена" Style="{StaticResource App.Button.Outline}"
                        MinWidth="100" Height="38" Margin="0,0,10,0" IsCancel="True" Click="Cancel_Click"/>
                <Button Content="Оплатил" Style="{StaticResource App.Button.Primary}"
                        MinWidth="120" Height="38" IsDefault="True" Click="Paid_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
