<Window x:Class="DriveCare.Windows.EnterRealMileageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Реальный пробег"
        Width="400" Height="240" MinWidth="360" MinHeight="220"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource App.Brush.Panel}">
    <Border Padding="20" Background="{DynamicResource App.Brush.Panel}">
        <StackPanel>
            <TextBlock Text="Пробег с одометра" FontSize="18" FontWeight="SemiBold"
                       Foreground="{DynamicResource App.Brush.Foreground}"/>
            <TextBlock x:Name="HintText" Margin="0,8,0,12" FontSize="13" TextWrapping="Wrap"
                       Foreground="{DynamicResource App.Brush.Muted}"/>
            <TextBox x:Name="MileageBox" Style="{StaticResource App.FieldTextBox}"
                     MinHeight="40" FontSize="16" InputMethod.IsInputMethodEnabled="False"/>
            <TextBlock x:Name="ErrorText" Margin="0,8,0,0" FontSize="12" TextWrapping="Wrap"
                       Foreground="{DynamicResource App.Brush.DangerBorder}" Visibility="Collapsed"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="Отмена" Style="{StaticResource App.Button.Outline}"
                        MinWidth="100" Height="36" Margin="0,0,10,0" IsCancel="True" Click="Cancel_Click"/>
                <Button Content="Сохранить" Style="{StaticResource App.Button.Primary}"
                        MinWidth="110" Height="36" IsDefault="True" Click="Save_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
