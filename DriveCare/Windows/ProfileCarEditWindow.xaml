<Window x:Class="DriveCare.Windows.ProfileCarEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Автомобиль" Height="560" Width="480"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource App.Brush.Panel}">
    <Grid Margin="22,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleText" Text="Добавить автомобиль" FontSize="20" FontWeight="SemiBold"
                   Foreground="{DynamicResource App.Brush.Foreground}" Margin="0,0,0,14"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Марка *" FontSize="12" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,0,0,4"/>
                <ComboBox x:Name="BrandCombo" Height="38" DisplayMemberPath="Name" Margin="0,0,0,10"
                          SelectionChanged="BrandCombo_SelectionChanged"/>

                <TextBlock Text="Модель *" FontSize="12" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,0,0,4"/>
                <ComboBox x:Name="ModelCombo" Height="38" DisplayMemberPath="Name" Margin="0,0,0,10"/>

                <TextBlock Text="Тип кузова *" FontSize="12" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,0,0,4"/>
                <ComboBox x:Name="CarTypeCombo" Height="38" DisplayMemberPath="Name" Margin="0,0,0,10"/>

                <TextBlock Text="Топливо *" FontSize="12" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,0,0,4"/>
                <ComboBox x:Name="FuelTypeCombo" Height="38" DisplayMemberPath="Name" Margin="0,0,0,10"/>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Год выпуска" FontSize="12" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,0,0,4"/>
                        <TextBox x:Name="YearBox" Height="38" Padding="10,0" VerticalContentAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Гос. номер" FontSize="12" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,0,0,4"/>
                        <TextBox x:Name="PlateBox" Height="38" Padding="10,0" VerticalContentAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="VIN" FontSize="12" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,0,0,4"/>
                <TextBox x:Name="VinBox" Height="38" Padding="10,0" VerticalContentAlignment="Center" Margin="0,0,0,10"/>

                <TextBlock Text="Заметка" FontSize="12" Foreground="{DynamicResource App.Brush.Muted}" Margin="0,0,0,4"/>
                <TextBox x:Name="NoteBox" Height="60" Padding="10,8" TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Отмена" Height="40" MinWidth="100" Margin="0,0,10,0" Click="Cancel_Click"/>
            <Button Content="Сохранить" Height="40" MinWidth="120" Click="Save_Click"
                    Foreground="White" Background="{DynamicResource App.Brush.Accent}"/>
        </StackPanel>
    </Grid>
</Window>
