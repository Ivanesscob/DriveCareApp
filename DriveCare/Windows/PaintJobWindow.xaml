<Window x:Class="DriveCare.Windows.PaintJobWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="Покраска"
        Width="480" Height="500" MinWidth="440" MinHeight="460"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource App.Brush.PageBackground}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="22,20,22,18">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#FF0D9488" Offset="0"/>
                    <GradientStop Color="#FF14B8A6" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconModern x:Name="HeaderIcon" Kind="DrawPaintbrush" Width="26" Height="26"
                                              Foreground="{DynamicResource App.Brush.TextOnAccent}" Margin="0,0,10,0"/>
                    <TextBlock x:Name="TitleText" FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource App.Brush.TextOnAccent}" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock x:Name="HintText" Margin="0,8,0,0" FontSize="13" TextWrapping="Wrap"
                           Foreground="#E6FFFFFF"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Padding="22,18,22,20" Background="{DynamicResource App.Brush.Panel}">
            <StackPanel>
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="ColorPreviewOuter" Width="56" Height="56" CornerRadius="28"
                            BorderThickness="3" VerticalAlignment="Top" Margin="0,0,14,0"
                            Background="{DynamicResource App.Brush.Surface2}">
                        <Border x:Name="ColorPreviewInner" Width="44" Height="44" CornerRadius="22"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                BorderThickness="2"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Превью цвета" FontSize="12"
                                   Foreground="{DynamicResource App.Brush.Muted}"/>
                        <TextBlock x:Name="PreviewColorNameText" FontSize="15" FontWeight="SemiBold" Margin="0,4,0,0"
                                   Foreground="{DynamicResource App.Brush.Foreground}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Цвет из справочника" Foreground="{DynamicResource App.Brush.Muted}" FontSize="12" Margin="0,0,0,4"/>
                <ComboBox x:Name="ColorCombo" MinHeight="44" DisplayMemberPath="Name"
                          SelectionChanged="ColorCombo_SelectionChanged"/>

                <TextBlock Text="или свой цвет" Foreground="{DynamicResource App.Brush.Muted}" FontSize="12" Margin="0,12,0,4"/>
                <TextBox x:Name="CustomColorBox" Style="{StaticResource App.FieldTextBox}" MinHeight="44"
                         TextChanged="CustomColorBox_TextChanged"/>

                <StackPanel x:Name="PartPanel" Margin="0,12,0,0" Visibility="Collapsed">
                    <TextBlock Text="Название детали" Foreground="{DynamicResource App.Brush.Muted}" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox x:Name="PartNameBox" Style="{StaticResource App.FieldTextBox}" MinHeight="44"/>
                </StackPanel>

                <TextBlock Text="Комментарий (необязательно)" Foreground="{DynamicResource App.Brush.Muted}" FontSize="12" Margin="0,12,0,4"/>
                <TextBox x:Name="NotesBox" Style="{StaticResource App.FieldTextBox}" MinHeight="56" TextWrapping="Wrap" AcceptsReturn="True"/>

                <TextBlock x:Name="ErrorText" Margin="0,10,0,0" FontSize="12" TextWrapping="Wrap"
                           Foreground="{DynamicResource App.Brush.DangerBorder}" Visibility="Collapsed"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                    <Button Content="Отмена" Style="{StaticResource App.Button.Outline}"
                            MinWidth="100" Height="38" Margin="0,0,10,0" IsCancel="True" Click="Cancel_Click"/>
                    <Button Content="Сохранить" Style="{StaticResource App.Button.Primary}"
                            MinWidth="120" Height="38" IsDefault="True" Click="Save_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
