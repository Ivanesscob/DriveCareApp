<Window x:Class="DriveCare.Windows.WorkshopReviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Оценка сервиса"
        Width="480" Height="560" MinWidth="420" MinHeight="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource App.Brush.Panel}">
    <Border Padding="22" Background="{DynamicResource App.Brush.Panel}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock x:Name="TitleText" Text="Оцените автосервис" FontSize="20" FontWeight="SemiBold"
                           Foreground="{DynamicResource App.Brush.Foreground}"/>
                <TextBlock x:Name="WorkshopText" Margin="0,6,0,0" FontSize="13" TextWrapping="Wrap"
                           Foreground="{DynamicResource App.Brush.Muted}"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="0,18,0,0">
                <TextBlock Text="Ваша оценка" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource App.Brush.Foreground}"/>
                <StackPanel x:Name="StarsPanel" Orientation="Horizontal" Margin="0,10,0,0">
                    <Button x:Name="Star1" Content="★" Tag="1" Width="44" Height="44" Margin="0,0,6,0"
                            FontSize="22" Click="Star_Click" Style="{StaticResource App.Button.Outline}"/>
                    <Button x:Name="Star2" Content="★" Tag="2" Width="44" Height="44" Margin="0,0,6,0"
                            FontSize="22" Click="Star_Click" Style="{StaticResource App.Button.Outline}"/>
                    <Button x:Name="Star3" Content="★" Tag="3" Width="44" Height="44" Margin="0,0,6,0"
                            FontSize="22" Click="Star_Click" Style="{StaticResource App.Button.Outline}"/>
                    <Button x:Name="Star4" Content="★" Tag="4" Width="44" Height="44" Margin="0,0,6,0"
                            FontSize="22" Click="Star_Click" Style="{StaticResource App.Button.Outline}"/>
                    <Button x:Name="Star5" Content="★" Tag="5" Width="44" Height="44"
                            FontSize="22" Click="Star_Click" Style="{StaticResource App.Button.Outline}"/>
                </StackPanel>
                <TextBlock x:Name="RatingHintText" Margin="0,8,0,0" FontSize="12"
                           Foreground="{DynamicResource App.Brush.Muted}" Text="Нажмите на звезду"/>
            </StackPanel>

            <ScrollViewer Grid.Row="2" Margin="0,16,0,0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Плюсы" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource App.Brush.Foreground}"/>
                    <TextBox x:Name="ProsBox" Style="{StaticResource App.FieldTextBox}" MinHeight="64"
                             TextWrapping="Wrap" AcceptsReturn="True" Margin="0,6,0,12"
                             ToolTip="Что понравилось"/>

                    <TextBlock Text="Минусы" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource App.Brush.Foreground}"/>
                    <TextBox x:Name="ConsBox" Style="{StaticResource App.FieldTextBox}" MinHeight="64"
                             TextWrapping="Wrap" AcceptsReturn="True" Margin="0,6,0,12"
                             ToolTip="Что можно улучшить"/>

                    <TextBlock Text="Отзыв" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource App.Brush.Foreground}"/>
                    <TextBox x:Name="CommentBox" Style="{StaticResource App.FieldTextBox}" MinHeight="80"
                             TextWrapping="Wrap" AcceptsReturn="True" Margin="0,6,0,0"/>
                    <TextBlock x:Name="ErrorText" Margin="0,10,0,0" FontSize="12" TextWrapping="Wrap"
                               Foreground="{DynamicResource App.Brush.DangerBorder}" Visibility="Collapsed"/>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="Отмена" Style="{StaticResource App.Button.Outline}"
                        MinWidth="100" Height="38" Margin="0,0,10,0" IsCancel="True" Click="Cancel_Click"/>
                <Button Content="Отправить" Style="{StaticResource App.Button.Primary}"
                        MinWidth="120" Height="38" IsDefault="True" Click="Save_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
