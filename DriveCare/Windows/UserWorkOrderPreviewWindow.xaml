<Window x:Class="DriveCare.Windows.UserWorkOrderPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Заказ-наряд"
        Width="720" Height="640" MinWidth="560" MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource App.Brush.Panel}"
        ResizeMode="CanResizeWithGrip">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock x:Name="TitleText" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap"
                       Foreground="{DynamicResource App.Brush.Foreground}"/>
            <TextBlock x:Name="WorkshopText" Margin="0,6,0,0" FontSize="13" TextWrapping="Wrap"
                       Foreground="{DynamicResource App.Brush.SecondaryText}"/>
            <TextBlock x:Name="ReasonText" Margin="0,4,0,0" FontSize="12" TextWrapping="Wrap"
                       Foreground="{DynamicResource App.Brush.Muted}"/>
            <TextBlock x:Name="MetaText" Margin="0,4,0,0" FontSize="12" TextWrapping="Wrap"
                       Foreground="{DynamicResource App.Brush.Muted}"/>
        </StackPanel>

        <TabControl x:Name="PreviewTabs" Grid.Row="1" Margin="0,14,0,0" Background="Transparent" BorderThickness="0"
                    SelectionChanged="PreviewTabs_SelectionChanged">
            <TabItem Header="Услуги">
                <DataGrid x:Name="ServicesGrid" AutoGenerateColumns="False" IsReadOnly="True"
                          HeadersVisibility="Column" CanUserAddRows="False" MinHeight="120"
                          AlternatingRowBackground="{DynamicResource App.Brush.Surface2}"
                          Foreground="{DynamicResource App.Brush.Foreground}" RowHeight="32"
                          Background="{DynamicResource App.Brush.SurfaceCard}"
                          BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="2*" MinWidth="160"/>
                        <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity, StringFormat=N2}" Width="65"/>
                        <DataGridTextColumn Header="Ед." Binding="{Binding UnitName}" Width="50"/>
                        <DataGridTextColumn Header="Цена" Binding="{Binding UnitPrice, StringFormat=N2}" Width="75"/>
                        <DataGridTextColumn Header="Сумма" Binding="{Binding LineAmount, StringFormat=N2}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Запчасти">
                <DataGrid x:Name="PartsGrid" AutoGenerateColumns="False" IsReadOnly="True"
                          HeadersVisibility="Column" CanUserAddRows="False" MinHeight="120"
                          AlternatingRowBackground="{DynamicResource App.Brush.Surface2}"
                          Foreground="{DynamicResource App.Brush.Foreground}" RowHeight="32"
                          Background="{DynamicResource App.Brush.SurfaceCard}"
                          BorderBrush="{DynamicResource App.Brush.Border}" BorderThickness="1">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="2*" MinWidth="160"/>
                        <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity, StringFormat=N2}" Width="65"/>
                        <DataGridTextColumn Header="Ед." Binding="{Binding UnitName}" Width="50"/>
                        <DataGridTextColumn Header="Цена" Binding="{Binding UnitPrice, StringFormat=N2}" Width="75"/>
                        <DataGridTextColumn Header="Сумма" Binding="{Binding LineAmount, StringFormat=N2}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Комментарий">
                <TextBox x:Name="ReportTextBox" IsReadOnly="True" TextWrapping="Wrap"
                         AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                         Style="{StaticResource App.FieldTextBox}" BorderThickness="1"/>
            </TabItem>
        </TabControl>

        <Button Grid.Row="2" Content="Закрыть" Style="{StaticResource App.Button.Primary}"
                HorizontalAlignment="Right" MinWidth="120" Height="40" Margin="0,14,0,0"
                Click="Close_Click"/>
    </Grid>
</Window>
